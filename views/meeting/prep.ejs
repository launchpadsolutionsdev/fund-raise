<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">Meeting Prep</div>
        <div class="page-subtitle">AI-generated briefing documents using your live fundraising data</div>
    </div>
</div>

<style>
/* ── Meeting Prep Hero ── */
.mp-hero {
    margin: 0 0 28px;
    background: linear-gradient(135deg, #0f766e 0%, #0d9488 40%, #14b8a6 100%);
    border-radius: 16px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    gap: 36px;
    color: #fff;
    box-shadow: 0 4px 24px rgba(13, 148, 136, 0.2);
}
.mp-hero-icon {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
}
.mp-hero-text h2 {
    margin: 0 0 6px;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.3px;
}
.mp-hero-text p {
    margin: 0 0 16px;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
}
.mp-hero-features {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.mp-hero-feat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
}
.mp-hero-feat i { color: #99f6e4; font-size: 12px; }

/* ── Data badge ── */
.mp-data-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
    color: #99f6e4;
    margin-bottom: 12px;
}
.mp-data-badge i { font-size: 14px; }

/* ── Page layout ── */
.mp-page-wrap {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 120px);
}
.mp-hero { flex-shrink: 0; }

/* ── Workspace ── */
.mp-workspace {
    display: grid;
    grid-template-columns: minmax(340px, 380px) 1fr;
    gap: 20px;
    align-items: stretch;
    flex: 1;
    min-height: 0;
}
.mp-input-panel {
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-primary);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.mp-input-panel .mp-section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--color-text-tertiary);
    margin-bottom: 14px;
}
.mp-input-panel .mp-section-label i { font-size: 13px; color: #0d9488; }

.mp-input-panel {
    overflow-y: auto;
}
.mp-output-card {
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-primary);
    border-radius: 16px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    overflow: hidden;
}
.mp-output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border-primary);
    background: var(--color-background-secondary);
}
.mp-output-header-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
}
.mp-output-header-title i { color: #0d9488; }
.mp-output-body {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    min-height: 0;
}
.mp-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 30px;
    text-align: center;
}
.mp-empty-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f0fdfa, #ccfbf1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: #0d9488;
    margin-bottom: 16px;
}
.mp-empty-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 6px;
}
.mp-empty-desc {
    font-size: 12px;
    color: var(--color-text-tertiary);
    line-height: 1.6;
    max-width: 280px;
}

@media (max-width: 840px) {
    .mp-hero { flex-direction: column; text-align: center; padding: 28px 24px; }
    .mp-hero-features { justify-content: center; }
    .mp-workspace { grid-template-columns: 1fr; }
}
</style>

<!-- Page Wrap -->
<div class="mp-page-wrap">

<!-- Hero Card -->
<div class="mp-hero">
    <div class="mp-hero-icon"><i class="bi bi-briefcase"></i></div>
    <div class="mp-hero-text">
        <div class="mp-data-badge"><i class="bi bi-database-fill-check"></i> Powered by Your Live Data</div>
        <h2>Walk In Prepared, Walk Out Impressed</h2>
        <p>Generate data-driven briefing documents with talking points, KPI summaries, and discussion questions — all tailored to your meeting type and audience.</p>
        <div class="mp-hero-features">
            <span class="mp-hero-feat"><i class="bi bi-check-circle-fill"></i> Board Presentations</span>
            <span class="mp-hero-feat"><i class="bi bi-check-circle-fill"></i> Donor Meetings</span>
            <span class="mp-hero-feat"><i class="bi bi-check-circle-fill"></i> Strategy Sessions</span>
            <span class="mp-hero-feat"><i class="bi bi-check-circle-fill"></i> Year-End Reviews</span>
        </div>
    </div>
</div>

<!-- Workspace -->
<div class="mp-workspace">
    <div class="mp-input-panel">
        <div class="mp-section-label"><i class="bi bi-calendar-event"></i> Meeting Configuration</div>

        <div class="we-template-wrap" id="weTemplateWrap">
            <div class="we-template-label">
                <span><i class="bi bi-lightning-charge-fill"></i> Quick start</span>
            </div>
            <div id="weTemplateRail"></div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Meeting Type</div>
            <div class="writing-options" id="typeOptions">
                <button class="writing-option active" data-val="Board Presentation">Board Presentation</button>
                <button class="writing-option" data-val="Donor Meeting">Donor Meeting</button>
                <button class="writing-option" data-val="Department Check-In">Dept Check-In</button>
                <button class="writing-option" data-val="Campaign Strategy Session">Strategy Session</button>
                <button class="writing-option" data-val="Year-End Review">Year-End Review</button>
                <button class="writing-option" data-val="New Donor Cultivation">Donor Cultivation</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Focus Department (optional)</div>
            <select class="form-input" id="deptSelect">
                <option value="">All / Organization-wide</option>
                <option value="annual_giving">Annual Giving</option>
                <option value="direct_mail">Direct Mail</option>
                <option value="events">Events</option>
                <option value="major_gifts">Major Gifts</option>
                <option value="legacy_giving">Legacy Giving</option>
            </select>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Attendees (optional)</div>
            <input type="text" class="form-input" id="attendees" placeholder="e.g. Board Chair, VP Development, Major Gifts team">
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Duration (minutes)</div>
            <div class="writing-options" id="durationOptions">
                <button class="writing-option" data-val="15">15</button>
                <button class="writing-option" data-val="30">30</button>
                <button class="writing-option active" data-val="60">60</button>
                <button class="writing-option" data-val="90">90</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Agenda Notes (optional)</div>
            <textarea class="form-input form-textarea" id="agenda" rows="4" placeholder="Key topics to cover, specific questions to address..."></textarea>
        </div>

        <button class="btn-brand" id="generateBtn" style="width:100%;">
            <i class="bi bi-stars"></i> Generate Briefing
        </button>
    </div>

    <div class="mp-output-card">
        <div class="mp-output-header" style="position:relative;">
            <span class="mp-output-header-title"><i class="bi bi-file-earmark-richtext"></i> Meeting Briefing</span>
            <div style="display:flex;gap:6px;align-items:center;">
                <div id="weFeedbackMount"></div>
                <button class="chat-msg-action-btn" id="copyBtn" style="display:none;"><i class="bi bi-clipboard"></i> Copy</button>
                <button class="chat-msg-action-btn" id="printBtn" style="display:none;"><i class="bi bi-printer"></i> Print</button>
                <button class="chat-msg-action-btn" id="historyBtn" title="Your past briefings"><i class="bi bi-clock-history"></i> History</button>
            </div>
        </div>
        <div class="mp-output-body" id="outputBody">
            <div class="mp-empty-state">
                <div class="mp-empty-icon"><i class="bi bi-briefcase"></i></div>
                <div class="mp-empty-title">Your briefing will appear here</div>
                <div class="mp-empty-desc">Select your meeting type and details — the briefing automatically incorporates your latest fundraising snapshot data</div>
            </div>
        </div>
    </div>
</div>

</div><!-- /mp-page-wrap -->

<div id="weHistoryMount"></div>

<link rel="stylesheet" href="/css/writing-extras.css">
<script src="/js/writing-extras.js"></script>

<%- include('../partials/renderMarkdown') %>
<script>
(function() {
    let meetingType = 'Board Presentation';
    let duration = '60';
    let generatedText = '';

    function setup(id, setter) {
        document.getElementById(id).addEventListener('click', function(e) {
            const btn = e.target.closest('.writing-option');
            if (!btn) return;
            this.querySelectorAll('.writing-option').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            setter(btn.dataset.val);
        });
    }

    setup('typeOptions', v => meetingType = v);
    setup('durationOptions', v => duration = v);

    const generateBtn = document.getElementById('generateBtn');
    const outputBody = document.getElementById('outputBody');
    const copyBtn = document.getElementById('copyBtn');
    const printBtn = document.getElementById('printBtn');
    let lastOutputId = null;

    // ── WritingExtras: templates + feedback + history ────────────────────
    function pickPill(containerId, value) {
        if (!value) return;
        var btn = document.querySelector('#' + containerId + ' .writing-option[data-val="' + String(value).replace(/"/g, '\\"') + '"]');
        if (btn) btn.click();
    }
    var extras = WritingExtras.init({
        feature: 'meetingPrep',
        accentColor: '#0d9488',
        featureLabel: 'Your Meeting Briefings',
        templateRailEl: document.getElementById('weTemplateRail'),
        feedbackMountEl: document.getElementById('weFeedbackMount'),
        historyMountEl: document.getElementById('weHistoryMount'),
        generateBtn: generateBtn,
        outputBody: outputBody,
        applyTemplate: function(params) {
            pickPill('typeOptions', params.meetingType);
            if (params.duration) pickPill('durationOptions', params.duration);
            if (params.department) document.getElementById('deptSelect').value = params.department;
        },
        restoreItem: function(item) {
            var p = item.params || {};
            pickPill('typeOptions', p.meetingType);
            if (p.duration) pickPill('durationOptions', p.duration);
            if (p.department) document.getElementById('deptSelect').value = p.department;
            if (p.attendees) document.getElementById('attendees').value = p.attendees;
            if (p.agenda) document.getElementById('agenda').value = p.agenda;
            generatedText = item.generatedText || '';
            outputBody.innerHTML = '<div class="writing-rendered" id="outputRendered"></div>';
            document.getElementById('outputRendered').innerHTML = renderMarkdown(generatedText);
            copyBtn.style.display = 'inline-flex';
            printBtn.style.display = 'inline-flex';
        },
    });
    document.getElementById('historyBtn').addEventListener('click', function() { extras.openHistory(); });
    ['typeOptions', 'durationOptions'].forEach(function(id) {
        document.getElementById(id).addEventListener('click', function() { extras.clearActiveTemplate(); });
    });
    ['deptSelect', 'attendees', 'agenda'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) {
            el.addEventListener('input', function() { extras.clearActiveTemplate(); });
            el.addEventListener('change', function() { extras.clearActiveTemplate(); });
        }
    });

    generateBtn.addEventListener('click', function() {
        this.disabled = true;
        this.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating...';
        generatedText = '';
        lastOutputId = null;
        copyBtn.style.display = 'none';
        printBtn.style.display = 'none';
        extras.onGenerationStart();

        outputBody.innerHTML = '<div class="writing-rendered" id="outputRendered"></div>';
        const outputEl = document.getElementById('outputRendered');

        fetch('/api/meeting-prep/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                meetingType,
                department: document.getElementById('deptSelect').value || null,
                attendees: document.getElementById('attendees').value.trim() || null,
                duration: parseInt(duration) || 60,
                agenda: document.getElementById('agenda').value.trim() || null,
            }),
        })
        .then(response => {
            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';
            function read() {
                return reader.read().then(({ done, value }) => {
                    if (done) { finalize(); return; }
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();
                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            try {
                                const data = JSON.parse(line.substring(6));
                                if (data.text) { generatedText += data.text; outputEl.innerHTML = renderMarkdown(generatedText); outputBody.scrollTop = outputBody.scrollHeight; }
                                if (data.done) {
                                    if (data.outputId) lastOutputId = data.outputId;
                                    finalize();
                                    return;
                                }
                            } catch(e) {}
                        }
                    }
                    return read();
                });
            }
            return read();
        })
        .catch(() => { outputBody.innerHTML = '<div style="padding:20px;color:var(--color-text-danger);">Failed to generate.</div>'; })
        .finally(() => { generateBtn.disabled = false; generateBtn.innerHTML = '<i class="bi bi-stars"></i> Generate Briefing'; });
    });

    function finalize() {
        var el = document.getElementById('outputRendered');
        if (el) el.innerHTML = renderMarkdown(generatedText);
        copyBtn.style.display = 'inline-flex';
        printBtn.style.display = 'inline-flex';
        if (lastOutputId) extras.onGenerationDone(lastOutputId);
    }

    copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(generatedText).then(() => {
            copyBtn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
            setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard"></i> Copy'; }, 1500);
        });
    });

    printBtn.addEventListener('click', function() {
        var win = window.open('', '_blank');
        if (!win) { frAlert('Please allow popups to print.', { variant: 'warning', title: 'Popup Blocked' }); return; }
        win.document.write('<!DOCTYPE html><html><head><title>Meeting Briefing</title>' + writingPrintStyles() + '</head><body>' + renderMarkdown(generatedText) + '<script>window.onload=function(){window.print();}<\/script></body></html>');
        win.document.close();
    });

    function writingPrintStyles() {
        return '<style>body{font-family:Arial,sans-serif;max-width:750px;margin:40px auto;padding:0 20px;color:#333;font-size:13px;line-height:1.7;}' +
        'h2{font-size:18px;font-weight:700;color:#1A223D;margin:24px 0 8px;padding-bottom:5px;border-bottom:2px solid #3434D6;}' +
        'h3{font-size:15px;font-weight:700;color:#1A223D;margin:18px 0 6px;padding-bottom:4px;border-bottom:2px solid #3434D6;}' +
        'h4{font-size:14px;font-weight:700;color:#1A223D;margin:14px 0 6px;padding-left:8px;border-left:3px solid #3434D6;}' +
        'h5{font-size:12px;font-weight:600;color:#888;text-transform:uppercase;margin:10px 0 4px;}' +
        'strong{font-weight:700;color:#1a1a1a;} em{color:#666;}' +
        'ul,ol{margin:6px 0;padding-left:22px;} li{margin-bottom:3px;}' +
        'hr{border:none;height:1px;background:#ddd;margin:14px 0;}' +
        'blockquote{margin:12px 0;padding:10px 16px;border-left:3px solid #3434D6;background:#EDEDFB;border-radius:0 6px 6px 0;font-style:italic;color:#555;}' +
        'table{width:100%;border-collapse:collapse;margin:10px 0;font-size:12px;}' +
        'thead{background:#3434D6;} th{padding:7px 10px;text-align:left;color:#fff;font-size:11px;font-weight:600;text-transform:uppercase;}' +
        'td{padding:6px 10px;border-top:1px solid #e5e7eb;} tr:nth-child(even){background:rgba(52,52,214,0.04);}' +
        'td:first-child{font-weight:600;}' +
        '@media print{body{margin:20px;}}</style>';
    }
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

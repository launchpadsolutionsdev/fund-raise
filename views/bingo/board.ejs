<%- include('../partials/header') %>

<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;">
    <div>
        <div class="page-greeting"><i class="bi bi-grid-3x3"></i> Fundraising Bingo</div>
        <div class="page-subtitle">Complete fundraising activities to fill your card!</div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <div id="bingoStatus" style="font-size:13px;font-weight:600;color:var(--color-text-success);display:none;">BINGO! 🎉</div>
        <% if (currentUser && currentUser.isAdmin()) { %>
        <button class="btn-secondary" id="resetBtn" style="font-size:12px;"><i class="bi bi-arrow-counterclockwise"></i> Reset Board</button>
        <% } %>
    </div>
</div>

<div class="bingo-layout">
    <div class="bingo-board-container">
        <div class="bingo-grid" id="bingoGrid"></div>
        <div class="bingo-progress" id="bingoProgress"></div>
    </div>

    <div class="bingo-sidebar">
        <h4 style="font-size:14px;font-weight:600;margin:0 0 12px;">Leaderboard</h4>
        <div id="leaderboard"></div>
    </div>
</div>

<script>
(function() {
    const grid = document.getElementById('bingoGrid');
    const progress = document.getElementById('bingoProgress');
    const leaderboard = document.getElementById('leaderboard');
    const bingoStatus = document.getElementById('bingoStatus');
    const isAdmin = <%= currentUser && currentUser.isAdmin() ? 'true' : 'false' %>;
    let board = null;

    function loadBoard() {
        fetch('/api/bingo')
            .then(r => r.json())
            .then(data => {
                board = data;
                renderBoard();
                loadLeaderboard();
            });
    }

    function renderBoard() {
        grid.innerHTML = '';
        board.squares.forEach((sq, i) => {
            const cell = document.createElement('div');
            cell.className = 'bingo-cell' + (board.myCompletions.includes(i) ? ' completed' : '') + (i === 12 ? ' free-space' : '');
            cell.textContent = sq;
            cell.addEventListener('click', () => toggleSquare(i));
            grid.appendChild(cell);
        });
        progress.textContent = board.myCompletions.length + '/25 completed';
    }

    function toggleSquare(index) {
        fetch('/api/bingo/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ squareIndex: index }),
        })
        .then(r => r.json())
        .then(data => {
            board.myCompletions = data.myCompletions;
            renderBoard();
            loadLeaderboard();
            if (data.hasBingo) {
                bingoStatus.style.display = 'block';
                bingoStatus.classList.add('bingo-flash');
            } else {
                bingoStatus.style.display = 'none';
            }
        });
    }

    function loadLeaderboard() {
        fetch('/api/bingo/leaderboard')
            .then(r => r.json())
            .then(entries => {
                if (!entries.length) {
                    leaderboard.innerHTML = '<div style="font-size:12px;color:var(--color-text-tertiary);padding:12px;">No activity yet!</div>';
                    return;
                }
                leaderboard.innerHTML = '';
                entries.forEach((e, i) => {
                    const row = document.createElement('div');
                    row.className = 'bingo-lb-row';

                    let avatar;
                    if (e.avatarSrc) {
                        avatar = '<img src="' + e.avatarSrc + '" alt="">';
                    } else {
                        const init = e.displayName.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
                        avatar = '<span class="bingo-lb-initials">' + init + '</span>';
                    }

                    row.innerHTML =
                        '<span class="bingo-lb-rank">' + (i+1) + '</span>' +
                        '<span class="bingo-lb-avatar">' + avatar + '</span>' +
                        '<span class="bingo-lb-name">' + esc(e.displayName) + (e.hasBingo ? ' 🎉' : '') + '</span>' +
                        '<span class="bingo-lb-score">' + e.completed + '/25</span>';
                    leaderboard.appendChild(row);
                });
            });
    }

    if (document.getElementById('resetBtn')) {
        document.getElementById('resetBtn').addEventListener('click', function() {
            frConfirm('Reset the bingo board for everyone? This clears all progress.', { variant: 'warning', title: 'Reset Board' }).then(function(ok) {
                if (!ok) return;
                fetch('/api/bingo/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
                    .then(() => loadBoard());
            });
        });
    }

    function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    loadBoard();
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

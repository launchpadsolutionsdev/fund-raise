<%- include('../partials/header') %>

<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;">
    <div>
        <div class="page-greeting">Quick Notes</div>
        <div class="page-subtitle">Your personal scratchpad — jot down ideas, reminders, and to-dos</div>
    </div>
    <button class="btn-brand" id="addNoteBtn"><i class="bi bi-plus-lg"></i> New Note</button>
</div>

<style>
/* ── Quick Notes Hero ── */
.qn-hero {
    margin: 0 0 28px;
    background: linear-gradient(135deg, var(--fr-navy) 0%, #2d3555 50%, #3d4568 100%);
    border-radius: 16px;
    padding: 32px 36px;
    display: flex;
    align-items: center;
    gap: 28px;
    color: #fff;
    box-shadow: 0 4px 24px rgba(26, 34, 61, 0.18);
}
.qn-hero-icon {
    flex-shrink: 0;
    width: 68px;
    height: 68px;
    border-radius: 18px;
    background: linear-gradient(135deg, #fef9c3, #fde68a);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    color: #92400e;
    box-shadow: 0 4px 16px rgba(254, 249, 195, 0.3);
}
.qn-hero-text h2 {
    margin: 0 0 6px;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.3px;
}
.qn-hero-text p {
    margin: 0;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
}
.qn-hero-colors {
    display: flex;
    gap: 6px;
    margin-top: 12px;
}
.qn-hero-swatch {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.2);
}

/* ── Color Bar Elevated ── */
.qn-color-bar {
    margin: 0 0 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-primary);
    border-radius: 12px;
    padding: 12px 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}
.qn-color-bar-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-tertiary);
    margin-right: 4px;
}

/* ── Notes Grid Elevated ── */
.qn-grid-wrap {
}
.qn-empty {
    grid-column: 1/-1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    text-align: center;
}
.qn-empty-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fef9c3, #fde68a);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: #92400e;
    margin-bottom: 16px;
}
.qn-empty-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 6px;
}
.qn-empty-desc {
    font-size: 12px;
    color: var(--color-text-tertiary);
    line-height: 1.6;
    max-width: 260px;
}

@media (max-width: 840px) {
    .qn-hero { flex-direction: column; text-align: center; padding: 24px 20px; }
    .qn-hero-colors { justify-content: center; }
}
</style>

<!-- Hero Card -->
<div class="qn-hero">
    <div class="qn-hero-icon"><i class="bi bi-sticky"></i></div>
    <div class="qn-hero-text">
        <h2>Your Personal Scratchpad</h2>
        <p>Jot down quick ideas, donor follow-up reminders, meeting notes, or anything you need to remember. Color-code your notes to stay organized.</p>
        <div class="qn-hero-colors">
            <span class="qn-hero-swatch" style="background:#fef9c3;"></span>
            <span class="qn-hero-swatch" style="background:#dbeafe;"></span>
            <span class="qn-hero-swatch" style="background:#dcfce7;"></span>
            <span class="qn-hero-swatch" style="background:#fce7f3;"></span>
            <span class="qn-hero-swatch" style="background:#f3e8ff;"></span>
            <span class="qn-hero-swatch" style="background:#ffedd5;"></span>
        </div>
    </div>
</div>

<!-- Color Bar -->
<div class="qn-color-bar">
    <span class="qn-color-bar-label">New Note Color:</span>
    <button class="note-color-btn active" data-color="yellow" style="background:#fef9c3;"></button>
    <button class="note-color-btn" data-color="blue" style="background:#dbeafe;"></button>
    <button class="note-color-btn" data-color="green" style="background:#dcfce7;"></button>
    <button class="note-color-btn" data-color="pink" style="background:#fce7f3;"></button>
    <button class="note-color-btn" data-color="purple" style="background:#f3e8ff;"></button>
    <button class="note-color-btn" data-color="orange" style="background:#ffedd5;"></button>
</div>

<!-- Notes Grid -->
<div class="qn-grid-wrap">
    <div class="notes-grid" id="notesGrid">
        <div style="text-align:center;padding:40px;color:var(--color-text-tertiary);font-size:13px;">Loading...</div>
    </div>
</div>

<script>
(function() {
    const grid = document.getElementById('notesGrid');
    const addBtn = document.getElementById('addNoteBtn');
    let selectedColor = 'yellow';
    let notes = [];

    const colorMap = {
        yellow: '#fef9c3', blue: '#dbeafe', green: '#dcfce7',
        pink: '#fce7f3', purple: '#f3e8ff', orange: '#ffedd5',
    };

    // Color selector
    document.querySelectorAll('.note-color-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.note-color-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            selectedColor = this.dataset.color;
        });
    });

    addBtn.addEventListener('click', () => createNote());

    function loadNotes() {
        fetch('/api/notes')
            .then(r => r.json())
            .then(data => {
                notes = data;
                renderNotes();
            });
    }

    function renderNotes() {
        if (notes.length === 0) {
            grid.innerHTML =
                '<div class="qn-empty">' +
                    '<div class="qn-empty-icon"><i class="bi bi-sticky"></i></div>' +
                    '<div class="qn-empty-title">No notes yet</div>' +
                    '<div class="qn-empty-desc">Click "New Note" above to create your first note. Use colors to organize ideas, reminders, and to-dos.</div>' +
                '</div>';
            return;
        }
        grid.innerHTML = '';
        notes.forEach(note => {
            const card = document.createElement('div');
            card.className = 'note-card';
            card.style.background = colorMap[note.color] || colorMap.yellow;
            card.dataset.id = note.id;

            const textarea = document.createElement('textarea');
            textarea.className = 'note-content';
            textarea.value = note.content;
            textarea.placeholder = 'Write something...';
            textarea.addEventListener('blur', function() {
                saveNote(note.id, this.value, note.color);
            });

            const actions = document.createElement('div');
            actions.className = 'note-actions';

            // Color dots
            Object.entries(colorMap).forEach(([name, hex]) => {
                const dot = document.createElement('button');
                dot.className = 'note-color-dot' + (name === note.color ? ' active' : '');
                dot.style.background = hex;
                dot.addEventListener('click', function() {
                    note.color = name;
                    card.style.background = hex;
                    actions.querySelectorAll('.note-color-dot').forEach(d => d.classList.remove('active'));
                    this.classList.add('active');
                    saveNote(note.id, textarea.value, name);
                });
                actions.appendChild(dot);
            });

            const delBtn = document.createElement('button');
            delBtn.className = 'note-delete-btn';
            delBtn.innerHTML = '<i class="bi bi-x-lg"></i>';
            delBtn.addEventListener('click', () => deleteNote(note.id));
            actions.appendChild(delBtn);

            card.appendChild(textarea);
            card.appendChild(actions);
            grid.appendChild(card);
        });
    }

    function createNote() {
        fetch('/api/notes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: '', color: selectedColor }),
        })
        .then(r => r.json())
        .then(note => {
            notes.unshift(note);
            renderNotes();
            // Focus the new note
            const firstTextarea = grid.querySelector('.note-content');
            if (firstTextarea) firstTextarea.focus();
        });
    }

    function saveNote(id, content, color) {
        fetch('/api/notes/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content, color }),
        });
    }

    function deleteNote(id) {
        fetch('/api/notes/' + id, { method: 'DELETE' })
            .then(() => {
                notes = notes.filter(n => n.id !== id);
                renderNotes();
            });
    }

    loadNotes();
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

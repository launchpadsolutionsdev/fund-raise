<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

<div class="chat-page">
    <div class="chat-header">
        <div>
            <div class="page-greeting"><i class="bi bi-chat-dots"></i> Ask Fund-Raise</div>
            <div class="page-subtitle">
                <% if (hasData) { %>
                    AI-powered insights from your fundraising data (Snapshot: <%= selectedDate %>)
                <% } else { %>
                    Upload data first to start asking questions
                <% } %>
                <% if (typeof bbConnected !== 'undefined' && bbConnected) { %>
                    <span class="chat-bb-badge"><i class="bi bi-database-check"></i> Blackbaud Connected</span>
                <% } %>
            </div>
        </div>
        <div class="chat-header-actions">
            <button class="btn-brand chat-clear-btn" id="toggleHistory" title="Toggle conversation history">
                <i class="bi bi-clock-history"></i> History
            </button>
            <button class="btn-brand chat-clear-btn" id="newChat" title="New conversation">
                <i class="bi bi-plus-lg"></i> New Chat
            </button>
        </div>
    </div>

    <div class="chat-layout">
        <!-- Conversation history panel -->
        <div class="conv-panel" id="convPanel">
            <div class="conv-panel-header">
                <span class="conv-panel-title">Conversations</span>
                <button class="conv-panel-close" id="closePanel" title="Close"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="conv-list" id="convList">
                <div class="conv-list-empty">No conversations yet</div>
            </div>
        </div>

        <!-- Main chat area -->
        <div class="chat-container" id="chatContainer">
            <div class="chat-messages" id="chatMessages">
                <div class="chat-welcome">
                    <div class="chat-welcome-icon">
                        <img src="/images/fund-raise-icon-flat.svg" alt="Fund-Raise" class="chat-welcome-logo">
                    </div>
                    <h3>Welcome to Ask Fund-Raise</h3>
                    <p>I can help you explore your fundraising data, compare departments, analyze donor trends, and provide actionable insights.</p>
                    <% if (hasData) { %>
                    <div class="chat-suggestions">
                        <button class="chat-suggestion" onclick="askSuggestion(this)">How are we tracking against our overall goal?</button>
                        <button class="chat-suggestion" onclick="askSuggestion(this)">Which department is performing best?</button>
                        <button class="chat-suggestion" onclick="askSuggestion(this)">Who are our top 10 donors?</button>
                        <button class="chat-suggestion" onclick="askSuggestion(this)">Give me a summary of Annual Giving performance</button>
                        <button class="chat-suggestion" onclick="askSuggestion(this)">What does our gift size distribution look like?</button>
                        <button class="chat-suggestion" onclick="askSuggestion(this)">Are we on track for year-end projections?</button>
                        <button class="chat-suggestion chat-suggestion-renxt" onclick="askSuggestion(this)">How do I build a query for donors who gave $1,000+ this year?</button>
                        <button class="chat-suggestion chat-suggestion-renxt" onclick="askSuggestion(this)">Help me troubleshoot an RE NXT error (paste a screenshot)</button>
                        <% if (typeof bbConnected !== 'undefined' && bbConnected) { %>
                        <button class="chat-suggestion chat-suggestion-bb" onclick="askSuggestion(this)">Look up a donor's giving history in Blackbaud</button>
                        <button class="chat-suggestion chat-suggestion-bb" onclick="askSuggestion(this)">What gifts came in this week?</button>
                        <% } %>
                    </div>
                    <% } else { %>
                    <div class="alert-card warning" style="margin-top: 16px;">
                        <div class="alert-card-title">No data available</div>
                        <div class="alert-card-text">Please <a href="/upload">upload your fundraising data</a> to start using Ask Fund-Raise.</div>
                    </div>
                    <% } %>
                </div>
            </div>

            <div class="chat-input-area">
                <form id="chatForm" class="chat-form" autocomplete="off">
                    <!-- Image preview area (hidden until image attached) -->
                    <div class="chat-image-preview" id="imagePreview" style="display:none;">
                        <div class="chat-image-preview-inner">
                            <img id="imagePreviewImg" src="" alt="Preview">
                            <button type="button" class="chat-image-remove" id="removeImage" title="Remove image">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                    <div class="chat-input-wrapper">
                        <button type="button" class="chat-attach-btn" id="attachBtn" title="Attach screenshot (PNG, JPEG, GIF, WebP — max 5MB)" <%= hasData ? '' : 'disabled' %>>
                            <i class="bi bi-paperclip"></i>
                        </button>
                        <input type="file" id="imageFileInput" accept=".png,.jpg,.jpeg,.gif,.webp" style="display:none;">
                        <textarea id="chatInput" class="chat-input"
                            placeholder="<%= hasData ? 'Ask anything about your fundraising data...' : 'Upload data first to start chatting' %>"
                            rows="1"
                            <%= hasData ? '' : 'disabled' %>
                        ></textarea>
                        <button type="submit" class="chat-send-btn" id="sendBtn" <%= hasData ? '' : 'disabled' %>>
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div class="chat-input-toolbar">
                        <button type="button" class="deep-dive-toggle" id="deepDiveToggle" title="Deep Dive enables Blackbaud CRM lookups and web search">
                            <i class="bi bi-lightning-charge"></i>
                            <span>Deep Dive</span>
                            <span class="deep-dive-status" id="deepDiveStatus">OFF</span>
                        </button>
                        <button type="button" class="deep-dive-toggle" id="crmToggle" title="CRM Mode queries your imported RE NXT gift data" style="margin-left: 6px;">
                            <i class="bi bi-database"></i>
                            <span>CRM</span>
                            <span class="deep-dive-status" id="crmStatus">OFF</span>
                        </button>
                        <div class="chat-input-hint">Press Enter to send, Shift+Enter for new line · Paste or attach screenshots</div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Share dialog -->
<div class="share-overlay" id="shareOverlay" style="display:none;">
    <div class="share-dialog">
        <div class="share-dialog-header">
            <span>Share Conversation</span>
            <button class="conv-panel-close" id="closeShare"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="share-dialog-body" id="shareBody">
            <p style="font-size:12px;color:var(--color-text-secondary);margin:0 0 12px;">Select team members to share this conversation with:</p>
            <div id="shareUserList"></div>
        </div>
        <div class="share-dialog-footer">
            <button class="btn-brand" id="saveShare">Save</button>
        </div>
    </div>
</div>

<script>
(function() {
    const chatMessages = document.getElementById('chatMessages');
    const chatForm = document.getElementById('chatForm');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendBtn');
    const newChatBtn = document.getElementById('newChat');
    const toggleHistoryBtn = document.getElementById('toggleHistory');
    const convPanel = document.getElementById('convPanel');
    const convList = document.getElementById('convList');
    const closePanel = document.getElementById('closePanel');

    const deepDiveToggle = document.getElementById('deepDiveToggle');
    const deepDiveStatus = document.getElementById('deepDiveStatus');
    const crmToggle = document.getElementById('crmToggle');
    const crmStatus = document.getElementById('crmStatus');

    const shareOverlay = document.getElementById('shareOverlay');
    const closeShare = document.getElementById('closeShare');
    const saveShare = document.getElementById('saveShare');
    const shareUserList = document.getElementById('shareUserList');

    // Image upload elements
    const attachBtn = document.getElementById('attachBtn');
    const imageFileInput = document.getElementById('imageFileInput');
    const imagePreview = document.getElementById('imagePreview');
    const imagePreviewImg = document.getElementById('imagePreviewImg');
    const removeImageBtn = document.getElementById('removeImage');
    let pendingImageFile = null;

    let conversationHistory = [];
    let currentConversationId = null;
    let isLoading = false;
    let deepDiveEnabled = false;
    let crmEnabled = false;
    let currentSharedWith = [];

    // ── Image attachment handling ──
    attachBtn.addEventListener('click', function() { imageFileInput.click(); });

    imageFileInput.addEventListener('change', function() {
        if (this.files && this.files[0]) {
            attachImage(this.files[0]);
        }
    });

    removeImageBtn.addEventListener('click', function() {
        clearPendingImage();
    });

    function attachImage(file) {
        const maxSize = 5 * 1024 * 1024;
        const allowed = ['image/png', 'image/jpeg', 'image/gif', 'image/webp'];
        if (!allowed.includes(file.type)) {
            alert('Only PNG, JPEG, GIF, and WebP images are allowed.');
            return;
        }
        if (file.size > maxSize) {
            alert('Image must be under 5MB.');
            return;
        }
        pendingImageFile = file;
        const reader = new FileReader();
        reader.onload = function(e) {
            imagePreviewImg.src = e.target.result;
            imagePreview.style.display = 'block';
        };
        reader.readAsDataURL(file);
    }

    function clearPendingImage() {
        pendingImageFile = null;
        imagePreview.style.display = 'none';
        imagePreviewImg.src = '';
        imageFileInput.value = '';
    }

    // ── Clipboard paste support for screenshots ──
    chatInput.addEventListener('paste', function(e) {
        const items = e.clipboardData && e.clipboardData.items;
        if (!items) return;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.startsWith('image/')) {
                e.preventDefault();
                const file = items[i].getAsFile();
                if (file) attachImage(file);
                return;
            }
        }
    });

    // ── Deep Dive toggle (mutually exclusive with CRM) ──
    deepDiveToggle.addEventListener('click', function() {
        deepDiveEnabled = !deepDiveEnabled;
        deepDiveToggle.classList.toggle('active', deepDiveEnabled);
        deepDiveStatus.textContent = deepDiveEnabled ? 'ON' : 'OFF';
        if (deepDiveEnabled && crmEnabled) {
            crmEnabled = false;
            crmToggle.classList.remove('active');
            crmStatus.textContent = 'OFF';
        }
    });

    // ── CRM toggle (mutually exclusive with Deep Dive) ──
    crmToggle.addEventListener('click', function() {
        crmEnabled = !crmEnabled;
        crmToggle.classList.toggle('active', crmEnabled);
        crmStatus.textContent = crmEnabled ? 'ON' : 'OFF';
        if (crmEnabled && deepDiveEnabled) {
            deepDiveEnabled = false;
            deepDiveToggle.classList.remove('active');
            deepDiveStatus.textContent = 'OFF';
        }
    });

    // ── Conversation panel toggling ──
    toggleHistoryBtn.addEventListener('click', function() {
        convPanel.classList.toggle('open');
        if (convPanel.classList.contains('open')) loadConversations();
    });
    closePanel.addEventListener('click', function() {
        convPanel.classList.remove('open');
    });

    // ── Load conversations list ──
    function loadConversations() {
        fetch('/api/ai/conversations')
            .then(r => r.json())
            .then(convs => {
                if (!convs.length) {
                    convList.innerHTML = '<div class="conv-list-empty">No conversations yet</div>';
                    return;
                }
                convList.innerHTML = '';
                convs.forEach(c => {
                    const item = document.createElement('div');
                    item.className = 'conv-item' + (c.id === currentConversationId ? ' active' : '');
                    item.dataset.id = c.id;

                    const titleEl = document.createElement('div');
                    titleEl.className = 'conv-item-title';
                    titleEl.textContent = (c.isShared ? '(shared) ' : '') + c.title;

                    const dateEl = document.createElement('div');
                    dateEl.className = 'conv-item-date';
                    dateEl.textContent = formatDate(c.updatedAt);

                    const actions = document.createElement('div');
                    actions.className = 'conv-item-actions';

                    if (!c.isShared) {
                        const shareBtn = document.createElement('button');
                        shareBtn.className = 'conv-action-btn';
                        shareBtn.title = 'Share';
                        shareBtn.innerHTML = '<i class="bi bi-share"></i>';
                        shareBtn.addEventListener('click', function(e) {
                            e.stopPropagation();
                            openShareDialog(c.id, c.sharedWith || []);
                        });
                        actions.appendChild(shareBtn);

                        const renameBtn = document.createElement('button');
                        renameBtn.className = 'conv-action-btn';
                        renameBtn.title = 'Rename';
                        renameBtn.innerHTML = '<i class="bi bi-pencil"></i>';
                        renameBtn.addEventListener('click', function(e) {
                            e.stopPropagation();
                            renameConversation(c.id, c.title);
                        });
                        actions.appendChild(renameBtn);

                        const deleteBtn = document.createElement('button');
                        deleteBtn.className = 'conv-action-btn conv-action-delete';
                        deleteBtn.title = 'Delete';
                        deleteBtn.innerHTML = '<i class="bi bi-trash3"></i>';
                        deleteBtn.addEventListener('click', function(e) {
                            e.stopPropagation();
                            deleteConversation(c.id);
                        });
                        actions.appendChild(deleteBtn);
                    }

                    item.appendChild(titleEl);
                    item.appendChild(dateEl);
                    item.appendChild(actions);
                    item.addEventListener('click', function() { loadConversation(c.id); });
                    convList.appendChild(item);
                });
            })
            .catch(() => {
                convList.innerHTML = '<div class="conv-list-empty">Failed to load</div>';
            });
    }

    function formatDate(dateStr) {
        const d = new Date(dateStr);
        const now = new Date();
        const diff = now - d;
        if (diff < 60000) return 'Just now';
        if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';
        if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';
        if (diff < 604800000) return Math.floor(diff / 86400000) + 'd ago';
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    // ── Load a conversation ──
    function loadConversation(id) {
        fetch('/api/ai/conversations/' + id)
            .then(r => r.json())
            .then(conv => {
                if (conv.error) return;
                currentConversationId = conv.id;
                conversationHistory = conv.messages || [];
                chatMessages.innerHTML = '';
                conversationHistory.forEach(m => appendMessage(m.role, m.content));
                history.replaceState(null, '', '/ask?c=' + conv.id);
                document.querySelectorAll('.conv-item').forEach(el => {
                    el.classList.toggle('active', el.dataset.id === id);
                });
                scrollToBottom();
                chatInput.focus();
            });
    }

    // ── Delete a conversation ──
    function deleteConversation(id) {
        if (!confirm('Delete this conversation?')) return;
        fetch('/api/ai/conversations/' + id, { method: 'DELETE' })
            .then(r => r.json())
            .then(() => {
                if (id === currentConversationId) startNewChat();
                loadConversations();
            });
    }

    // ── Rename a conversation ──
    function renameConversation(id, currentTitle) {
        const newTitle = prompt('Rename conversation:', currentTitle);
        if (!newTitle || !newTitle.trim()) return;
        fetch('/api/ai/conversations/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: newTitle.trim() }),
        })
        .then(r => r.json())
        .then(() => loadConversations());
    }

    // ── Share dialog ──
    let shareConvId = null;

    function openShareDialog(convId, sharedWith) {
        shareConvId = convId;
        currentSharedWith = sharedWith || [];
        shareOverlay.style.display = 'flex';
        shareUserList.innerHTML = '<div style="font-size:12px;color:var(--color-text-tertiary);padding:8px;">Loading...</div>';
        fetch('/api/ai/team-members')
            .then(r => r.json())
            .then(users => {
                if (!users.length) {
                    shareUserList.innerHTML = '<div style="font-size:12px;color:var(--color-text-tertiary);padding:8px;">No other team members found.</div>';
                    return;
                }
                shareUserList.innerHTML = '';
                users.forEach(u => {
                    const label = document.createElement('label');
                    label.className = 'share-user-item';
                    const cb = document.createElement('input');
                    cb.type = 'checkbox';
                    cb.value = u.id;
                    cb.checked = currentSharedWith.includes(u.id);
                    label.appendChild(cb);
                    label.appendChild(document.createTextNode(' ' + (u.name || u.email)));
                    shareUserList.appendChild(label);
                });
            });
    }

    closeShare.addEventListener('click', function() { shareOverlay.style.display = 'none'; });
    shareOverlay.addEventListener('click', function(e) { if (e.target === shareOverlay) shareOverlay.style.display = 'none'; });

    saveShare.addEventListener('click', function() {
        const checked = Array.from(shareUserList.querySelectorAll('input:checked')).map(cb => parseInt(cb.value));
        fetch('/api/ai/conversations/' + shareConvId + '/share', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userIds: checked }),
        })
        .then(r => r.json())
        .then(() => {
            shareOverlay.style.display = 'none';
            loadConversations();
        });
    });

    // ── New chat ──
    newChatBtn.addEventListener('click', startNewChat);

    function startNewChat() {
        currentConversationId = null;
        conversationHistory = [];
        chatMessages.innerHTML = '';
        renderWelcome();
        chatInput.value = '';
        chatInput.style.height = 'auto';
        history.replaceState(null, '', '/ask');
        document.querySelectorAll('.conv-item').forEach(el => el.classList.remove('active'));
    }

    // ── Auto-resize textarea ──
    chatInput.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 150) + 'px';
    });

    chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            chatForm.dispatchEvent(new Event('submit'));
        }
    });

    chatForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const text = chatInput.value.trim();
        if ((!text && !pendingImageFile) || isLoading) return;
        sendMessage(text);
    });

    function renderWelcome() {
        const hasData = <%= hasData ? 'true' : 'false' %>;
        const suggestions = [
            'How are we tracking against our overall goal?',
            'Which department is performing best?',
            'Who are our top 10 donors?',
            'Give me a summary of Annual Giving performance',
            'What does our gift size distribution look like?',
            'Are we on track for year-end projections?',
        ];

        let html = '<div class="chat-welcome">';
        html += '<div class="chat-welcome-icon"><img src="/images/fund-raise-icon-flat.svg" alt="Fund-Raise" class="chat-welcome-logo"></div>';
        html += '<h3>Welcome to Ask Fund-Raise</h3>';
        html += '<p>I can help you explore your fundraising data, compare departments, analyze donor trends, and provide actionable insights.</p>';
        if (hasData) {
            html += '<div class="chat-suggestions">';
            suggestions.forEach(s => {
                html += '<button class="chat-suggestion" onclick="askSuggestion(this)">' + s + '</button>';
            });
            html += '</div>';
        }
        html += '</div>';
        chatMessages.innerHTML = html;
    }

    // ── Streaming message sender ──
    function sendMessage(text) {
        const welcome = chatMessages.querySelector('.chat-welcome');
        if (welcome) welcome.remove();

        const hasImg = !!pendingImageFile;
        const imageDataUrl = hasImg ? imagePreviewImg.src : null;

        // Show user message with optional image thumbnail
        appendMessage('user', text, imageDataUrl);
        conversationHistory.push({ role: 'user', content: text || '[Image attached]' });

        chatInput.value = '';
        chatInput.style.height = 'auto';

        isLoading = true;
        sendBtn.disabled = true;

        // Create assistant message container for streaming
        const { msgDiv, bubble } = appendStreamingMessage();
        let streamedText = '';
        let currentCitations = [];

        // Build request — use FormData if image is attached, else JSON
        let fetchOptions;
        if (hasImg) {
            const formData = new FormData();
            formData.append('image', pendingImageFile);
            formData.append('payload', JSON.stringify({
                messages: conversationHistory,
                conversationId: currentConversationId,
                deepDive: deepDiveEnabled,
                crmMode: crmEnabled,
            }));
            fetchOptions = { method: 'POST', body: formData };
            clearPendingImage();
        } else {
            fetchOptions = {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    messages: conversationHistory,
                    conversationId: currentConversationId,
                    deepDive: deepDiveEnabled,
                    crmMode: crmEnabled,
                }),
            };
        }

        // Abort controller: cancel the stream if it takes too long with no data
        const abortController = new AbortController();
        fetchOptions.signal = abortController.signal;
        let lastDataTime = Date.now();
        const STREAM_TIMEOUT = 120000; // 2 minutes with no data = timeout

        const timeoutChecker = setInterval(function() {
            if (Date.now() - lastDataTime > STREAM_TIMEOUT) {
                clearInterval(timeoutChecker);
                abortController.abort();
            }
        }, 5000);

        fetch('/api/ai/chat/stream', fetchOptions)
        .then(response => {
            if (!response.ok) throw new Error('Stream request failed');

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';

            function read() {
                return reader.read().then(({ done, value }) => {
                    if (done) {
                        finishStream(streamedText, currentCitations, bubble, msgDiv);
                        return;
                    }

                    lastDataTime = Date.now(); // Reset timeout on any data
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop(); // keep incomplete line

                    let currentEvent = '';
                    for (const line of lines) {
                        if (line.startsWith('event: ')) {
                            currentEvent = line.substring(7);
                        } else if (line.startsWith('data: ')) {
                            try {
                                const data = JSON.parse(line.substring(6));
                                handleSSE(currentEvent, data, bubble, msgDiv);
                                if (currentEvent === 'delta') {
                                    streamedText += data.text;
                                }
                                if (currentEvent === 'done' && data.citations) {
                                    currentCitations = data.citations;
                                }
                                if (currentEvent === 'saved' && data.conversationId) {
                                    if (!currentConversationId) {
                                        currentConversationId = data.conversationId;
                                        history.replaceState(null, '', '/ask?c=' + data.conversationId);
                                    }
                                }
                            } catch (parseErr) {
                                console.warn('[Chat] Failed to parse SSE data:', parseErr);
                            }
                            currentEvent = '';
                        }
                    }

                    scrollToBottom();
                    return read();
                });
            }

            return read();
        })
        .catch(err => {
            stopThinkingAnimation();
            bubble._inToolRound = false;
            var errMsg = 'Failed to connect to AI service. Please try again.';
            if (err.name === 'AbortError') {
                errMsg = 'The request timed out. The CRM lookup may have taken too long — please try again.';
            }
            // Only show error if bubble doesn't already have real content
            if (!streamedText) {
                bubble.innerHTML = '<span class="chat-bubble-error">' + errMsg + '</span>';
            }
        })
        .finally(() => {
            clearInterval(timeoutChecker);
            stopThinkingAnimation();
            isLoading = false;
            sendBtn.disabled = false;
            chatInput.focus();
            if (convPanel.classList.contains('open')) loadConversations();
        });
    }

    function appendStreamingMessage() {
        const div = document.createElement('div');
        div.className = 'chat-message chat-message-assistant';

        const avatar = document.createElement('div');
        avatar.className = 'chat-avatar';
        avatar.innerHTML = '<img src="/images/fund-raise-icon-flat.svg" alt="AI">';

        const bubble = document.createElement('div');
        bubble.className = 'chat-bubble';
        bubble.innerHTML = '<div class="chat-typing"><span></span><span></span><span></span></div>';

        div.appendChild(avatar);
        div.appendChild(bubble);
        chatMessages.appendChild(div);
        scrollToBottom();
        return { msgDiv: div, bubble };
    }

    // ── Tool-use thinking animation ──
    const THINKING_PHRASES = [
        'Searching the database...',
        'Looking that up...',
        'Pulling records...',
        'Crunching the numbers...',
        'Digging through the CRM...',
        'Doing some hard yakka...',
        'Ruminating on this...',
        'Consulting the archives...',
        'Vibing with the data...',
        'Cross-referencing records...',
        'Almost there...',
        'Connecting the dots...',
        'Sifting through gifts...',
        'Running the numbers...',
    ];
    let thinkingInterval = null;
    let thinkingPhraseIdx = 0;

    function startThinkingAnimation(bubble) {
        // Clear any existing content and show thinking UI
        bubble.innerHTML =
            '<div class="chat-thinking-anim">' +
                '<div class="chat-thinking-dots"><span></span><span></span><span></span></div>' +
                '<div class="chat-thinking-subtitle"></div>' +
            '</div>';

        // Pick a random starting phrase
        thinkingPhraseIdx = Math.floor(Math.random() * THINKING_PHRASES.length);
        var subtitle = bubble.querySelector('.chat-thinking-subtitle');
        if (subtitle) subtitle.textContent = THINKING_PHRASES[thinkingPhraseIdx];

        // Rotate phrases every 2.5 seconds
        if (thinkingInterval) clearInterval(thinkingInterval);
        thinkingInterval = setInterval(function() {
            thinkingPhraseIdx = (thinkingPhraseIdx + 1) % THINKING_PHRASES.length;
            var sub = bubble.querySelector('.chat-thinking-subtitle');
            if (sub) {
                sub.style.opacity = '0';
                setTimeout(function() {
                    if (sub) {
                        sub.textContent = THINKING_PHRASES[thinkingPhraseIdx];
                        sub.style.opacity = '1';
                    }
                }, 200);
            }
        }, 2500);

        bubble._inToolRound = true;
    }

    function stopThinkingAnimation() {
        if (thinkingInterval) {
            clearInterval(thinkingInterval);
            thinkingInterval = null;
        }
    }

    function handleSSE(event, data, bubble, msgDiv) {
        if (event === 'delta') {
            // During tool rounds, ignore intermediate deltas — the done event will have the full text
            if (bubble._inToolRound) return;

            // Remove any typing/thinking indicators on first delta
            var typing = bubble.querySelector('.chat-typing');
            if (typing) bubble.innerHTML = '';
            var anim = bubble.querySelector('.chat-thinking-anim');
            if (anim) bubble.innerHTML = '';

            // Append raw text incrementally; we'll render markdown on 'done'
            if (!bubble._rawText) bubble._rawText = '';
            bubble._rawText += data.text;
            bubble.innerHTML = renderMarkdown(bubble._rawText);

        } else if (event === 'tool_use') {
            // Show animated thinking indicator with rotating subtitles
            startThinkingAnimation(bubble);

        } else if (event === 'done') {
            // Always stop animation and clear the tool round flag
            stopThinkingAnimation();
            bubble._inToolRound = false;

            // Render the final complete text (this is the authoritative response)
            bubble.innerHTML = renderMarkdown(data.text || '');

            if (data.citations && data.citations.length > 0) {
                const citDiv = document.createElement('div');
                citDiv.className = 'chat-citations';
                citDiv.innerHTML = '<div class="chat-citations-label"><i class="bi bi-link-45deg"></i> Sources</div>';
                data.citations.forEach((c, i) => {
                    const a = document.createElement('a');
                    a.href = c.url;
                    a.target = '_blank';
                    a.rel = 'noopener noreferrer';
                    a.className = 'chat-citation-link';
                    a.textContent = c.title || c.url;
                    citDiv.appendChild(a);
                });
                bubble.appendChild(citDiv);
            }
            // Add action buttons (export, copy, chart)
            appendMessageActions(bubble, data.text, msgDiv);
            // Store in history
            conversationHistory.push({ role: 'assistant', content: data.text });
            // Render any chart blocks
            renderChartBlocks(bubble);
        } else if (event === 'error') {
            stopThinkingAnimation();
            bubble._inToolRound = false;
            bubble.innerHTML = '<span class="chat-bubble-error">' + (data.error || 'An error occurred') + '</span>';
        }
    }

    function finishStream(text, citations, bubble, msgDiv) {
        // If done event was already handled, skip
        if (bubble.querySelector('.chat-msg-actions')) return;
        stopThinkingAnimation();
        bubble._inToolRound = false;
        if (text) {
            bubble.innerHTML = renderMarkdown(text);
            if (citations && citations.length > 0) {
                const citDiv = document.createElement('div');
                citDiv.className = 'chat-citations';
                citDiv.innerHTML = '<div class="chat-citations-label"><i class="bi bi-link-45deg"></i> Sources</div>';
                citations.forEach(c => {
                    const a = document.createElement('a');
                    a.href = c.url;
                    a.target = '_blank';
                    a.rel = 'noopener noreferrer';
                    a.className = 'chat-citation-link';
                    a.textContent = c.title || c.url;
                    citDiv.appendChild(a);
                });
                bubble.appendChild(citDiv);
            }
            appendMessageActions(bubble, text, msgDiv);
            if (!conversationHistory.find(m => m.content === text && m.role === 'assistant')) {
                conversationHistory.push({ role: 'assistant', content: text });
            }
            renderChartBlocks(bubble);
        }
    }

    // ── Message action buttons (copy, export) ──
    function appendMessageActions(bubble, text, msgDiv) {
        const actions = document.createElement('div');
        actions.className = 'chat-msg-actions';

        const copyBtn = document.createElement('button');
        copyBtn.className = 'chat-msg-action-btn';
        copyBtn.title = 'Copy to clipboard';
        copyBtn.innerHTML = '<i class="bi bi-clipboard"></i>';
        copyBtn.addEventListener('click', function() {
            navigator.clipboard.writeText(text).then(() => {
                copyBtn.innerHTML = '<i class="bi bi-check-lg"></i>';
                setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard"></i>'; }, 1500);
            });
        });

        actions.appendChild(copyBtn);
        bubble.appendChild(actions);
    }

    // ── Export conversation ──
    function exportConversation(format) {
        if (conversationHistory.length === 0) return;

        if (format === 'clipboard') {
            const text = conversationHistory.map(m => {
                const label = m.role === 'user' ? 'You' : 'Ask Fund-Raise';
                return label + ':\n' + m.content + '\n';
            }).join('\n---\n\n');
            navigator.clipboard.writeText(text).then(() => {
                alert('Conversation copied to clipboard!');
            });
        } else if (format === 'pdf') {
            // Generate a printable HTML page and trigger print
            const win = window.open('', '_blank');
            if (!win) { alert('Please allow popups to export as PDF.'); return; }
            let html = '<!DOCTYPE html><html><head><title>Ask Fund-Raise Conversation</title>';
            html += '<style>';
            html += 'body{font-family:Arial,sans-serif;max-width:750px;margin:40px auto;padding:0 20px;color:#333;font-size:13px;line-height:1.6;}';
            html += '.msg{margin:20px 0;padding:14px 18px;border-radius:8px;page-break-inside:avoid;}';
            html += '.user{background:#e8f4fd;border-left:3px solid #0072BB;}';
            html += '.assistant{background:#f7f8fa;border-left:3px solid #143D8D;}';
            html += '.label{font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;color:#555;}';
            html += '.content{font-size:13px;line-height:1.7;}';
            html += '.content p{margin:0 0 8px 0;} .content p:last-child{margin-bottom:0;}';
            html += '.content h3{font-size:15px;font-weight:700;color:#143D8D;margin:16px 0 6px;padding-bottom:4px;border-bottom:2px solid #0072BB;}';
            html += '.content h4{font-size:14px;font-weight:700;color:#143D8D;margin:12px 0 6px;padding-left:8px;border-left:3px solid #0072BB;}';
            html += '.content h5{font-size:12px;font-weight:600;color:#888;text-transform:uppercase;margin:10px 0 4px;}';
            html += '.content strong{font-weight:700;color:#1a1a1a;} .content em{color:#666;}';
            html += '.content ul,.content ol{margin:6px 0;padding-left:22px;} .content li{margin-bottom:3px;}';
            html += '.content hr{border:none;height:1px;background:#ddd;margin:12px 0;}';
            html += 'table{width:100%;border-collapse:collapse;margin:10px 0;font-size:12px;}';
            html += 'thead{background:#0072BB;} th{padding:7px 10px;text-align:left;color:#fff;font-size:11px;font-weight:600;text-transform:uppercase;}';
            html += 'td{padding:6px 10px;border-top:1px solid #e5e7eb;} tr:nth-child(even){background:rgba(0,114,187,0.04);}';
            html += 'td:first-child{font-weight:600;} td:not(:first-child),th:not(:first-child){text-align:right;}';
            html += 'h1{font-size:18px;border-bottom:2px solid #0072BB;padding-bottom:8px;color:#143D8D;}';
            html += '.date{font-size:11px;color:#888;margin-bottom:20px;}';
            html += '@media print{body{margin:20px;} .msg{box-shadow:none;}}';
            html += '</style></head><body>';
            html += '<h1>Ask Fund-Raise Conversation</h1>';
            html += '<div class="date">Exported: ' + new Date().toLocaleString() + '</div>';
            conversationHistory.forEach(m => {
                const label = m.role === 'user' ? 'You' : 'Ask Fund-Raise';
                const cls = m.role === 'user' ? 'user' : 'assistant';
                const rendered = m.role === 'assistant' ? renderMarkdown(m.content) : '<p>' + escapeHtml(m.content) + '</p>';
                html += '<div class="msg ' + cls + '"><div class="label">' + label + '</div><div class="content">' + rendered + '</div></div>';
            });
            html += '<script>window.onload=function(){window.print();}<\/script></body></html>';
            win.document.write(html);
            win.document.close();
        }
    }

    function escapeHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // ── Chart rendering ──
    // The AI can embed chart data using ```chart ... ``` code blocks
    // Format: JSON with { type, title, labels, datasets }
    function renderChartBlocks(bubble) {
        const codeBlocks = bubble.querySelectorAll('code');
        codeBlocks.forEach(code => {
            const text = code.textContent.trim();
            if (text.startsWith('{') && text.includes('"type"') && text.includes('"labels"')) {
                try {
                    const config = JSON.parse(text);
                    if (config.type && config.labels && config.datasets) {
                        const container = document.createElement('div');
                        container.className = 'chat-chart-container';
                        if (config.title) {
                            const titleEl = document.createElement('div');
                            titleEl.className = 'chat-chart-title';
                            titleEl.textContent = config.title;
                            container.appendChild(titleEl);
                        }
                        const canvas = document.createElement('canvas');
                        canvas.width = 500;
                        canvas.height = 280;
                        container.appendChild(canvas);

                        // Replace the code block's parent (usually <pre> or inline)
                        const parent = code.parentElement;
                        if (parent && parent.tagName === 'PRE') {
                            parent.replaceWith(container);
                        } else {
                            code.replaceWith(container);
                        }

                        new Chart(canvas, {
                            type: config.type,
                            data: {
                                labels: config.labels,
                                datasets: config.datasets.map((ds, i) => ({
                                    label: ds.label || 'Series ' + (i + 1),
                                    data: ds.data,
                                    backgroundColor: ds.backgroundColor || getChartColors(config.labels.length),
                                    borderColor: ds.borderColor || (config.type === 'line' ? '#2563eb' : undefined),
                                    borderWidth: ds.borderWidth || (config.type === 'line' ? 2 : 1),
                                    tension: 0.3,
                                })),
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: true,
                                plugins: {
                                    legend: { display: config.datasets.length > 1, position: 'bottom', labels: { font: { size: 11 } } },
                                    title: { display: false },
                                },
                                scales: config.type !== 'pie' && config.type !== 'doughnut' ? {
                                    x: { ticks: { font: { size: 11 } } },
                                    y: { ticks: { font: { size: 11 } }, beginAtZero: true },
                                } : undefined,
                            },
                        });
                    }
                } catch (e) {
                    // Not a chart block, leave as-is
                }
            }
        });
    }

    function getChartColors(count) {
        const palette = [
            '#2563eb', '#7c3aed', '#059669', '#d97706', '#dc2626',
            '#0891b2', '#4f46e5', '#16a34a', '#ea580c', '#be185d',
            '#6366f1', '#14b8a6', '#f59e0b', '#ef4444', '#8b5cf6',
        ];
        return Array.from({ length: count }, (_, i) => palette[i % palette.length]);
    }

    // ── Non-streaming appendMessage (for loading saved conversations) ──
    function appendMessage(role, content, imageDataUrl) {
        const div = document.createElement('div');
        div.className = 'chat-message chat-message-' + role;

        const avatar = document.createElement('div');
        avatar.className = 'chat-avatar';

        if (role === 'user') {
            <% if (currentUser && currentUser.avatarUrl) { %>
            avatar.innerHTML = '<img src="<%= currentUser.avatarUrl %>" alt="You">';
            <% } else { %>
            avatar.innerHTML = '<span class="chat-avatar-initials"><%= typeof currentUser !== "undefined" && currentUser ? (currentUser.name || currentUser.email || "?").split(" ").map(w => w[0]).join("").substring(0,2).toUpperCase() : "?" %></span>';
            <% } %>
        } else if (role === 'assistant') {
            avatar.innerHTML = '<img src="/images/fund-raise-icon-flat.svg" alt="AI">';
        } else {
            avatar.innerHTML = '<i class="bi bi-exclamation-triangle"></i>';
        }

        const bubble = document.createElement('div');
        bubble.className = 'chat-bubble';

        // Show image thumbnail in user messages
        if (role === 'user' && imageDataUrl) {
            const imgEl = document.createElement('img');
            imgEl.src = imageDataUrl;
            imgEl.className = 'chat-bubble-image';
            imgEl.alt = 'Attached screenshot';
            bubble.appendChild(imgEl);
        }

        if (role === 'assistant') {
            bubble.innerHTML = renderMarkdown(content);
            appendMessageActions(bubble, content, div);
            // Render charts in loaded messages too
            setTimeout(() => renderChartBlocks(bubble), 0);
        } else if (role === 'error') {
            bubble.className += ' chat-bubble-error';
            bubble.textContent = content;
        } else {
            bubble.textContent = content;
        }

        div.appendChild(avatar);
        div.appendChild(bubble);
        chatMessages.appendChild(div);
        scrollToBottom();
        return div;
    }

    function scrollToBottom() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function renderMarkdown(text) {
        let html = text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');

        // Code blocks (``` ... ```)
        html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, function(match, lang, code) {
            return '<pre><code class="lang-' + lang + '">' + code.trim() + '</code></pre>';
        });

        // Markdown tables: detect blocks of | ... | lines
        html = html.replace(/((?:^\|.+\|$\n?)+)/gm, function(tableBlock) {
            var rows = tableBlock.trim().split('\n');
            if (rows.length < 2) return tableBlock;
            var tableHtml = '<div class="chat-table-wrap"><table class="chat-table">';
            var isHeader = true;
            for (var i = 0; i < rows.length; i++) {
                var row = rows[i].trim();
                // Skip separator row (| --- | --- |)
                var sepCells = row.split('|').filter(function(c) { return c.trim() !== ''; });
                if (sepCells.every(function(c) { return /^[\s\-:]+$/.test(c); })) {
                    isHeader = false;
                    continue;
                }
                var cells = sepCells;
                if (isHeader) {
                    tableHtml += '<thead><tr>' + cells.map(function(c) {
                        return '<th>' + c.trim() + '</th>';
                    }).join('') + '</tr></thead><tbody>';
                    isHeader = false;
                } else {
                    tableHtml += '<tr>' + cells.map(function(c) {
                        return '<td>' + c.trim() + '</td>';
                    }).join('') + '</tr>';
                }
            }
            tableHtml += '</tbody></table></div>';
            return tableHtml;
        });

        // Inline code
        html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

        // Horizontal rules
        html = html.replace(/^---+$/gm, '<hr class="chat-hr">');

        html = html
            .replace(/^#### (.+)$/gm, '<h5>$1</h5>')
            .replace(/^### (.+)$/gm, '<h4>$1</h4>')
            .replace(/^## (.+)$/gm, '<h3>$1</h3>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
            .replace(/^- (.+)$/gm, '<li>$1</li>')
            .replace(/^\d+\.\s+(.+)$/gm, '<li class="chat-ol-item">$1</li>')
            .replace(/\n\n/g, '</p><p>')
            .replace(/\n/g, '<br>');

        // Wrap consecutive <li> into <ul>, consecutive .chat-ol-item into <ol>
        html = html.replace(/((?:<li class="chat-ol-item">.*?<\/li>\s*(?:<br>)?)+)/g, function(match) {
            return '<ol>' + match.replace(/<br>/g, '').replace(/ class="chat-ol-item"/g, '') + '</ol>';
        });
        html = html.replace(/((?:<li>.*?<\/li>\s*(?:<br>)?)+)/g, function(match) {
            return '<ul>' + match.replace(/<br>/g, '') + '</ul>';
        });

        return '<p>' + html + '</p>';
    }

    window.askSuggestion = function(btn) {
        sendMessage(btn.textContent);
    };

    // ── Export buttons (accessible from header) ──
    // Add export dropdown to header actions
    (function addExportButtons() {
        const headerActions = document.querySelector('.chat-header-actions');
        const exportBtn = document.createElement('div');
        exportBtn.className = 'chat-export-dropdown';
        exportBtn.innerHTML = '<button class="btn-brand chat-clear-btn" id="exportToggle" title="Export conversation">' +
            '<i class="bi bi-download"></i> Export</button>' +
            '<div class="chat-export-menu" id="exportMenu">' +
            '<button class="chat-export-option" data-format="clipboard"><i class="bi bi-clipboard"></i> Copy to Clipboard</button>' +
            '<button class="chat-export-option" data-format="pdf"><i class="bi bi-file-earmark-pdf"></i> Export as PDF</button>' +
            '</div>';
        headerActions.insertBefore(exportBtn, headerActions.firstChild);

        const toggle = exportBtn.querySelector('#exportToggle');
        const menu = exportBtn.querySelector('#exportMenu');
        toggle.addEventListener('click', function() {
            menu.classList.toggle('open');
        });
        document.addEventListener('click', function(e) {
            if (!exportBtn.contains(e.target)) menu.classList.remove('open');
        });
        exportBtn.querySelectorAll('.chat-export-option').forEach(btn => {
            btn.addEventListener('click', function() {
                exportConversation(this.dataset.format);
                menu.classList.remove('open');
            });
        });
    })();

    // ── On load: restore conversation from URL or show welcome ──
    const urlParams = new URLSearchParams(window.location.search);
    const loadId = '<%= conversationId || "" %>' || urlParams.get('c');
    if (loadId) {
        loadConversation(loadId);
    }

    if (!chatInput.disabled) chatInput.focus();
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

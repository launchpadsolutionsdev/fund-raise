<%- include('../partials/header') %>

<!-- Hero Card -->
<div class="ac-hero">
    <div class="ac-hero-icon"><i class="bi bi-lightning-charge"></i></div>
    <div class="ac-hero-text">
        <h2>Action Centre</h2>
        <p>Track donor follow-ups, delegate tasks to your team, and never let a conversation fall through the cracks.</p>
        <div class="ac-hero-chips">
            <span class="ac-hero-chip"><i class="bi bi-check-circle-fill"></i> Follow-Ups</span>
            <span class="ac-hero-chip"><i class="bi bi-check-circle-fill"></i> Due Dates</span>
            <span class="ac-hero-chip"><i class="bi bi-check-circle-fill"></i> Team Delegation</span>
            <span class="ac-hero-chip"><i class="bi bi-check-circle-fill"></i> Donor Context</span>
            <span class="ac-hero-chip"><i class="bi bi-check-circle-fill"></i> AI-Powered</span>
        </div>
    </div>
    <% if (currentUser && currentUser.canUpload()) { %>
    <div class="ac-hero-actions">
        <button class="ac-hero-btn-secondary" id="bulkEditToggle"><i class="bi bi-check2-square"></i> Bulk Edit</button>
        <button class="ac-hero-btn-primary" id="newActionBtn"><i class="bi bi-plus-lg"></i> New Action</button>
    </div>
    <% } %>
</div>

<!-- Tabs -->
<div class="action-tabs" id="actionTabs">
    <button class="action-tab active" data-tab="my">My Actions</button>
    <button class="action-tab" data-tab="assigned">Assigned by Me</button>
    <% if (currentUser && currentUser.isAdmin()) { %>
    <button class="action-tab" data-tab="all">All Actions</button>
    <% } %>
</div>

<!-- Filters row -->
<div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:16px;">
    <!-- Status filter pills -->
    <div class="action-filters" id="actionFilters" style="margin-bottom:0;">
        <button class="action-filter-pill active" data-status="">Open</button>
        <button class="action-filter-pill" data-status="pending">Pending</button>
        <button class="action-filter-pill" data-status="resolved">Resolved</button>
    </div>
    <div style="border-left:1px solid var(--color-border-primary);height:24px;"></div>
    <!-- Due date filters -->
    <div class="action-filters" id="dueFilters" style="margin-bottom:0;">
        <button class="action-due-pill" data-due="overdue"><i class="bi bi-exclamation-circle"></i> Overdue</button>
        <button class="action-due-pill" data-due="today">Due Today</button>
        <button class="action-due-pill" data-due="week">This Week</button>
    </div>
    <div style="margin-left:auto;">
        <select class="action-sort-select" id="actionSort">
            <option value="priority">Sort: Priority</option>
            <option value="due">Sort: Due Date</option>
            <option value="created">Sort: Newest</option>
        </select>
    </div>
</div>

<!-- Activity digest -->
<div class="action-digest" id="actionDigest" style="display:none;"></div>

<!-- Stats bar -->
<div class="action-stats-bar" id="actionStats" style="display:none;"></div>

<!-- Action list -->
<div class="action-list" id="actionList">
    <div style="text-align:center;padding:40px;color:var(--color-text-tertiary);font-size:13px;">Loading...</div>
</div>

<!-- Bulk action bar -->
<% if (currentUser && currentUser.canUpload()) { %>
<div class="action-bulk-bar" id="bulkBar" style="display:none;">
    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;color:var(--color-text-secondary);">
        <input type="checkbox" id="bulkSelectAll" style="width:16px;height:16px;cursor:pointer;"> Select all
    </label>
    <span id="bulkCount" style="font-size:12px;font-weight:600;color:var(--color-text-primary);">0 selected</span>
    <div style="margin-left:auto;display:flex;gap:8px;">
        <button class="btn-secondary" id="bulkResolve" style="font-size:12px;padding:6px 12px;"><i class="bi bi-check-circle"></i> Mark Resolved</button>
        <button class="btn-secondary" id="bulkPending" style="font-size:12px;padding:6px 12px;"><i class="bi bi-clock"></i> Mark Pending</button>
        <button class="btn-secondary" id="bulkOpen" style="font-size:12px;padding:6px 12px;"><i class="bi bi-circle"></i> Re-open</button>
        <button class="btn-secondary" id="bulkCancel" style="font-size:12px;padding:6px 12px;color:var(--color-text-tertiary);">Cancel</button>
    </div>
</div>
<% } %>

<div id="loadMore" style="text-align:center;padding:16px;display:none;">
    <button class="btn-secondary" id="loadMoreBtn">Load More</button>
</div>

<!-- New Action Modal -->
<div class="modal-overlay" id="newActionModal" style="display:none;">
    <div class="modal-dialog" style="max-width:560px;">
        <div class="modal-header">
            <span>New Action</span>
            <button class="modal-close" id="closeActionModal"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Assign To <span style="color:#A32D2D">*</span></label>
                <select class="form-input" id="actionAssignee">
                    <option value="">Select team member...</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" style="margin-bottom:6px;">Quick Templates</label>
                <div class="action-template-row" id="actionTemplates">
                    <button class="action-template-btn" data-title="Thank donor" data-desc="Send a personalized thank-you note for their recent gift." data-priority="normal"><i class="bi bi-heart"></i> Thank Donor</button>
                    <button class="action-template-btn" data-title="Schedule meeting" data-desc="Set up a meeting to discuss giving plans." data-priority="high"><i class="bi bi-calendar-event"></i> Schedule Meeting</button>
                    <button class="action-template-btn" data-title="Send follow-up letter" data-desc="Draft and send a follow-up letter regarding their recent engagement." data-priority="normal"><i class="bi bi-envelope"></i> Follow-up Letter</button>
                    <button class="action-template-btn" data-title="Reconnect with lapsed donor" data-desc="Reach out to re-engage this donor who hasn't given recently." data-priority="high"><i class="bi bi-arrow-repeat"></i> Reconnect</button>
                    <button class="action-template-btn" data-title="Prepare upgrade proposal" data-desc="Review giving history and prepare a proposal for increased giving." data-priority="normal"><i class="bi bi-graph-up-arrow"></i> Upgrade Proposal</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Title <span style="color:#A32D2D">*</span></label>
                <input type="text" class="form-input" id="actionTitle" maxlength="255" placeholder="e.g. Follow up with Margaret Chen">
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea class="form-input form-textarea" id="actionDescription" rows="4" placeholder="Detailed instructions or context..."></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Priority</label>
                <div class="action-priority-options">
                    <button class="action-priority-btn active" data-priority="normal">Normal</button>
                    <button class="action-priority-btn" data-priority="high">High</button>
                    <button class="action-priority-btn" data-priority="urgent">Urgent</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Due Date</label>
                <input type="date" class="form-input" id="actionDueDate" style="max-width:200px;">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" id="cancelAction">Cancel</button>
            <button class="btn-brand" id="submitAction"><i class="bi bi-send"></i> Assign</button>
        </div>
    </div>
</div>

<style>
/* ── Action Centre Hero ── */
.ac-hero {
    margin: 0 0 24px;
    background: linear-gradient(135deg, var(--fr-navy) 0%, #252d4a 100%);
    border-radius: 16px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    gap: 36px;
    color: #fff;
    box-shadow: 0 4px 24px rgba(26, 34, 61, 0.18);
}
.ac-hero-icon {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--fr-blue-start), var(--fr-blue-end));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: #fff;
    box-shadow: 0 4px 16px rgba(25, 96, 249, 0.35);
}
.ac-hero-text { flex: 1; }
.ac-hero-text h2 {
    margin: 0 0 6px;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.3px;
}
.ac-hero-text p {
    margin: 0 0 16px;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
}
.ac-hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.ac-hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
}
.ac-hero-chip i { color: var(--fr-cyan-start); font-size: 12px; }
.ac-hero-actions {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.ac-hero-btn-primary {
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--fr-blue-start), var(--fr-blue-end));
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 2px 12px rgba(25, 96, 249, 0.3);
    white-space: nowrap;
}
.ac-hero-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(25, 96, 249, 0.45); }
.ac-hero-btn-secondary {
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 8px;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.85);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.15s;
    white-space: nowrap;
}
.ac-hero-btn-secondary:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }

@media (max-width: 840px) {
    .ac-hero { flex-direction: column; text-align: center; padding: 28px 24px; }
    .ac-hero-chips { justify-content: center; }
    .ac-hero-actions { flex-direction: row; }
}

/* Action Centre Styles */
.action-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--color-border-primary);
    margin-bottom: 16px;
}
.action-tab {
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
}
.action-tab:hover { color: var(--color-text-primary); }
.action-tab.active {
    color: #3434D6;
    border-bottom-color: #3434D6;
}

.action-filters {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
}
.action-filter-pill {
    padding: 6px 16px;
    font-size: 12px;
    font-weight: 500;
    border-radius: 20px;
    border: 1px solid var(--color-border-primary);
    background: var(--color-background-primary);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
}
.action-filter-pill:hover { border-color: #3434D6; color: #3434D6; }
.action-filter-pill.active {
    background: #3434D6;
    color: #fff;
    border-color: #3434D6;
}

/* Activity digest */
.action-digest {
    margin-bottom: 12px;
    padding: 10px 16px;
    background: linear-gradient(135deg, rgba(52,52,214,0.04), rgba(29,158,117,0.04));
    border: 1px solid var(--color-border-primary);
    border-radius: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.6;
}
.action-digest i { margin-right: 2px; }

.action-stats-bar {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    padding: 12px 16px;
    background: var(--color-background-secondary);
    border-radius: 8px;
    font-size: 12px;
    color: var(--color-text-secondary);
}
.action-stat { font-weight: 600; }
.action-stat-value { color: #3434D6; font-size: 16px; font-weight: 700; margin-right: 4px; }

.action-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.action-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-primary);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    border-left: 4px solid #3434D6;
    position: relative;
}
.action-card:hover {
    border-color: #3434D6;
    box-shadow: 0 2px 8px rgba(52, 52, 214, 0.08);
}
.action-card.priority-high { border-left-color: #BA7517; }
.action-card.priority-urgent { border-left-color: #A32D2D; }

.action-card-new-dot {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #3434D6;
}

.action-card-body { flex: 1; min-width: 0; }
.action-card-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.action-card-donor {
    font-size: 12px;
    color: #3434D6;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
}
.action-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--color-text-tertiary);
    flex-wrap: wrap;
}
.action-card-meta .action-card-avatar {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    object-fit: cover;
    vertical-align: middle;
}
.action-card-meta .action-card-avatar-initials {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-background-tertiary, #D3D6E0);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 700;
    color: var(--color-text-secondary);
}

.action-card-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
}

.action-status-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.action-status-badge.open { background: rgba(52,52,214,0.1); color: #3434D6; }
.action-status-badge.pending { background: rgba(186,117,23,0.1); color: #BA7517; }
.action-status-badge.resolved { background: rgba(29,158,117,0.1); color: #1D9E75; }

.action-comment-count {
    font-size: 11px;
    color: var(--color-text-tertiary);
    display: flex;
    align-items: center;
    gap: 3px;
}

/* Priority option buttons */
.action-priority-options { display: flex; gap: 8px; }
.action-priority-btn {
    padding: 6px 16px;
    font-size: 12px;
    font-weight: 500;
    border-radius: 6px;
    border: 1px solid var(--color-border-primary);
    background: var(--color-background-primary);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
}
.action-priority-btn.active { background: #3434D6; color: #fff; border-color: #3434D6; }
.action-priority-btn[data-priority="high"].active { background: #BA7517; border-color: #BA7517; }
.action-priority-btn[data-priority="urgent"].active { background: #A32D2D; border-color: #A32D2D; }

/* Action templates */
.action-template-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}
.action-template-btn {
    padding: 5px 10px;
    font-size: 11px;
    font-weight: 500;
    border-radius: 6px;
    border: 1px solid var(--color-border-primary);
    background: var(--color-background-primary);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}
.action-template-btn:hover { border-color: #3434D6; color: #3434D6; }
.action-template-btn.selected { background: #3434D6; color: #fff; border-color: #3434D6; }

/* Due date pills */
.action-due-pill {
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
    border-radius: 20px;
    border: 1px solid var(--color-border-primary);
    background: var(--color-background-primary);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
}
.action-due-pill:hover { border-color: #BA7517; color: #BA7517; }
.action-due-pill.active { background: #BA7517; color: #fff; border-color: #BA7517; }
.action-due-pill[data-due="overdue"].active { background: #A32D2D; border-color: #A32D2D; }

/* Sort dropdown */
.action-sort-select {
    padding: 6px 12px;
    font-size: 12px;
    font-family: inherit;
    border: 1px solid var(--color-border-primary);
    border-radius: 6px;
    background: var(--color-background-primary);
    color: var(--color-text-secondary);
    cursor: pointer;
}

/* Bulk action bar */
.action-bulk-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: var(--color-background-secondary);
    border: 1px solid #3434D6;
    border-radius: 8px;
    margin-bottom: 12px;
}

/* Due date on action cards */
.action-card-due {
    font-size: 11px;
    display: flex;
    align-items: center;
    gap: 3px;
}
.action-card-due.overdue { color: #A32D2D; font-weight: 600; }
.action-card-due.due-soon { color: #BA7517; font-weight: 600; }
.action-card-due.due-later { color: var(--color-text-tertiary); }
</style>

<script>
(function() {
    const list = document.getElementById('actionList');
    const loadMoreDiv = document.getElementById('loadMore');
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    const statsBar = document.getElementById('actionStats');
    const isAdmin = <%= currentUser && currentUser.isAdmin() ? 'true' : 'false' %>;
    const canCreate = <%= currentUser && currentUser.canUpload() ? 'true' : 'false' %>;

    let currentTab = 'my';
    let currentStatus = '';  // empty = open (default)
    let currentDueFilter = '';
    let currentSort = 'priority';
    let page = 1;
    const limit = 20;
    let total = 0;

    // Tab switching
    document.getElementById('actionTabs').addEventListener('click', function(e) {
        const btn = e.target.closest('.action-tab');
        if (!btn) return;
        document.querySelectorAll('.action-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentTab = btn.dataset.tab;
        page = 1;
        loadActions(true);
    });

    // Status filter
    document.getElementById('actionFilters').addEventListener('click', function(e) {
        const btn = e.target.closest('.action-filter-pill');
        if (!btn) return;
        document.querySelectorAll('.action-filter-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentStatus = btn.dataset.status;
        // Clear due filter when switching status
        currentDueFilter = '';
        document.querySelectorAll('.action-due-pill').forEach(b => b.classList.remove('active'));
        page = 1;
        loadActions(true);
    });

    // Due date filter
    document.getElementById('dueFilters').addEventListener('click', function(e) {
        const btn = e.target.closest('.action-due-pill');
        if (!btn) return;
        const wasActive = btn.classList.contains('active');
        document.querySelectorAll('.action-due-pill').forEach(b => b.classList.remove('active'));
        if (wasActive) {
            currentDueFilter = '';
        } else {
            btn.classList.add('active');
            currentDueFilter = btn.dataset.due;
        }
        page = 1;
        loadActions(true);
    });

    // Sort
    document.getElementById('actionSort').addEventListener('change', function() {
        currentSort = this.value;
        page = 1;
        loadActions(true);
    });

    // Load more
    loadMoreBtn.addEventListener('click', () => {
        page++;
        loadActions(false);
    });

    // Load stats + digest
    var digestEl = document.getElementById('actionDigest');
    function loadStats() {
        fetch('/api/actions/stats')
            .then(r => r.json())
            .then(data => {
                if (data.error) return;
                const totalActive = data.myOpen + data.myPending;
                if (totalActive > 0 || data.assignedOpen > 0 || data.myOverdue > 0) {
                    statsBar.style.display = 'flex';
                    var statsHtml =
                        '<div class="action-stat"><span class="action-stat-value">' + data.myOpen + '</span>open for me</div>' +
                        '<div class="action-stat"><span class="action-stat-value">' + data.myPending + '</span>pending</div>' +
                        '<div class="action-stat"><span class="action-stat-value">' + data.assignedOpen + '</span>assigned out</div>';
                    if (data.myOverdue > 0) {
                        statsHtml += '<div class="action-stat"><span class="action-stat-value" style="color:#A32D2D;">' + data.myOverdue + '</span><span style="color:#A32D2D;">overdue</span></div>';
                    }
                    if (data.myDueToday > 0) {
                        statsHtml += '<div class="action-stat"><span class="action-stat-value" style="color:#BA7517;">' + data.myDueToday + '</span><span style="color:#BA7517;">due today</span></div>';
                    }
                    statsBar.innerHTML = statsHtml;
                }

                // Build activity digest sentence
                var parts = [];
                if (data.myOverdue > 0) parts.push('<i class="bi bi-exclamation-triangle-fill" style="color:#A32D2D;"></i> <strong style="color:#A32D2D;">' + data.myOverdue + ' overdue</strong>');
                if (data.myDueToday > 0) parts.push('<i class="bi bi-clock-fill" style="color:#BA7517;"></i> <strong style="color:#BA7517;">' + data.myDueToday + ' due today</strong>');
                if (data.dueThisWeek > 0) parts.push('<strong>' + data.dueThisWeek + '</strong> due this week');
                if (data.resolvedYesterday > 0) parts.push('<i class="bi bi-check-circle-fill" style="color:#1D9E75;"></i> <strong style="color:#1D9E75;">' + data.resolvedYesterday + ' resolved</strong> yesterday');
                if (parts.length > 0) {
                    digestEl.style.display = 'block';
                    digestEl.innerHTML = '<i class="bi bi-lightning-charge" style="color:#3434D6;"></i> ' + parts.join(' &nbsp;&middot;&nbsp; ');
                }
            })
            .catch(() => {});
    }

    function loadActions(replace) {
        if (replace) page = 1;
        let url;
        const statusParam = currentStatus || 'open';
        var base;
        if (currentTab === 'my') {
            base = '/api/actions';
        } else if (currentTab === 'assigned') {
            base = '/api/actions/assigned';
        } else {
            base = '/api/actions/all';
        }
        url = base + '?status=' + statusParam + '&page=' + page + '&limit=' + limit + '&sort=' + currentSort;
        if (currentDueFilter) url += '&dueFilter=' + currentDueFilter;

        fetch(url)
            .then(r => r.json())
            .then(data => {
                if (data.error) throw new Error(data.error);
                if (replace) list.innerHTML = '';
                total = data.total;

                if (data.actions.length === 0 && page === 1) {
                    list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--color-text-tertiary);font-size:13px;">No actions found.</div>';
                    loadMoreDiv.style.display = 'none';
                    return;
                }

                data.actions.forEach(a => list.appendChild(createActionCard(a)));
                const loaded = (page - 1) * limit + data.actions.length;
                loadMoreDiv.style.display = loaded < total ? 'block' : 'none';
            })
            .catch(() => {
                if (replace) list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--color-text-danger);">Failed to load actions.</div>';
            });
    }

    function createActionCard(a) {
        const card = document.createElement('div');
        card.className = 'action-card priority-' + a.priority;
        card.addEventListener('click', () => { window.location.href = '/actions/' + a.id; });

        // Determine if "new" (unviewed)
        const isNew = !a.lastViewedAt || new Date(a.updatedAt) > new Date(a.lastViewedAt);
        const newDot = (currentTab === 'my' && isNew) ? '<div class="action-card-new-dot"></div>' : '';

        // User info (who assigned / who is assigned)
        const person = currentTab === 'my' ? a.assignedBy : (a.assignedTo || a.assignedBy);
        const personLabel = currentTab === 'my' ? 'Assigned by ' : 'Assigned to ';

        let avatarHtml = '';
        if (person) {
            if (person.avatarSrc) {
                avatarHtml = '<img src="' + esc(person.avatarSrc) + '" alt="" class="action-card-avatar">';
            } else {
                const initials = (person.displayName || '').split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() || '?';
                avatarHtml = '<span class="action-card-avatar-initials">' + initials + '</span>';
            }
        }

        // For the "all" tab, show both
        let metaPerson = '';
        if (currentTab === 'all' && a.assignedBy && a.assignedTo) {
            metaPerson = esc(a.assignedBy.displayName) + ' &rarr; ' + esc(a.assignedTo.displayName);
        } else if (person) {
            metaPerson = personLabel + esc(person.displayName);
        }

        const donorHtml = a.constituentName
            ? '<div class="action-card-donor"><i class="bi bi-link-45deg"></i> ' + esc(a.constituentName) + '</div>'
            : '';

        // Due date rendering
        var dueHtml = '';
        if (a.dueDate && a.status !== 'resolved') {
            var today = new Date().toISOString().split('T')[0];
            var tomorrow = new Date(Date.now() + 86400000).toISOString().split('T')[0];
            var dueCls = 'due-later';
            var dueIcon = 'bi-calendar3';
            if (a.dueDate < today) { dueCls = 'overdue'; dueIcon = 'bi-exclamation-triangle-fill'; }
            else if (a.dueDate <= tomorrow) { dueCls = 'due-soon'; dueIcon = 'bi-clock-fill'; }
            var dd = new Date(a.dueDate + 'T00:00:00');
            var dueLabel = a.dueDate < today ? 'Overdue' : (a.dueDate === today ? 'Due today' : dd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
            dueHtml = '<span class="action-card-due ' + dueCls + '"><i class="bi ' + dueIcon + '"></i> ' + dueLabel + '</span>';
        }

        // Bulk select checkbox
        var checkboxHtml = '<input type="checkbox" class="action-bulk-check" data-id="' + a.id + '" onclick="event.stopPropagation();" style="display:none;width:16px;height:16px;cursor:pointer;flex-shrink:0;margin-top:2px;">';

        card.innerHTML = checkboxHtml + newDot +
            '<div class="action-card-body">' +
                '<div class="action-card-title">' + esc(a.title) + '</div>' +
                donorHtml +
                '<div class="action-card-meta">' +
                    avatarHtml +
                    '<span>' + metaPerson + '</span>' +
                    '<span>&middot;</span>' +
                    '<span>' + formatDate(a.createdAt) + '</span>' +
                '</div>' +
            '</div>' +
            '<div class="action-card-right">' +
                '<span class="action-status-badge ' + a.status + '">' + a.status + '</span>' +
                dueHtml +
                (a.commentCount > 0 ? '<span class="action-comment-count"><i class="bi bi-chat-dots"></i> ' + a.commentCount + '</span>' : '') +
            '</div>';

        return card;
    }

    // New Action Modal
    if (canCreate) {
        const modal = document.getElementById('newActionModal');
        let selectedPriority = 'normal';
        let teamMembers = [];

        document.getElementById('newActionBtn').addEventListener('click', () => {
            modal.style.display = 'flex';
            loadTeamMembers();
        });
        document.getElementById('closeActionModal').addEventListener('click', () => { modal.style.display = 'none'; });
        document.getElementById('cancelAction').addEventListener('click', () => { modal.style.display = 'none'; });
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

        document.querySelectorAll('.action-priority-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.action-priority-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                selectedPriority = this.dataset.priority;
            });
        });

        // Template buttons
        document.getElementById('actionTemplates').addEventListener('click', function(e) {
            var btn = e.target.closest('.action-template-btn');
            if (!btn) return;
            var wasSelected = btn.classList.contains('selected');
            document.querySelectorAll('.action-template-btn').forEach(function(b) { b.classList.remove('selected'); });
            if (wasSelected) return; // deselect = leave fields as-is
            btn.classList.add('selected');
            document.getElementById('actionTitle').value = btn.dataset.title;
            document.getElementById('actionDescription').value = btn.dataset.desc;
            // Set priority
            var prio = btn.dataset.priority || 'normal';
            selectedPriority = prio;
            document.querySelectorAll('.action-priority-btn').forEach(function(b) { b.classList.remove('active'); });
            document.querySelector('.action-priority-btn[data-priority="' + prio + '"]').classList.add('active');
        });

        function loadTeamMembers() {
            if (teamMembers.length > 0) return;
            fetch('/api/actions/team-members')
                .then(r => r.json())
                .then(data => {
                    teamMembers = data;
                    const sel = document.getElementById('actionAssignee');
                    sel.innerHTML = '<option value="">Select team member...</option>';
                    data.forEach(u => {
                        sel.innerHTML += '<option value="' + u.id + '">' + esc(u.displayName) + '</option>';
                    });
                })
                .catch(() => {});
        }

        document.getElementById('submitAction').addEventListener('click', function() {
            const assignedToId = document.getElementById('actionAssignee').value;
            const title = document.getElementById('actionTitle').value.trim();
            const description = document.getElementById('actionDescription').value.trim();
            if (!assignedToId) return frAlert('Please select a team member.', { variant: 'warning', title: 'Missing Assignee' });
            if (!title) return frAlert('Please enter a title.', { variant: 'warning', title: 'Missing Title' });

            this.disabled = true;
            fetch('/api/actions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ assignedToId: parseInt(assignedToId), title, description: description || undefined, priority: selectedPriority, dueDate: document.getElementById('actionDueDate').value || undefined }),
            })
            .then(r => r.json())
            .then(data => {
                if (data.error) throw new Error(data.error);
                modal.style.display = 'none';
                document.getElementById('actionTitle').value = '';
                document.getElementById('actionDescription').value = '';
                document.getElementById('actionDueDate').value = '';
                document.getElementById('actionAssignee').value = '';
                document.querySelectorAll('.action-template-btn').forEach(function(b) { b.classList.remove('selected'); });
                selectedPriority = 'normal';
                document.querySelectorAll('.action-priority-btn').forEach(b => b.classList.remove('active'));
                document.querySelector('.action-priority-btn[data-priority="normal"]').classList.add('active');
                page = 1;
                loadActions(true);
                loadStats();
            })
            .catch(err => frAlert('Error: ' + err.message, { variant: 'danger', title: 'Error' }))
            .finally(() => { document.getElementById('submitAction').disabled = false; });
        });
    }

    function esc(str) {
        return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function formatDate(dateStr) {
        const d = new Date(dateStr);
        const now = new Date();
        const diff = now - d;
        if (diff < 60000) return 'Just now';
        if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';
        if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';
        if (diff < 604800000) return Math.floor(diff / 86400000) + 'd ago';
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    // Bulk edit mode
    var bulkMode = false;
    var bulkToggle = document.getElementById('bulkEditToggle');
    var bulkBar = document.getElementById('bulkBar');
    var bulkSelectAll = document.getElementById('bulkSelectAll');

    if (bulkToggle && bulkBar) {
        bulkToggle.addEventListener('click', function() {
            bulkMode = !bulkMode;
            toggleBulkMode(bulkMode);
        });

        document.getElementById('bulkCancel').addEventListener('click', function() {
            bulkMode = false;
            toggleBulkMode(false);
        });

        bulkSelectAll.addEventListener('change', function() {
            var checks = document.querySelectorAll('.action-bulk-check');
            checks.forEach(function(c) { c.checked = bulkSelectAll.checked; });
            updateBulkCount();
        });

        list.addEventListener('change', function(e) {
            if (e.target.classList.contains('action-bulk-check')) updateBulkCount();
        });

        document.getElementById('bulkResolve').addEventListener('click', function() { bulkStatusChange('resolved'); });
        document.getElementById('bulkPending').addEventListener('click', function() { bulkStatusChange('pending'); });
        document.getElementById('bulkOpen').addEventListener('click', function() { bulkStatusChange('open'); });
    }

    function toggleBulkMode(on) {
        var checks = document.querySelectorAll('.action-bulk-check');
        checks.forEach(function(c) { c.style.display = on ? 'block' : 'none'; c.checked = false; });
        if (bulkBar) bulkBar.style.display = on ? 'flex' : 'none';
        if (bulkSelectAll) bulkSelectAll.checked = false;
        if (bulkToggle) bulkToggle.style.display = on ? 'none' : '';
        updateBulkCount();
    }

    function updateBulkCount() {
        var checked = document.querySelectorAll('.action-bulk-check:checked');
        var countEl = document.getElementById('bulkCount');
        if (countEl) countEl.textContent = checked.length + ' selected';
    }

    function bulkStatusChange(status) {
        var checked = document.querySelectorAll('.action-bulk-check:checked');
        if (checked.length === 0) return frAlert('No actions selected.', { variant: 'warning', title: 'Bulk Edit' });
        var ids = [];
        checked.forEach(function(c) { ids.push(c.dataset.id); });

        var label = status === 'resolved' ? 'resolved' : (status === 'pending' ? 'pending' : 're-opened');
        frConfirm('Mark ' + ids.length + ' action(s) as ' + label + '?', { variant: 'confirm', title: 'Bulk Update' }).then(function(ok) {
            if (!ok) return;
            var promises = ids.map(function(id) {
                return fetch('/api/actions/' + id + '/status', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: status }),
                }).then(function(r) { return r.json(); });
            });
            Promise.all(promises).then(function() {
                bulkMode = false;
                toggleBulkMode(false);
                loadActions(true);
                loadStats();
            }).catch(function(err) {
                frAlert('Some updates failed: ' + err.message, { variant: 'danger', title: 'Error' });
            });
        });
    }

    loadStats();
    loadActions(true);
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

<%- include('../partials/department_base') %>

<% if (data && data.summary) { %>
<% const s = data.summary; %>
<div class="kpi-grid" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
    <% if (s.avgGift) { %>
    <div class="kpi-card">
        <div class="kpi-label">Average Legacy Gift</div>
        <div class="kpi-value">$<%= (parseFloat(s.avgGift) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <% } %>
    <% if (s.newExpectancies != null) { %>
    <div class="kpi-card">
        <div class="kpi-label">New Confirmed Expectancies</div>
        <div class="kpi-value"><%= s.newExpectancies %></div>
    </div>
    <% } %>
    <% if (s.openEstates != null) { %>
    <div class="kpi-card">
        <div class="kpi-label">Open Estates</div>
        <div class="kpi-value"><%= s.openEstates %></div>
    </div>
    <% } %>
</div>
<% } %>

<%- include('../partials/department_charts') %>

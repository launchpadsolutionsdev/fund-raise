<%- include('../partials/department_base') %>

<% if (data && data.summary && data.summary.thirdPartyTotalAmount) { %>
<% const s = data.summary; %>
<div class="section-title">Third Party Events</div>
<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Third Party Gifts</div>
        <div class="kpi-value"><%= (s.thirdPartyTotalGifts || 0).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Third Party Amount</div>
        <div class="kpi-value">$<%= (parseFloat(s.thirdPartyTotalAmount) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Third Party Goal</div>
        <div class="kpi-value">$<%= (parseFloat(s.thirdPartyGoal) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Third Party % to Goal</div>
        <div class="kpi-value"><%= ((parseFloat(s.thirdPartyPctToGoal) || 0) * 100).toFixed(1) %>%</div>
    </div>
</div>
<% } %>

<%- include('../partials/department_charts') %>

<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">Upload Data</div>
        <div class="page-subtitle">Upload the 5 weekly cumulative reports (FY 2025–2026)</div>
    </div>
</div>

<div class="fr-card">
    <div class="fr-card-body">
        <form id="upload-form" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 12px; margin-bottom: 20px;">
                <div>
                    <label class="fr-form-label">Report Date</label>
                    <input type="date" name="snapshot_date" id="snapshot-date" class="fr-form-input" required>
                    <div class="text-muted" style="font-size:11px;margin-top:4px;" id="week-label"></div>
                </div>
                <div>
                    <label class="fr-form-label">Reporting Period</label>
                    <div class="fr-form-input" id="reporting-period" style="background:var(--color-bg-secondary);border:none;font-size:12px;color:var(--color-text-secondary);">—</div>
                    <div class="text-muted" style="font-size:11px;margin-top:4px;">Cumulative from FY start</div>
                </div>
                <div>
                    <label class="fr-form-label">Notes (optional)</label>
                    <input type="text" name="notes" class="fr-form-input" placeholder="Any notes about this upload...">
                </div>
            </div>

            <div class="section-title">Department Spreadsheets</div>

            <%
            const deptInfo = [
                { key: 'annual_giving', name: 'Annual Giving', file: 'Annual Giving reporting master sheet.xlsx' },
                { key: 'direct_mail', name: 'Direct Mail', file: 'Direct Mail reporting master sheet.xlsx' },
                { key: 'events', name: 'Events', file: 'Events reporting master sheet.xlsx' },
                { key: 'major_gifts', name: 'Major Gifts', file: 'Major reporting master sheet.xlsx' },
                { key: 'legacy_giving', name: 'Legacy Giving', file: 'legacy reporting master sheet.xlsx' },
            ];
            %>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px;">
                <% for (const d of deptInfo) { %>
                <div class="upload-zone" id="zone-<%= d.key %>">
                    <h6><%= d.name %></h6>
                    <p class="upload-hint">Expected: <%= d.file %></p>
                    <input type="file" name="<%= d.key %>" class="fr-form-input"
                           accept=".xlsx,.xls" data-dept="<%= d.key %>" style="font-size: 12px;">
                    <div class="upload-status mt-2 d-none" id="status-<%= d.key %>"></div>
                </div>
                <% } %>
            </div>

            <div id="overwrite-warning" class="alert-card warning d-none" style="margin-bottom: 16px;">
                <div class="alert-card-title">A snapshot already exists for this date</div>
                <div class="alert-card-text">
                    Check the box to overwrite it.
                    <label style="display: flex; align-items: center; gap: 6px; margin-top: 6px; cursor: pointer;">
                        <input type="checkbox" id="overwrite-check">
                        <span>Yes, overwrite existing data</span>
                    </label>
                </div>
            </div>

            <div id="upload-progress" class="d-none" style="margin-bottom: 16px;">
                <div class="upload-progress-track">
                    <div class="upload-progress-fill" id="progress-bar" style="width: 0%"></div>
                </div>
                <div style="font-size: 12px; color: var(--color-text-secondary);">Uploading...</div>
            </div>

            <div id="upload-results" class="d-none" style="margin-bottom: 16px;"></div>

            <button type="submit" class="btn-brand" id="upload-btn">
                <i class="bi bi-cloud-upload" style="font-size: 14px;"></i>
                Upload & Process
            </button>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
<script src="/js/upload.js"></script>
</body>
</html>

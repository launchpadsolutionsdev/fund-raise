<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">CRM Data Import</div>
        <div class="page-subtitle">Upload your RE NXT gift export to power AI-driven analytics</div>
    </div>
</div>

<!-- Current Data Stats -->
<% if (stats && stats.gifts > 0) { %>
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Current CRM Data</div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-primary);"><%= stats.gifts.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Gifts</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-primary);"><%= stats.fundraisers.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Fundraiser Links</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-primary);"><%= stats.softCredits.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Soft Credits</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-primary);"><%= stats.matches.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Matching Gifts</div>
            </div>
        </div>
        <% if (stats.lastImport) { %>
        <div class="text-muted" style="font-size: 11px; text-align: center; margin-top: 8px;">
            Last import: <%= new Date(stats.lastImport.date).toLocaleDateString() %> (<%= stats.lastImport.fileName %>)
        </div>
        <% } %>
    </div>
</div>
<% } %>

<!-- Upload Form -->
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 4px;">Upload RE NXT Export</div>
        <div class="text-muted" style="font-size: 12px; margin-bottom: 16px;">
            Export your gift data from the NXT Query Editor as an Excel file, then upload it here.
            Existing gifts are updated automatically (upsert by Gift ID).
        </div>

        <form id="crm-upload-form" enctype="multipart/form-data">
            <div style="border: 2px dashed var(--color-border); border-radius: 12px; padding: 32px; text-align: center; cursor: pointer; transition: all 0.2s;" id="drop-zone">
                <div style="font-size: 36px; margin-bottom: 8px;">&#128196;</div>
                <div style="font-weight: 600; margin-bottom: 4px;">Drop your Excel file here or click to browse</div>
                <div class="text-muted" style="font-size: 12px;">.xlsx or .xls up to 300 MB</div>
                <input type="file" name="crm_file" id="crm-file" accept=".xlsx,.xls" style="display:none;">
            </div>

            <div id="file-info" style="display:none; margin-top: 16px; padding: 12px; background: var(--color-bg-secondary); border-radius: 8px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <span id="file-name" style="font-weight: 600;"></span>
                        <span id="file-size" class="text-muted" style="font-size: 12px; margin-left: 8px;"></span>
                    </div>
                    <button type="button" id="clear-file" class="fr-btn fr-btn-secondary" style="padding: 4px 12px; font-size: 12px;">Clear</button>
                </div>
            </div>

            <div id="preview-results" style="display:none; margin-top: 16px;"></div>

            <div style="margin-top: 16px; display: flex; gap: 12px;">
                <button type="button" id="preview-btn" class="fr-btn fr-btn-secondary" disabled>Preview Mapping</button>
                <button type="button" id="import-btn" class="fr-btn fr-btn-primary" disabled>Import Data</button>
            </div>
        </form>

        <!-- Progress -->
        <div id="import-progress" style="display:none; margin-top: 16px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div class="loading-spinner"></div>
                <span id="progress-text">Processing...</span>
            </div>
        </div>

        <!-- Result -->
        <div id="import-result" style="display:none; margin-top: 16px;"></div>
    </div>
</div>

<!-- Import History -->
<% if (history && history.length > 0) { %>
<div class="fr-card">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Import History</div>
        <table class="fr-table" style="width: 100%; font-size: 13px;">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>File</th>
                    <th>Status</th>
                    <th>Gifts</th>
                    <th>Fundraisers</th>
                    <th>Soft Credits</th>
                    <th>Matches</th>
                </tr>
            </thead>
            <tbody>
                <% history.forEach(imp => { %>
                <tr>
                    <td><%= new Date(imp.uploadedAt).toLocaleString() %></td>
                    <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;"><%= imp.fileName %></td>
                    <td>
                        <span class="fr-badge fr-badge-<%= imp.status === 'completed' ? 'success' : imp.status === 'failed' ? 'danger' : 'warning' %>">
                            <%= imp.status %>
                        </span>
                    </td>
                    <td><%= (imp.giftsUpserted || 0).toLocaleString() %></td>
                    <td><%= (imp.fundraisersUpserted || 0).toLocaleString() %></td>
                    <td><%= (imp.softCreditsUpserted || 0).toLocaleString() %></td>
                    <td><%= (imp.matchesUpserted || 0).toLocaleString() %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<script>
(function() {
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('crm-file');
    const fileInfo = document.getElementById('file-info');
    const fileName = document.getElementById('file-name');
    const fileSize = document.getElementById('file-size');
    const clearBtn = document.getElementById('clear-file');
    const previewBtn = document.getElementById('preview-btn');
    const importBtn = document.getElementById('import-btn');
    const previewResults = document.getElementById('preview-results');
    const progressDiv = document.getElementById('import-progress');
    const progressText = document.getElementById('progress-text');
    const resultDiv = document.getElementById('import-result');

    // Drag and drop
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--color-primary)';
        dropZone.style.background = 'var(--color-bg-secondary)';
    });
    dropZone.addEventListener('dragleave', () => {
        dropZone.style.borderColor = 'var(--color-border)';
        dropZone.style.background = '';
    });
    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--color-border)';
        dropZone.style.background = '';
        if (e.dataTransfer.files.length) {
            fileInput.files = e.dataTransfer.files;
            showFileInfo(e.dataTransfer.files[0]);
        }
    });

    fileInput.addEventListener('change', () => {
        if (fileInput.files.length) showFileInfo(fileInput.files[0]);
    });

    function showFileInfo(file) {
        fileName.textContent = file.name;
        fileSize.textContent = formatBytes(file.size);
        fileInfo.style.display = 'block';
        dropZone.style.display = 'none';
        previewBtn.disabled = false;
        importBtn.disabled = false;
        previewResults.style.display = 'none';
        resultDiv.style.display = 'none';
    }

    clearBtn.addEventListener('click', () => {
        fileInput.value = '';
        fileInfo.style.display = 'none';
        dropZone.style.display = '';
        previewBtn.disabled = true;
        importBtn.disabled = true;
        previewResults.style.display = 'none';
        resultDiv.style.display = 'none';
    });

    previewBtn.addEventListener('click', async () => {
        if (!fileInput.files.length) return;
        previewBtn.disabled = true;
        previewBtn.textContent = 'Analyzing...';

        const formData = new FormData();
        formData.append('crm_file', fileInput.files[0]);

        try {
            const res = await fetch('/crm-upload/preview', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.error) {
                previewResults.innerHTML = '<div style="color: var(--color-danger);">' + data.error + '</div>';
            } else {
                let html = '<div style="padding: 12px; background: var(--color-bg-secondary); border-radius: 8px;">';
                html += '<div style="font-weight: 600; margin-bottom: 8px;">Column Mapping Preview</div>';
                html += '<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; font-size: 13px;">';
                for (const [cat, count] of Object.entries(data.categories)) {
                    const label = cat.replace(/([A-Z])/g, ' $1').replace(/^./, c => c.toUpperCase());
                    html += '<div>' + label + ': <strong>' + count + '</strong></div>';
                }
                html += '</div>';
                html += '<div class="text-muted" style="font-size: 12px; margin-top: 8px;">' + data.mappedColumns + '/' + data.totalColumns + ' columns mapped';
                if (data.unmappedColumns.length > 0) {
                    html += ' &middot; Unmapped: ' + data.unmappedColumns.join(', ');
                }
                html += '</div>';
                if (!data.hasGiftId) {
                    html += '<div style="color: var(--color-danger); margin-top: 8px; font-weight: 600;">Missing required "Gift ID" column!</div>';
                    importBtn.disabled = true;
                }
                html += '</div>';
                previewResults.innerHTML = html;
            }
            previewResults.style.display = 'block';
        } catch (err) {
            previewResults.innerHTML = '<div style="color: var(--color-danger);">Error: ' + err.message + '</div>';
            previewResults.style.display = 'block';
        }
        previewBtn.disabled = false;
        previewBtn.textContent = 'Preview Mapping';
    });

    importBtn.addEventListener('click', async () => {
        if (!fileInput.files.length) return;
        if (!confirm('This will import/update all gifts in the file. Continue?')) return;

        importBtn.disabled = true;
        previewBtn.disabled = true;
        progressDiv.style.display = 'block';
        progressText.textContent = 'Uploading and processing... This may take a few minutes for large files.';
        resultDiv.style.display = 'none';

        const formData = new FormData();
        formData.append('crm_file', fileInput.files[0]);

        try {
            const res = await fetch('/crm-upload/process', { method: 'POST', body: formData });
            const data = await res.json();

            progressDiv.style.display = 'none';

            if (data.error) {
                resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(220,53,69,0.1); border-radius: 8px; color: var(--color-danger);"><strong>Import Failed</strong><br>' + data.error + '</div>';
            } else {
                let html = '<div style="padding: 16px; background: rgba(40,167,69,0.1); border-radius: 8px;">';
                html += '<div style="font-weight: 700; color: var(--color-success); margin-bottom: 8px;">Import Successful</div>';
                html += '<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; font-size: 13px;">';
                html += '<div>Total rows processed: <strong>' + (data.stats.totalRows || 0).toLocaleString() + '</strong></div>';
                html += '<div>Unique gifts: <strong>' + (data.stats.uniqueGifts || 0).toLocaleString() + '</strong></div>';
                html += '<div>Gifts upserted: <strong>' + (data.stats.giftsUpserted || 0).toLocaleString() + '</strong></div>';
                html += '<div>Fundraiser links: <strong>' + (data.stats.fundraisersUpserted || 0).toLocaleString() + '</strong></div>';
                html += '<div>Soft credits: <strong>' + (data.stats.softCreditsUpserted || 0).toLocaleString() + '</strong></div>';
                html += '<div>Matching gifts: <strong>' + (data.stats.matchesUpserted || 0).toLocaleString() + '</strong></div>';
                html += '</div>';
                if (data.unmappedColumns && data.unmappedColumns.length > 0) {
                    html += '<div class="text-muted" style="font-size: 11px; margin-top: 8px;">Unmapped columns (ignored): ' + data.unmappedColumns.join(', ') + '</div>';
                }
                html += '</div>';
                resultDiv.innerHTML = html;

                // Reload after 2s to refresh stats
                setTimeout(() => location.reload(), 2000);
            }
            resultDiv.style.display = 'block';
        } catch (err) {
            progressDiv.style.display = 'none';
            resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(220,53,69,0.1); border-radius: 8px; color: var(--color-danger);">Network error: ' + err.message + '</div>';
            resultDiv.style.display = 'block';
        }
        importBtn.disabled = false;
        previewBtn.disabled = false;
    });

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }
})();
</script>

<%- include('../partials/footer') %>

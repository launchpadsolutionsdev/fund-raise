<%- include('../partials/header') %>

<style>
.loading-spinner {
    width: 24px;
    height: 24px;
    border: 3px solid var(--color-border-primary);
    border-top-color: var(--color-brand-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}
@keyframes spin {
    to { transform: rotate(360deg); }
}
</style>

<div class="page-header">
    <div>
        <div class="page-greeting">CRM Data Import</div>
        <div class="page-subtitle">Upload your RE NXT gift export to power AI-driven analytics</div>
    </div>
</div>

<!-- Current Data Stats -->
<% if (stats && stats.gifts > 0) { %>
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Current CRM Data</div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-brand-blue);"><%= stats.gifts.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Gifts</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-brand-blue);"><%= stats.fundraisers.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Fundraiser Links</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-brand-blue);"><%= stats.softCredits.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Soft Credits</div>
            </div>
            <div style="text-align:center;">
                <div style="font-size: 28px; font-weight: 700; color: var(--color-brand-blue);"><%= stats.matches.toLocaleString() %></div>
                <div class="text-muted" style="font-size: 12px;">Matching Gifts</div>
            </div>
        </div>
        <% if (stats.lastImport) { %>
        <div class="text-muted" style="font-size: 11px; text-align: center; margin-top: 8px;">
            Last import: <%= new Date(stats.lastImport.date).toLocaleDateString() %> (<%= stats.lastImport.fileName %>)
        </div>
        <% } %>
    </div>
</div>
<%
  // Stale data nudge — show if last import was 30+ days ago
  const _staleThresholdDays = 30;
  const _lastImportDate = (stats && stats.lastImport && stats.lastImport.date) ? new Date(stats.lastImport.date) : null;
  const _daysSinceImport = _lastImportDate ? Math.floor((Date.now() - _lastImportDate.getTime()) / (1000 * 60 * 60 * 24)) : null;
  const _isStale = _daysSinceImport !== null && _daysSinceImport >= _staleThresholdDays;
%>
<% if (_isStale) { %>
<div class="fr-card" id="staleDataNudge" style="margin-bottom: 20px; border-left: 4px solid #f59e0b; animation: fadeSlideIn 0.5s ease both;">
    <div class="fr-card-body" style="display: flex; align-items: flex-start; gap: 14px; padding: 16px 20px;">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <i class="bi bi-clock-history" style="font-size: 20px; color: #f59e0b;"></i>
        </div>
        <div style="flex: 1; min-width: 0;">
            <div style="font-weight: 700; font-size: 14px; color: var(--color-text-primary); margin-bottom: 2px;">
                Your data hasn't been refreshed in <%= _daysSinceImport %> days
            </div>
            <div style="font-size: 13px; color: var(--color-text-secondary); line-height: 1.5;">
                Keeping your CRM data up to date ensures accurate dashboards and donor insights. Consider importing a fresh export from Raiser's Edge NXT.
            </div>
        </div>
        <button type="button" onclick="document.getElementById('staleDataNudge').style.display='none'" style="background: none; border: none; color: var(--color-text-tertiary); cursor: pointer; padding: 4px; font-size: 16px; flex-shrink: 0; line-height: 1;" title="Dismiss">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
</div>
<style>@keyframes fadeSlideIn{0%{opacity:0;transform:translateY(-8px)}100%{opacity:1;transform:translateY(0)}}</style>
<% } %>
<% } %>

<!-- Upload Form -->
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 4px;">Upload RE NXT Export</div>
        <div class="text-muted" style="font-size: 12px; margin-bottom: 16px;">
            Export your gift data from the NXT Query Editor as an Excel file, then upload it here.
            Existing gifts are updated automatically (upsert by Gift ID).
        </div>

        <form id="crm-upload-form" enctype="multipart/form-data">
            <div style="border: 2px dashed var(--color-border); border-radius: 12px; padding: 32px; text-align: center; cursor: pointer; transition: all 0.2s;" id="drop-zone">
                <div style="font-size: 36px; margin-bottom: 8px;">&#128196;</div>
                <div style="font-weight: 600; margin-bottom: 4px;">Drop your Excel file here or click to browse</div>
                <div class="text-muted" style="font-size: 12px;">.csv, .xlsx, or .xls up to 300 MB</div>
                <input type="file" name="crm_file" id="crm-file" accept=".csv,.xlsx,.xls" style="display:none;">
            </div>

            <div id="file-info" style="display:none; margin-top: 16px; padding: 12px; background: var(--color-background-secondary); border-radius: 8px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <span id="file-name" style="font-weight: 600;"></span>
                        <span id="file-size" class="text-muted" style="font-size: 12px; margin-left: 8px;"></span>
                    </div>
                    <button type="button" id="clear-file" class="fr-btn fr-btn-secondary" style="padding: 4px 12px; font-size: 12px;">Clear</button>
                </div>
            </div>

            <div id="preview-results" style="display:none; margin-top: 16px;"></div>

            <div style="margin-top: 16px; display: flex; gap: 12px;">
                <button type="button" id="preview-btn" class="fr-btn fr-btn-secondary" disabled>Preview Mapping</button>
                <button type="button" id="import-btn" class="fr-btn fr-btn-primary" disabled>Import Data</button>
            </div>
        </form>

        <!-- Progress -->
        <div id="import-progress" style="display:none; margin-top: 16px; padding: 16px; background: var(--color-background-secondary); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <div class="loading-spinner"></div>
                <span id="progress-text" style="font-weight: 600;">Processing...</span>
            </div>
            <div style="background: var(--color-border); border-radius: 4px; height: 8px; overflow: hidden; margin-bottom: 8px;">
                <div id="progress-bar" style="background: var(--color-brand-blue); height: 100%; width: 0%; transition: width 0.5s ease; border-radius: 4px;"></div>
            </div>
            <div id="progress-details" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 4px; font-size: 12px; color: var(--color-text-secondary);">
            </div>
            <div id="import-game-container">
                <%- include('../partials/loading-game') %>
            </div>
        </div>

        <!-- Result -->
        <div id="import-result" style="display:none; margin-top: 16px;"></div>
    </div>
</div>

<!-- Import History -->
<% if (history && history.length > 0) { %>
<div class="fr-card">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Import History</div>
        <table class="fr-table" style="width: 100%; font-size: 13px;">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>File</th>
                    <th>Status</th>
                    <th>Gifts</th>
                    <th>Fundraisers</th>
                    <th>Soft Credits</th>
                    <th>Matches</th>
                </tr>
            </thead>
            <tbody>
                <% history.forEach(imp => { %>
                <tr>
                    <td><%= new Date(imp.uploadedAt).toLocaleString() %></td>
                    <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;"><%= imp.fileName %></td>
                    <td>
                        <span class="fr-badge fr-badge-<%= imp.status === 'completed' ? 'success' : imp.status === 'failed' ? 'danger' : 'warning' %>">
                            <%= imp.status %>
                        </span>
                    </td>
                    <td><%= (imp.giftsUpserted || 0).toLocaleString() %></td>
                    <td><%= (imp.fundraisersUpserted || 0).toLocaleString() %></td>
                    <td><%= (imp.softCreditsUpserted || 0).toLocaleString() %></td>
                    <td><%= (imp.matchesUpserted || 0).toLocaleString() %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Branded confirm modal -->
<div id="frConfirmOverlay" style="position:fixed;inset:0;z-index:10000;background:rgba(26,34,61,0.5);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s ease;">
    <div style="background:#fff;border-radius:16px;padding:32px;max-width:440px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(26,34,61,.3);transform:scale(.95);transition:transform .2s ease;" id="frConfirmCard">
        <div style="width:48px;height:48px;border-radius:50%;background:#eff6ff;color:#3434D6;display:flex;align-items:center;justify-content:center;font-size:22px;margin:0 auto 16px;"><i class="bi bi-question-circle"></i></div>
        <div id="frConfirmTitle" style="font-family:Manrope,sans-serif;font-size:18px;font-weight:700;color:#1A223D;margin-bottom:8px;"></div>
        <div id="frConfirmMessage" style="font-family:Manrope,sans-serif;font-size:14px;color:#6E7180;line-height:1.5;margin-bottom:24px;"></div>
        <div style="display:flex;gap:10px;justify-content:center;">
            <button type="button" id="frConfirmCancel" style="font-family:Manrope,sans-serif;font-size:14px;font-weight:600;background:#fff;color:#1A223D;border:1px solid #d1d5db;border-radius:10px;padding:10px 24px;cursor:pointer;transition:background .15s;">Cancel</button>
            <button type="button" id="frConfirmOk" style="font-family:Manrope,sans-serif;font-size:14px;font-weight:600;background:#3434D6;color:#fff;border:none;border-radius:10px;padding:10px 24px;cursor:pointer;transition:background .15s;">Continue</button>
        </div>
    </div>
</div>

<script>
(function() {
    function frConfirm(message, opts) {
        opts = opts || {};
        var overlay = document.getElementById('frConfirmOverlay');
        var card = document.getElementById('frConfirmCard');
        document.getElementById('frConfirmTitle').textContent = opts.title || 'Confirm';
        document.getElementById('frConfirmMessage').textContent = message;
        document.getElementById('frConfirmOk').textContent = opts.confirmText || 'Continue';
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'auto';
        card.style.transform = 'scale(1)';

        return new Promise(function(resolve) {
            function close(result) {
                overlay.style.opacity = '0';
                overlay.style.pointerEvents = 'none';
                card.style.transform = 'scale(.95)';
                document.getElementById('frConfirmOk').removeEventListener('click', onOk);
                document.getElementById('frConfirmCancel').removeEventListener('click', onCancel);
                resolve(result);
            }
            function onOk() { close(true); }
            function onCancel() { close(false); }
            document.getElementById('frConfirmOk').addEventListener('click', onOk);
            document.getElementById('frConfirmCancel').addEventListener('click', onCancel);
        });
    }

    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('crm-file');
    const fileInfo = document.getElementById('file-info');
    const fileName = document.getElementById('file-name');
    const fileSize = document.getElementById('file-size');
    const clearBtn = document.getElementById('clear-file');
    const previewBtn = document.getElementById('preview-btn');
    const importBtn = document.getElementById('import-btn');
    const previewResults = document.getElementById('preview-results');
    const progressDiv = document.getElementById('import-progress');
    const progressText = document.getElementById('progress-text');
    const resultDiv = document.getElementById('import-result');

    // Drag and drop
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--color-brand-blue)';
        dropZone.style.background = 'var(--color-background-secondary)';
    });
    dropZone.addEventListener('dragleave', () => {
        dropZone.style.borderColor = 'var(--color-border)';
        dropZone.style.background = '';
    });
    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--color-border)';
        dropZone.style.background = '';
        if (e.dataTransfer.files.length) {
            fileInput.files = e.dataTransfer.files;
            showFileInfo(e.dataTransfer.files[0]);
        }
    });

    fileInput.addEventListener('change', () => {
        if (fileInput.files.length) showFileInfo(fileInput.files[0]);
    });

    let previewPassed = false;

    function showFileInfo(file) {
        fileName.textContent = file.name;
        fileSize.textContent = formatBytes(file.size);
        fileInfo.style.display = 'block';
        dropZone.style.display = 'none';
        previewBtn.disabled = false;
        importBtn.disabled = true;
        previewPassed = false;
        previewResults.style.display = 'none';
        resultDiv.style.display = 'none';

        // Auto-trigger preview
        setTimeout(() => previewBtn.click(), 100);
    }

    clearBtn.addEventListener('click', () => {
        fileInput.value = '';
        fileInfo.style.display = 'none';
        dropZone.style.display = '';
        previewBtn.disabled = true;
        importBtn.disabled = true;
        previewPassed = false;
        previewResults.style.display = 'none';
        resultDiv.style.display = 'none';
    });

    previewBtn.addEventListener('click', async () => {
        if (!fileInput.files.length) return;
        previewBtn.disabled = true;
        previewBtn.textContent = 'Analyzing...';

        const formData = new FormData();
        formData.append('crm_file', fileInput.files[0]);

        try {
            const res = await fetch('/crm-upload/preview', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.error) {
                previewResults.innerHTML = '<div style="color: var(--color-danger);">' + data.error + '</div>';
            } else {
                var html = '';

                // Mapped columns summary card
                html += '<div style="padding: 16px; background: var(--color-background-secondary); border-radius: 12px; margin-bottom: 12px;">';
                html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">';
                html += '<i class="bi bi-check-circle-fill" style="color:var(--color-brand-blue);font-size:18px;"></i>';
                html += '<span style="font-weight:700;font-size:15px;">Column Mapping</span>';
                html += '<span style="margin-left:auto;font-size:12px;font-weight:600;padding:3px 10px;border-radius:12px;background:var(--color-brand-blue);color:#fff;">' + data.mappedColumns + '/' + data.totalColumns + ' mapped</span>';
                html += '</div>';
                html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:6px;font-size:13px;">';
                var catIcons = { gift:'bi-gift',fund:'bi-bank',campaign:'bi-megaphone',appeal:'bi-envelope-open',fundraiser:'bi-person-badge',softCredit:'bi-arrow-left-right',match:'bi-arrow-repeat' };
                for (var cat in data.categories) {
                    var count = data.categories[cat];
                    var label = cat.replace(/([A-Z])/g, ' $1').replace(/^./, function(c) { return c.toUpperCase(); });
                    var icon = catIcons[cat] || 'bi-tag';
                    var clr = count > 0 ? 'var(--color-brand-blue)' : 'var(--color-text-tertiary)';
                    html += '<div style="display:flex;align-items:center;gap:6px;padding:6px 10px;border-radius:8px;background:#fff;border:1px solid var(--color-border-primary);">';
                    html += '<i class="bi ' + icon + '" style="color:' + clr + ';font-size:14px;"></i>';
                    html += '<span style="color:' + (count > 0 ? 'var(--color-text-primary)' : 'var(--color-text-tertiary)') + ';">' + label + '</span>';
                    html += '<strong style="margin-left:auto;color:' + clr + ';">' + count + '</strong></div>';
                }
                html += '</div>';
                if (data.unmappedColumns.length > 0) {
                    html += '<div style="font-size:11px;color:var(--color-text-tertiary);margin-top:8px;">Unmapped: ' + data.unmappedColumns.map(function(c) { return '<code style="font-size:10px;padding:1px 4px;border-radius:3px;background:#fff;border:1px solid var(--color-border-primary);">' + c + '</code>'; }).join(' ') + '</div>';
                }
                // Validation warnings
                var canImport = true;
                if (!data.hasGiftId) {
                    html += '<div style="display:flex;align-items:center;gap:8px;margin-top:10px;padding:10px 14px;border-radius:8px;background:rgba(220,53,69,0.08);border:1px solid rgba(220,53,69,0.2);">';
                    html += '<i class="bi bi-exclamation-triangle-fill" style="color:var(--color-danger);"></i>';
                    html += '<span style="font-weight:600;font-size:13px;color:var(--color-danger);">Missing required "Gift ID" column</span></div>';
                    canImport = false;
                }
                if (data.mappedColumns === 0) {
                    html += '<div style="display:flex;align-items:center;gap:8px;margin-top:10px;padding:10px 14px;border-radius:8px;background:rgba(220,53,69,0.08);border:1px solid rgba(220,53,69,0.2);">';
                    html += '<i class="bi bi-exclamation-triangle-fill" style="color:var(--color-danger);"></i>';
                    html += '<span style="font-weight:600;font-size:13px;color:var(--color-danger);">No columns could be mapped. Please check that your export contains recognized RE NXT headers.</span></div>';
                    canImport = false;
                }
                importBtn.disabled = !canImport;
                previewPassed = canImport;
                html += '</div>';

                // Recommendations card (only if there are suggestions)
                if (data.recommendations && data.recommendations.length > 0) {
                    html += '<div style="border:1px solid var(--color-border-primary);border-radius:12px;overflow:hidden;">';
                    html += '<div style="padding:14px 16px;background:linear-gradient(135deg,#1A223D 0%,#252D4A 100%);display:flex;align-items:center;gap:10px;">';
                    html += '<i class="bi bi-lightbulb" style="color:#FFAA00;font-size:18px;"></i>';
                    html += '<div><div style="font-weight:700;font-size:14px;color:#fff;">Enhance Your Import</div>';
                    html += '<div style="font-size:11px;color:rgba(255,255,255,0.65);">Add these fields to your RE NXT query for richer analytics</div></div></div>';
                    html += '<div style="padding:4px 0;">';
                    data.recommendations.forEach(function(rec) {
                        html += '<div style="display:flex;align-items:flex-start;gap:12px;padding:12px 16px;border-bottom:1px solid var(--color-border-primary);">';
                        html += '<div style="width:32px;height:32px;border-radius:8px;background:var(--color-background-secondary);display:flex;align-items:center;justify-content:center;flex-shrink:0;">';
                        html += '<i class="bi bi-' + rec.icon + '" style="color:var(--color-brand-blue);font-size:15px;"></i></div>';
                        html += '<div style="flex:1;min-width:0;">';
                        html += '<div style="font-weight:600;font-size:13px;color:var(--color-text-primary);">' + rec.label + '</div>';
                        html += '<div style="font-size:12px;color:var(--color-text-secondary);margin-top:1px;">' + rec.desc + '</div>';
                        html += '<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;">';
                        rec.fields.forEach(function(f) {
                            html += '<code style="font-size:10px;padding:2px 6px;border-radius:4px;background:var(--color-background-secondary);color:var(--color-text-secondary);white-space:nowrap;">' + f + '</code>';
                        });
                        html += '</div></div>';
                        html += '<button type="button" class="copy-rec-fields" data-fields="' + rec.fields.join('\\n') + '" style="flex-shrink:0;padding:4px 10px;border:1px solid var(--color-border-primary);border-radius:6px;background:#fff;font-size:11px;font-weight:500;cursor:pointer;color:var(--color-text-secondary);white-space:nowrap;" title="Copy field names">';
                        html += '<i class="bi bi-clipboard"></i></button></div>';
                    });
                    html += '</div></div>';
                }

                previewResults.innerHTML = html;

                // Wire up copy buttons for recommendations
                previewResults.querySelectorAll('.copy-rec-fields').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        var fields = this.getAttribute('data-fields').replace(/\\n/g, '\n');
                        navigator.clipboard.writeText(fields).then(function() {
                            btn.innerHTML = '<i class="bi bi-check-lg" style="color:var(--color-brand-blue);"></i>';
                            setTimeout(function() { btn.innerHTML = '<i class="bi bi-clipboard"></i>'; }, 1500);
                        });
                    });
                });
            }
            previewResults.style.display = 'block';
        } catch (err) {
            previewResults.innerHTML = '<div style="color: var(--color-danger);">Error: ' + err.message + '</div>';
            previewResults.style.display = 'block';
        }
        previewBtn.disabled = false;
        previewBtn.textContent = 'Preview Mapping';
    });

    importBtn.addEventListener('click', async () => {
        if (!fileInput.files.length) return;
        var confirmed = await frConfirm('This will import and update all gifts in the file. Existing records with matching Gift IDs will be updated.', { title: 'Start Import?', confirmText: 'Import Data' });
        if (!confirmed) return;

        importBtn.disabled = true;
        previewBtn.disabled = true;
        progressDiv.style.display = 'block';
        progressText.textContent = 'Uploading file...';
        resultDiv.style.display = 'none';

        const formData = new FormData();
        formData.append('crm_file', fileInput.files[0]);

        try {
            const res = await fetch('/crm-upload/process', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.error) {
                progressDiv.style.display = 'none';
                resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(220,53,69,0.1); border-radius: 8px; color: var(--color-danger);"><strong>Import Failed</strong><br>' + data.error + '</div>';
                resultDiv.style.display = 'block';
                importBtn.disabled = false;
                previewBtn.disabled = false;
                return;
            }

            // Import is running in background — poll for status
            progressText.textContent = 'Import in progress... Processing gifts in batches.';
            if (data.importId) {
                localStorage.setItem('fr_active_import', JSON.stringify({ id: data.importId, startedAt: Date.now() }));
                pollImportStatus(data.importId);
            } else {
                progressText.textContent = 'Import started but could not get import ID. Refresh the page in a few minutes.';
            }
        } catch (err) {
            progressDiv.style.display = 'none';
            resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(220,53,69,0.1); border-radius: 8px; color: var(--color-danger);">Upload error: ' + err.message + '</div>';
            resultDiv.style.display = 'block';
            importBtn.disabled = false;
            previewBtn.disabled = false;
        }
    });

    function pollImportStatus(importId) {
        const progressBar = document.getElementById('progress-bar');
        const progressDetails = document.getElementById('progress-details');
        let startTime = Date.now();
        let maxPollMs = 10 * 60 * 1000; // 10 minutes
        let networkErrors = 0;
        let maxNetworkErrors = 10;

        const poll = setInterval(async () => {
            // Check if polling has exceeded max duration
            if (Date.now() - startTime > maxPollMs) {
                clearInterval(poll);
                localStorage.removeItem('fr_active_import');
                if (window._lgGameStop) window._lgGameStop();
                progressDiv.style.display = 'none';
                resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(245,158,11,0.1); border-radius: 8px;">' +
                    '<div style="font-weight: 700; color: #b45309; margin-bottom: 8px;"><i class="bi bi-clock-history"></i> Taking Longer Than Expected</div>' +
                    '<div style="font-size: 13px; color: var(--color-text-secondary); margin-bottom: 12px;">Your import is still running in the background, but it\'s taking longer than usual.</div>' +
                    '<button onclick="location.reload()" class="fr-btn fr-btn-primary" style="font-size: 13px; padding: 8px 20px;">Refresh & Check</button></div>';
                resultDiv.style.display = 'block';
                return;
            }

            try {
                const res = await fetch('/crm-upload/status/' + importId);
                const data = await res.json();
                networkErrors = 0; // Reset on success

                if (data.status === 'processing') {
                    const gifts = data.giftsUpserted || 0;
                    const elapsed = Math.round((Date.now() - startTime) / 1000);
                    const rate = elapsed > 0 ? Math.round(gifts / elapsed) : 0;

                    progressText.textContent = 'Importing... ' + gifts.toLocaleString() + ' gifts processed';

                    // Estimate progress (we don't know total upfront, so use a log curve)
                    const estPct = Math.min(95, Math.round((gifts / Math.max(gifts + 1000, 10000)) * 100));
                    progressBar.style.width = estPct + '%';

                    let details = '';
                    details += '<div>Gifts: <strong>' + gifts.toLocaleString() + '</strong></div>';
                    details += '<div>Fundraisers: <strong>' + (data.fundraisersUpserted || 0).toLocaleString() + '</strong></div>';
                    details += '<div>Soft Credits: <strong>' + (data.softCreditsUpserted || 0).toLocaleString() + '</strong></div>';
                    details += '<div>Matches: <strong>' + (data.matchesUpserted || 0).toLocaleString() + '</strong></div>';
                    if (rate > 0) {
                        details += '<div>Rate: ~' + rate + ' gifts/sec</div>';
                        details += '<div>Elapsed: ' + Math.floor(elapsed / 60) + 'm ' + (elapsed % 60) + 's</div>';
                    }
                    progressDetails.innerHTML = details;
                    return;
                }

                clearInterval(poll);
                localStorage.removeItem('fr_active_import');
                if (window._lgGameStop) window._lgGameStop();
                progressDiv.style.display = 'none';

                if (data.status === 'completed') {
                    let html = '<div style="padding: 16px; background: rgba(40,167,69,0.1); border-radius: 8px;">';
                    html += '<div style="font-weight: 700; color: var(--color-success); margin-bottom: 8px;">Import Successful</div>';
                    html += '<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; font-size: 13px;">';
                    html += '<div>Total rows: <strong>' + (data.totalRows || 0).toLocaleString() + '</strong></div>';
                    html += '<div>Gifts upserted: <strong>' + (data.giftsUpserted || 0).toLocaleString() + '</strong></div>';
                    html += '<div>Fundraiser links: <strong>' + (data.fundraisersUpserted || 0).toLocaleString() + '</strong></div>';
                    html += '<div>Soft credits: <strong>' + (data.softCreditsUpserted || 0).toLocaleString() + '</strong></div>';
                    html += '<div>Matching gifts: <strong>' + (data.matchesUpserted || 0).toLocaleString() + '</strong></div>';
                    html += '</div></div>';
                    resultDiv.innerHTML = html;
                    resultDiv.style.display = 'block';
                    setTimeout(() => location.reload(), 3000);
                } else {
                    resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(220,53,69,0.1); border-radius: 8px; color: var(--color-danger);"><strong>Import Failed</strong><br>' + (data.errorMessage || 'Unknown error') + '</div>';
                    resultDiv.style.display = 'block';
                    importBtn.disabled = false;
                    previewBtn.disabled = false;
                }
            } catch (err) {
                networkErrors++;
                if (networkErrors >= maxNetworkErrors) {
                    clearInterval(poll);
                    localStorage.removeItem('fr_active_import');
                    if (window._lgGameStop) window._lgGameStop();
                    progressDiv.style.display = 'none';
                    resultDiv.innerHTML = '<div style="padding: 16px; background: rgba(220,53,69,0.1); border-radius: 8px;">' +
                        '<div style="font-weight: 700; color: var(--color-danger); margin-bottom: 8px;"><i class="bi bi-wifi-off"></i> Connection Lost</div>' +
                        '<div style="font-size: 13px; color: var(--color-text-secondary); margin-bottom: 12px;">We lost connection to the server. Your import may still be running in the background.</div>' +
                        '<button onclick="location.reload()" class="fr-btn fr-btn-primary" style="font-size: 13px; padding: 8px 20px;">Refresh Page</button></div>';
                    resultDiv.style.display = 'block';
                }
            }
        }, 3000);
    }

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
    }

    // Auto-resume polling if page was refreshed during an active import
    (function resumeActiveImport() {
        try {
            var stored = localStorage.getItem('fr_active_import');
            if (!stored) return;
            var active = JSON.parse(stored);
            // Only resume if started within the last 15 minutes
            if (!active.id || Date.now() - active.startedAt > 15 * 60 * 1000) {
                localStorage.removeItem('fr_active_import');
                return;
            }
            // Show progress UI and start polling
            dropZone.style.display = 'none';
            importBtn.disabled = true;
            previewBtn.disabled = true;
            progressDiv.style.display = 'block';
            progressText.textContent = 'Reconnecting to import in progress...';
            pollImportStatus(active.id);
        } catch (_) {}
    })();
})();
</script>


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>What's New — Fund-Raise</title>
    <meta name="description" content="See the latest features, improvements, and updates to Fund-Raise — fundraising intelligence for nonprofits.">
    <link rel="icon" type="image/svg+xml" href="/images/fund-raise-icon-flat.svg">
    <link href="/css/landing.css" rel="stylesheet">
    <style>
    :root{--banner-h:0px}
    .wn-hero{padding:calc(80px + var(--banner-h, 0px)) 0 60px;background:linear-gradient(135deg,#0a1628 0%,#1A223D 50%,#3434D6 100%);color:#fff;text-align:center}
    .wn-hero h1{font-size:clamp(28px,5vw,44px);font-weight:800;margin:0 0 12px;letter-spacing:-0.5px}
    .wn-hero p{font-size:clamp(14px,2vw,18px);opacity:.8;max-width:540px;margin:0 auto}
    .wn-container{max-width:800px;margin:0 auto;padding:40px 20px 80px}
    .wn-year-label{font-size:13px;font-weight:700;color:var(--fr-blue,#3434D6);text-transform:uppercase;letter-spacing:1.5px;margin:40px 0 20px;padding-bottom:8px;border-bottom:2px solid #e5e7eb}
    .wn-article{position:relative;padding:28px 0;border-bottom:1px solid #f0f0f0;transition:background .2s}
    .wn-article:last-child{border-bottom:none}
    .wn-date{font-size:12px;font-weight:600;color:#6b7280;margin-bottom:6px;display:flex;align-items:center;gap:6px}
    .wn-date i{font-size:14px}
    .wn-tag{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;margin-left:8px}
    .wn-tag-ai{background:#f0e6ff;color:#7c3aed}
    .wn-tag-analytics{background:#E8F4FC;color:#3434D6}
    .wn-tag-team{background:#EAF3DE;color:#16a34a}
    .wn-tag-writing{background:#FFF6E0;color:#d97706}
    .wn-tag-admin{background:#f3f4f6;color:#374151}
    .wn-tag-planning{background:#FCEBEB;color:#dc2626}
    .wn-tag-integration{background:#E8F4FC;color:#1A223D}
    .wn-tag-new{background:linear-gradient(135deg,#FFAA00,#FFD700);color:#7c4a00}
    .wn-title{font-size:20px;font-weight:700;color:#1a1a1a;margin:0 0 8px;line-height:1.3}
    .wn-body{font-size:14px;line-height:1.7;color:#4b5563}
    .wn-body p{margin:0 0 10px}
    .wn-body p:last-child{margin:0}
    .wn-body ul{margin:8px 0;padding-left:20px}
    .wn-body li{margin-bottom:4px}
    .wn-highlight{background:#f8fafc;border-left:3px solid #3434D6;padding:12px 16px;border-radius:0 8px 8px 0;margin:12px 0;font-size:13px}
    .wn-back{display:inline-flex;align-items:center;gap:6px;color:#3434D6;font-size:13px;font-weight:500;text-decoration:none;margin-bottom:40px}
    .wn-back:hover{text-decoration:underline}
    @media(max-width:600px){.wn-hero{padding:calc(70px + var(--banner-h, 0px)) 0 40px}.wn-title{font-size:17px}.wn-body{font-size:13px}.wn-container{padding:24px 16px 60px}}
    </style>
</head>
<body class="landing-page">


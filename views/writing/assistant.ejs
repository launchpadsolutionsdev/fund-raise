<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">Writing Assistant</div>
        <div class="page-subtitle">AI-powered help for donor-facing communications</div>
    </div>
</div>

<style>
/* ── Writing Assistant Hero ── */
.wa-hero {
    margin: 0 0 28px;
    background: linear-gradient(135deg, var(--fr-navy) 0%, #252d4a 100%);
    border-radius: 16px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    gap: 36px;
    color: #fff;
    box-shadow: 0 4px 24px rgba(26, 34, 61, 0.18);
}
.wa-hero-icon {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--fr-blue-start), var(--fr-blue-end));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: #fff;
    box-shadow: 0 4px 16px rgba(25, 96, 249, 0.35);
}
.wa-hero-text h2 {
    margin: 0 0 6px;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.3px;
}
.wa-hero-text p {
    margin: 0 0 16px;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
}
.wa-hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.wa-hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
}
.wa-hero-chip i { color: var(--fr-cyan-start); font-size: 12px; }

/* ── Page layout ── */
.wa-page-wrap {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 120px);
}
.wa-hero { flex-shrink: 0; }

/* ── Elevated panels ── */
.wa-workspace {
    display: grid;
    grid-template-columns: minmax(340px, 380px) 1fr;
    gap: 20px;
    align-items: stretch;
    flex: 1;
    min-height: 0;
}
.wa-input-panel {
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-primary);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.wa-input-panel .wa-section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--color-text-tertiary);
    margin-bottom: 14px;
}
.wa-input-panel .wa-section-label i { font-size: 13px; color: var(--color-brand-blue); }

.wa-input-panel {
    overflow-y: auto;
}
.wa-output-card {
    background: var(--color-background-primary);
    border: 1px solid var(--color-border-primary);
    border-radius: 16px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    overflow: hidden;
}
.wa-output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border-primary);
    background: var(--color-background-secondary);
}
.wa-output-header-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
}
.wa-output-header-title i { color: var(--color-brand-blue); }
.wa-output-body {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    min-height: 0;
}
.wa-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 30px;
    text-align: center;
}
.wa-empty-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-background-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: var(--color-text-tertiary);
    margin-bottom: 16px;
}
.wa-empty-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 6px;
}
.wa-empty-desc {
    font-size: 12px;
    color: var(--color-text-tertiary);
    line-height: 1.6;
    max-width: 260px;
}

/* Responsive */
@media (max-width: 840px) {
    .wa-hero { flex-direction: column; text-align: center; padding: 28px 24px; }
    .wa-hero-chips { justify-content: center; }
    .wa-workspace { grid-template-columns: 1fr; }
}
</style>

<!-- Page Wrap -->
<div class="wa-page-wrap">

<!-- Hero Card -->
<div class="wa-hero">
    <div class="wa-hero-icon"><i class="bi bi-pencil-square"></i></div>
    <div class="wa-hero-text">
        <h2>Craft Perfect Communications</h2>
        <p>Draft, polish, or reply to donor-facing messages with AI that understands nonprofit fundraising language, tone, and best practices.</p>
        <div class="wa-hero-chips">
            <span class="wa-hero-chip"><i class="bi bi-check-circle-fill"></i> Thank-You Letters</span>
            <span class="wa-hero-chip"><i class="bi bi-check-circle-fill"></i> Donor Emails</span>
            <span class="wa-hero-chip"><i class="bi bi-check-circle-fill"></i> Event Invitations</span>
            <span class="wa-hero-chip"><i class="bi bi-check-circle-fill"></i> Sympathy Cards</span>
            <span class="wa-hero-chip"><i class="bi bi-check-circle-fill"></i> Follow-Ups</span>
        </div>
    </div>
</div>

<!-- Workspace -->
<div class="wa-workspace">
    <!-- Input Panel -->
    <div class="wa-input-panel">
        <div class="wa-section-label"><i class="bi bi-sliders"></i> Configuration</div>

        <!-- Quick Start template rail (mounted by WritingExtras.init) -->
        <div class="we-template-wrap" id="weTemplateWrap">
            <div class="we-template-label">
                <span><i class="bi bi-lightning-charge-fill"></i> Quick start</span>
            </div>
            <div id="weTemplateRail"></div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Writing Mode</div>
            <div class="writing-options" id="modeOptions">
                <button class="writing-option active" data-val="Draft from scratch">Draft from scratch</button>
                <button class="writing-option" data-val="Polish/edit my draft">Polish my draft</button>
                <button class="writing-option" data-val="Reply to a message">Reply to a message</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Content Type</div>
            <div class="writing-options" id="typeOptions">
                <button class="writing-option active" data-val="Thank you letter">Thank you letter</button>
                <button class="writing-option" data-val="Sympathy/condolence card">Sympathy card</button>
                <button class="writing-option" data-val="Donor email">Donor email</button>
                <button class="writing-option" data-val="Event invitation">Event invitation</button>
                <button class="writing-option" data-val="Follow-up email">Follow-up email</button>
                <button class="writing-option" data-val="General correspondence">General</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Tone</div>
            <div class="writing-options" id="toneOptions">
                <button class="writing-option active" data-val="Warm & personal">Warm & personal</button>
                <button class="writing-option" data-val="Professional & formal">Professional & formal</button>
                <button class="writing-option" data-val="Celebratory">Celebratory</button>
                <button class="writing-option" data-val="Empathetic">Empathetic</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label" id="contextLabel">Context / Notes</div>
            <textarea class="form-input form-textarea" id="contextInput" rows="8"
                placeholder="Describe what you want to write, or paste your draft/message to reply to..."></textarea>
            <div class="form-hint">The more context you provide, the better the result</div>
        </div>

        <button class="btn-brand" id="generateBtn" style="width:100%;">
            <i class="bi bi-stars"></i> Generate
        </button>
    </div>

    <!-- Output Panel -->
    <div class="wa-output-card">
        <div class="wa-output-header" style="position:relative;">
            <span class="wa-output-header-title"><i class="bi bi-file-earmark-text"></i> Output</span>
            <div style="display:flex;gap:6px;align-items:center;">
                <!-- Feedback toolbar mounted by WritingExtras (rate / save / regen) -->
                <div id="weFeedbackMount"></div>
                <button class="chat-msg-action-btn" id="copyBtn" title="Copy to clipboard" style="display:none;">
                    <i class="bi bi-clipboard"></i> Copy
                </button>
                <button class="chat-msg-action-btn" id="clearBtn" title="Clear output" style="display:none;">
                    <i class="bi bi-x-lg"></i> Clear
                </button>
                <button class="chat-msg-action-btn" id="historyBtn" title="Your past writing"><i class="bi bi-clock-history"></i> History</button>
            </div>
        </div>
        <div class="wa-output-body" id="outputBody">
            <div class="wa-empty-state">
                <div class="wa-empty-icon"><i class="bi bi-pencil-square"></i></div>
                <div class="wa-empty-title">Your generated content will appear here</div>
                <div class="wa-empty-desc">Configure your writing mode, content type, and tone on the left, then click Generate</div>
            </div>
        </div>
    </div>
</div>

</div><!-- /wa-page-wrap -->

<!-- History drawer mount (rendered by WritingExtras) -->
<div id="weHistoryMount"></div>

<link rel="stylesheet" href="/css/writing-extras.css">
<script src="/js/writing-extras.js"></script>

<%- include('../partials/renderMarkdown') %>
<script>
(function() {
    const generateBtn = document.getElementById('generateBtn');
    const contextInput = document.getElementById('contextInput');
    const contextLabel = document.getElementById('contextLabel');
    const outputBody = document.getElementById('outputBody');
    const copyBtn = document.getElementById('copyBtn');
    const clearBtn = document.getElementById('clearBtn');

    let selectedMode = 'Draft from scratch';
    let selectedType = 'Thank you letter';
    let selectedTone = 'Warm & personal';
    let generatedText = '';

    function setupOptions(containerId, setter) {
        const container = document.getElementById(containerId);
        container.addEventListener('click', function(e) {
            const btn = e.target.closest('.writing-option');
            if (!btn) return;
            container.querySelectorAll('.writing-option').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            setter(btn.dataset.val);
        });
    }

    setupOptions('modeOptions', function(val) {
        selectedMode = val;
        if (val === 'Polish/edit my draft') {
            contextLabel.textContent = 'Your Draft';
            contextInput.placeholder = 'Paste your draft here and I\'ll polish it...';
        } else if (val === 'Reply to a message') {
            contextLabel.textContent = 'Message to Reply To';
            contextInput.placeholder = 'Paste the message you received here...';
        } else {
            contextLabel.textContent = 'Context / Notes';
            contextInput.placeholder = 'Describe what you want to write, or paste your draft/message to reply to...';
        }
    });
    setupOptions('typeOptions', function(val) { selectedType = val; });
    setupOptions('toneOptions', function(val) { selectedTone = val; });

    // ── WritingExtras: templates + feedback + history ────────────────────
    // Apply a template by simulating clicks on the existing pill rows.
    function pickPill(containerId, value) {
        if (!value) return;
        var btn = document.querySelector('#' + containerId + ' .writing-option[data-val="' + value.replace(/"/g, '\\"') + '"]');
        if (btn) btn.click();
    }
    var extras = WritingExtras.init({
        feature: 'writing',
        accentColor: '#1A223D',
        featureLabel: 'Your Writing Library',
        templateRailEl: document.getElementById('weTemplateRail'),
        feedbackMountEl: document.getElementById('weFeedbackMount'),
        historyMountEl: document.getElementById('weHistoryMount'),
        generateBtn: generateBtn,
        outputBody: outputBody,
        applyTemplate: function(params) {
            pickPill('modeOptions', params.mode);
            pickPill('typeOptions', params.contentType);
            pickPill('toneOptions', params.tone);
            if (typeof params.context === 'string' && !contextInput.value.trim()) {
                contextInput.value = params.context;
            }
        },
        restoreItem: function(item) {
            // Restore the form state and the output panel from a saved row.
            var p = item.params || {};
            pickPill('modeOptions', p.mode);
            pickPill('typeOptions', p.contentType);
            pickPill('toneOptions', p.tone);
            if (typeof p.context === 'string') contextInput.value = p.context;
            generatedText = item.generatedText || '';
            outputBody.innerHTML = '<div class="writing-rendered" id="outputRendered"></div>';
            document.getElementById('outputRendered').innerHTML = renderMarkdown(generatedText);
            copyBtn.style.display = 'inline-flex';
            clearBtn.style.display = 'inline-flex';
        },
    });
    document.getElementById('historyBtn').addEventListener('click', function() { extras.openHistory(); });
    // Manual edits to the form clear the active-template highlight.
    ['modeOptions', 'typeOptions', 'toneOptions'].forEach(function(id) {
        document.getElementById(id).addEventListener('click', function() { extras.clearActiveTemplate(); });
    });
    contextInput.addEventListener('input', function() { extras.clearActiveTemplate(); });

    var lastOutputId = null;

    generateBtn.addEventListener('click', function() {
        const context = contextInput.value.trim();
        if (!context) { frAlert('Please provide context or your draft.', { variant: 'warning', title: 'Required' }); return; }

        generateBtn.disabled = true;
        generateBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating...';
        generatedText = '';
        lastOutputId = null;
        copyBtn.style.display = 'none';
        clearBtn.style.display = 'none';
        extras.onGenerationStart();

        outputBody.innerHTML = '<div class="writing-rendered" id="outputRendered"></div>';
        const outputEl = document.getElementById('outputRendered');

        fetch('/api/writing-assistant/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                mode: selectedMode,
                contentType: selectedType,
                tone: selectedTone,
                context: context,
            }),
        })
        .then(response => {
            if (!response.ok) throw new Error('Request failed');
            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';

            function read() {
                return reader.read().then(({ done, value }) => {
                    if (done) { finalize(); return; }
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();
                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            try {
                                const data = JSON.parse(line.substring(6));
                                if (data.text) { generatedText += data.text; outputEl.innerHTML = renderMarkdown(generatedText); outputBody.scrollTop = outputBody.scrollHeight; }
                                if (data.done) {
                                    if (data.outputId) lastOutputId = data.outputId;
                                    finalize();
                                    return;
                                }
                                if (data.error) { outputEl.innerHTML = '<p style="color:var(--color-text-danger);">Error: ' + data.error + '</p>'; }
                            } catch (e) {}
                        }
                    }
                    return read();
                });
            }
            return read();
        })
        .catch(err => {
            outputBody.innerHTML = '<div style="padding:20px;color:var(--color-text-danger);font-size:13px;">Failed to generate. Please check your API key and try again.</div>';
        })
        .finally(() => {
            generateBtn.disabled = false;
            generateBtn.innerHTML = '<i class="bi bi-stars"></i> Generate';
        });
    });

    function finalize() {
        var el = document.getElementById('outputRendered');
        if (el) el.innerHTML = renderMarkdown(generatedText);
        copyBtn.style.display = 'inline-flex';
        clearBtn.style.display = 'inline-flex';
        if (lastOutputId) extras.onGenerationDone(lastOutputId);
    }

    copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(generatedText).then(() => {
            copyBtn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
            setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard"></i> Copy'; }, 1500);
        });
    });

    clearBtn.addEventListener('click', function() {
        generatedText = '';
        copyBtn.style.display = 'none';
        clearBtn.style.display = 'none';
        outputBody.innerHTML =
            '<div class="wa-empty-state">' +
                '<div class="wa-empty-icon"><i class="bi bi-pencil-square"></i></div>' +
                '<div class="wa-empty-title">Your generated content will appear here</div>' +
                '<div class="wa-empty-desc">Configure your writing mode, content type, and tone on the left, then click Generate</div>' +
            '</div>';
    });
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

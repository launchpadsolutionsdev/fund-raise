<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting"><i class="bi bi-pencil-square"></i> Writing Assistant</div>
        <div class="page-subtitle">AI-powered help for donor-facing communications</div>
    </div>
</div>

<div class="writing-layout">
    <!-- Input panel -->
    <div class="writing-panel">
        <div class="writing-option-group">
            <div class="writing-option-label">Writing Mode</div>
            <div class="writing-options" id="modeOptions">
                <button class="writing-option active" data-val="Draft from scratch">Draft from scratch</button>
                <button class="writing-option" data-val="Polish/edit my draft">Polish my draft</button>
                <button class="writing-option" data-val="Reply to a message">Reply to a message</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Content Type</div>
            <div class="writing-options" id="typeOptions">
                <button class="writing-option active" data-val="Thank you letter">Thank you letter</button>
                <button class="writing-option" data-val="Sympathy/condolence card">Sympathy card</button>
                <button class="writing-option" data-val="Donor email">Donor email</button>
                <button class="writing-option" data-val="Event invitation">Event invitation</button>
                <button class="writing-option" data-val="Follow-up email">Follow-up email</button>
                <button class="writing-option" data-val="General correspondence">General</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label">Tone</div>
            <div class="writing-options" id="toneOptions">
                <button class="writing-option active" data-val="Warm & personal">Warm & personal</button>
                <button class="writing-option" data-val="Professional & formal">Professional & formal</button>
                <button class="writing-option" data-val="Celebratory">Celebratory</button>
                <button class="writing-option" data-val="Empathetic">Empathetic</button>
            </div>
        </div>

        <div class="writing-option-group">
            <div class="writing-option-label" id="contextLabel">Context / Notes</div>
            <textarea class="form-input form-textarea" id="contextInput" rows="8"
                placeholder="Describe what you want to write, or paste your draft/message to reply to..."></textarea>
            <div class="form-hint">The more context you provide, the better the result</div>
        </div>

        <button class="btn-brand" id="generateBtn" style="width:100%;">
            <i class="bi bi-stars"></i> Generate
        </button>
    </div>

    <!-- Output panel -->
    <div class="writing-output-panel">
        <div class="writing-output-header">
            <span class="writing-output-title">Output</span>
            <div style="display:flex;gap:6px;">
                <button class="chat-msg-action-btn" id="copyBtn" title="Copy to clipboard" style="display:none;">
                    <i class="bi bi-clipboard"></i> Copy
                </button>
                <button class="chat-msg-action-btn" id="clearBtn" title="Clear output" style="display:none;">
                    <i class="bi bi-x-lg"></i> Clear
                </button>
            </div>
        </div>
        <div class="writing-output-body" id="outputBody">
            <div class="writing-output-empty">
                <i class="bi bi-pencil-square"></i>
                <div style="font-size:13px;font-weight:500;margin-bottom:4px;">Your generated content will appear here</div>
                <div style="font-size:12px;">Fill in the options on the left and click Generate</div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const generateBtn = document.getElementById('generateBtn');
    const contextInput = document.getElementById('contextInput');
    const contextLabel = document.getElementById('contextLabel');
    const outputBody = document.getElementById('outputBody');
    const copyBtn = document.getElementById('copyBtn');
    const clearBtn = document.getElementById('clearBtn');

    let selectedMode = 'Draft from scratch';
    let selectedType = 'Thank you letter';
    let selectedTone = 'Warm & personal';
    let generatedText = '';

    // Option selectors
    function setupOptions(containerId, setter) {
        const container = document.getElementById(containerId);
        container.addEventListener('click', function(e) {
            const btn = e.target.closest('.writing-option');
            if (!btn) return;
            container.querySelectorAll('.writing-option').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            setter(btn.dataset.val);
        });
    }

    setupOptions('modeOptions', function(val) {
        selectedMode = val;
        // Update context label based on mode
        if (val === 'Polish/edit my draft') {
            contextLabel.textContent = 'Your Draft';
            contextInput.placeholder = 'Paste your draft here and I\'ll polish it...';
        } else if (val === 'Reply to a message') {
            contextLabel.textContent = 'Message to Reply To';
            contextInput.placeholder = 'Paste the message you received here...';
        } else {
            contextLabel.textContent = 'Context / Notes';
            contextInput.placeholder = 'Describe what you want to write, or paste your draft/message to reply to...';
        }
    });
    setupOptions('typeOptions', function(val) { selectedType = val; });
    setupOptions('toneOptions', function(val) { selectedTone = val; });

    // Generate
    generateBtn.addEventListener('click', function() {
        const context = contextInput.value.trim();
        if (!context) return alert('Please provide context or your draft.');

        generateBtn.disabled = true;
        generateBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating...';
        generatedText = '';
        copyBtn.style.display = 'none';
        clearBtn.style.display = 'none';

        // Show streaming output
        outputBody.innerHTML = '<textarea class="writing-output-text" id="outputText" readonly placeholder="Generating..."></textarea>';
        const outputText = document.getElementById('outputText');

        fetch('/api/writing-assistant/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                mode: selectedMode,
                contentType: selectedType,
                tone: selectedTone,
                context: context,
            }),
        })
        .then(response => {
            if (!response.ok) throw new Error('Request failed');

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';

            function read() {
                return reader.read().then(({ done, value }) => {
                    if (done) {
                        finalize();
                        return;
                    }

                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();

                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            try {
                                const data = JSON.parse(line.substring(6));
                                if (data.text) {
                                    generatedText += data.text;
                                    outputText.value = generatedText;
                                    outputText.scrollTop = outputText.scrollHeight;
                                }
                                if (data.done) {
                                    finalize();
                                    return;
                                }
                                if (data.error) {
                                    outputText.value = 'Error: ' + data.error;
                                }
                            } catch (e) {}
                        }
                    }

                    return read();
                });
            }

            return read();
        })
        .catch(err => {
            outputBody.innerHTML = '<div style="padding:20px;color:var(--color-text-danger);font-size:13px;">Failed to generate. Please check your API key and try again.</div>';
        })
        .finally(() => {
            generateBtn.disabled = false;
            generateBtn.innerHTML = '<i class="bi bi-stars"></i> Generate';
        });
    });

    function finalize() {
        // Make the textarea editable
        const outputText = document.getElementById('outputText');
        if (outputText) {
            outputText.removeAttribute('readonly');
            outputText.placeholder = 'Edit the generated text here...';
        }
        copyBtn.style.display = 'inline-flex';
        clearBtn.style.display = 'inline-flex';
    }

    // Copy to clipboard
    copyBtn.addEventListener('click', function() {
        const outputText = document.getElementById('outputText');
        const text = outputText ? outputText.value : generatedText;
        navigator.clipboard.writeText(text).then(() => {
            copyBtn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
            setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard"></i> Copy'; }, 1500);
        });
    });

    // Clear
    clearBtn.addEventListener('click', function() {
        generatedText = '';
        copyBtn.style.display = 'none';
        clearBtn.style.display = 'none';
        outputBody.innerHTML =
            '<div class="writing-output-empty">' +
                '<i class="bi bi-pencil-square"></i>' +
                '<div style="font-size:13px;font-weight:500;margin-bottom:4px;">Your generated content will appear here</div>' +
                '<div style="font-size:12px;">Fill in the options on the left and click Generate</div>' +
            '</div>';
    });
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

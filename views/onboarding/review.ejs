<%# Review & Confirmation — Step 5 of the data onboarding wizard %>
<%
const importData = typeof importSummary !== 'undefined' ? importSummary : {};
const depts = typeof detectedDepartments !== 'undefined' ? detectedDepartments : null;
const rules = typeof classificationRules !== 'undefined' ? classificationRules : [];
const quality = typeof dataQuality !== 'undefined' ? dataQuality : {};
const dc = typeof dataConfig !== 'undefined' ? dataConfig : {};

function qualityColor(pct) {
  if (pct == null) return 'gray';
  if (pct >= 80) return 'green';
  if (pct >= 50) return 'amber';
  return 'red';
}

function fmtNum(n) {
  if (n == null) return '—';
  return Number(n).toLocaleString();
}

function fmtPct(n) {
  if (n == null) return 'N/A';
  return Math.round(n) + '%';
}

function fmtMoney(n) {
  if (n == null) return '$0';
  return '$' + Number(n).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}
%>

<div class="review-step">
  <div class="step-icon"><i class="bi bi-clipboard-data"></i></div>
  <h1 class="step-title">Review & Launch</h1>
  <p class="step-desc">Here's a summary of your imported data. Review the results below, then launch your dashboard.</p>

  <!-- Section 1: Import Summary -->
  <div class="review-section">
    <div class="review-section-title"><i class="bi bi-database-check"></i> Import Summary</div>
    <div class="review-import-summary">
      <div class="review-import-stat">
        <span class="review-import-stat-label">Total Gifts</span>
        <span class="review-import-stat-value"><%= fmtNum(importData.giftsUpserted) %></span>
      </div>
      <div class="review-import-stat">
        <span class="review-import-stat-label">Date Range</span>
        <span class="review-import-stat-value"><%= importData.dateRange || '—' %></span>
      </div>
      <div class="review-import-stat">
        <span class="review-import-stat-label">Columns Mapped</span>
        <span class="review-import-stat-value"><%= importData.mappedColumns || '—' %> of <%= importData.totalColumns || '—' %></span>
      </div>
      <div class="review-import-stat">
        <span class="review-import-stat-label">File</span>
        <span class="review-import-stat-value" style="font-size:13px;word-break:break-all;"><%= importData.fileName || '—' %></span>
      </div>
    </div>
    <% if (importData.unmappedColumns && importData.unmappedColumns.length > 0) { %>
    <div class="review-unmapped-note">
      <strong><%= importData.unmappedColumns.length %> unmapped column<%= importData.unmappedColumns.length > 1 ? 's' : '' %>:</strong>
      <%= importData.unmappedColumns.join(', ') %>.
      <br>These columns were not recognized and were skipped. This is normal &mdash; Fund-Raise focuses on the core fundraising fields.
    </div>
    <% } %>
  </div>

  <!-- Section 2: Data Quality Indicators -->
  <div class="review-section">
    <div class="review-section-title"><i class="bi bi-heart-pulse"></i> Data Quality</div>
    <div class="review-quality-grid">
      <div class="review-quality-card">
        <div class="review-quality-pct <%= qualityColor(quality.giftCompleteness) %>"><%= fmtPct(quality.giftCompleteness) %></div>
        <div class="review-quality-label">Gift Completeness</div>
      </div>
      <% if (dc.includeFunds !== false) { %>
      <div class="review-quality-card">
        <div class="review-quality-pct <%= qualityColor(quality.fundCoverage) %>"><%= fmtPct(quality.fundCoverage) %></div>
        <div class="review-quality-label">Fund Coverage</div>
      </div>
      <% } else { %>
      <div class="review-quality-card">
        <div class="review-quality-pct gray">N/A</div>
        <div class="review-quality-label">Fund Coverage</div>
      </div>
      <% } %>
      <% if (dc.includeCampaigns !== false) { %>
      <div class="review-quality-card">
        <div class="review-quality-pct <%= qualityColor(quality.campaignCoverage) %>"><%= fmtPct(quality.campaignCoverage) %></div>
        <div class="review-quality-label">Campaign Coverage</div>
      </div>
      <% } else { %>
      <div class="review-quality-card">
        <div class="review-quality-pct gray">N/A</div>
        <div class="review-quality-label">Campaign Coverage</div>
      </div>
      <% } %>
      <% if (dc.includeAppeals !== false) { %>
      <div class="review-quality-card">
        <div class="review-quality-pct <%= qualityColor(quality.appealCoverage) %>"><%= fmtPct(quality.appealCoverage) %></div>
        <div class="review-quality-label">Appeal Coverage</div>
      </div>
      <% } else { %>
      <div class="review-quality-card">
        <div class="review-quality-pct gray">N/A</div>
        <div class="review-quality-label">Appeal Coverage</div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Section 3: Detected Departments -->
  <% if (depts && depts.departments && depts.departments.length > 0) { %>
  <div class="review-section">
    <div class="review-section-title"><i class="bi bi-diagram-3"></i> Detected Departments</div>
    <div class="review-dept-grid">
      <% const deptStats = typeof departmentStats !== 'undefined' ? departmentStats : {};
         depts.departments.forEach(dept => {
           const ds = deptStats[dept] || {};
           const matchingRule = rules.find(r => r.department === dept && r.matchType !== 'default');
      %>
      <div class="review-dept-card">
        <div class="review-dept-name"><%= dept %></div>
        <div class="review-dept-stats">
          <div class="review-dept-stat"><strong><%= fmtNum(ds.count) %></strong> gifts</div>
          <div class="review-dept-stat"><strong><%= fmtMoney(ds.total) %></strong></div>
        </div>
        <% if (matchingRule) { %>
        <div class="review-dept-rationale"><%= matchingRule.rationale || '' %></div>
        <% } %>
      </div>
      <% }); %>
    </div>

    <div class="review-confidence">
      <span class="review-confidence-label">AI Confidence</span>
      <div class="review-confidence-bar">
        <div class="review-confidence-fill" style="width: <%= Math.round((depts.confidence || 0) * 100) %>%;"></div>
      </div>
      <span class="review-confidence-value"><%= Math.round((depts.confidence || 0) * 100) %>%</span>
    </div>

    <button type="button" class="review-adjust-btn" id="adjustDeptBtn">
      <i class="bi bi-sliders"></i> Adjust Departments
    </button>
  </div>
  <% } else { %>
  <div class="review-section">
    <div class="review-section-title"><i class="bi bi-diagram-3"></i> Department Configuration</div>
    <div class="review-structure-notes" style="margin-bottom:16px;">
      Automatic department detection was not completed. You can configure departments manually below, or re-analyze from Settings after launching.
    </div>
    <button type="button" class="review-adjust-btn" id="manualDeptBtn">
      <i class="bi bi-plus-circle"></i> Configure Departments Manually
    </button>
  </div>
  <% } %>

  <!-- Section 4: Data Structure Summary -->
  <% if (depts && depts.dataStructureNotes) { %>
  <div class="review-section">
    <div class="review-section-title"><i class="bi bi-info-circle"></i> How Your Data Is Organized</div>
    <div class="review-structure-notes"><%= depts.dataStructureNotes %></div>
  </div>
  <% } %>

  <!-- Launch button -->
  <button type="button" class="review-launch-btn" id="launchDashboardBtn">
    <i class="bi bi-rocket-takeoff"></i> Launch Dashboard
  </button>
</div>

<!-- Department adjustment modal (hidden by default) -->
<div id="deptAdjustModal" style="display:none; position:fixed; inset:0; background:rgba(26,34,61,0.85); z-index:1000; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; padding:32px; max-width:500px; width:90%; max-height:80vh; overflow-y:auto;">
    <h3 style="font-family:'Manrope','Poppins',sans-serif; font-size:18px; font-weight:700; color:#1A223D; margin-bottom:16px;">Adjust Departments</h3>
    <p style="font-size:13px; color:#6E7180; margin-bottom:20px;">Rename, merge, or remove detected departments. Removed departments will be reclassified as the default.</p>
    <div id="deptAdjustList"></div>
    <div style="display:flex; gap:12px; margin-top:20px;">
      <button type="button" id="deptAdjustCancel" style="flex:1; padding:12px; background:#EFF1F4; border:none; border-radius:8px; font-family:'Poppins',sans-serif; font-size:13px; cursor:pointer;">Cancel</button>
      <button type="button" id="deptAdjustSave" style="flex:1; padding:12px; background:#3434D6; color:#fff; border:none; border-radius:8px; font-family:'Poppins',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Save Changes</button>
    </div>
  </div>
</div>

<!-- Manual department configuration modal -->
<div id="manualDeptModal" style="display:none; position:fixed; inset:0; background:rgba(26,34,61,0.85); z-index:1000; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; padding:32px; max-width:600px; width:90%; max-height:85vh; overflow-y:auto;">
    <h3 style="font-family:'Manrope',sans-serif; font-size:18px; font-weight:700; color:#1A223D; margin-bottom:8px;">Configure Departments Manually</h3>
    <p style="font-size:13px; color:#6E7180; margin-bottom:20px;">Name your fundraising departments and optionally define classification rules. Gifts matching a rule will be assigned to that department. Unmatched gifts go to the default department.</p>

    <div id="manualDeptList"></div>

    <button type="button" id="addManualDeptBtn" style="display:flex; align-items:center; gap:6px; margin-top:12px; padding:8px 14px; background:none; border:1px dashed #BCBFCC; border-radius:8px; font-family:'Manrope',sans-serif; font-size:13px; color:#3434D6; cursor:pointer; width:100%; justify-content:center;">
      <i class="bi bi-plus-circle"></i> Add Department
    </button>

    <div style="display:flex; gap:12px; margin-top:24px;">
      <button type="button" id="manualDeptCancel" style="flex:1; padding:12px; background:#EFF1F4; border:none; border-radius:8px; font-family:'Manrope',sans-serif; font-size:13px; cursor:pointer;">Cancel</button>
      <button type="button" id="manualDeptSave" style="flex:1; padding:12px; background:#3434D6; color:#fff; border:none; border-radius:8px; font-family:'Manrope',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Save & Apply</button>
    </div>
    <div id="manualDeptMsg" style="display:none; margin-top:12px; font-size:12px; padding:8px 12px; border-radius:6px;"></div>
  </div>
</div>

<script>
(function() {
  // Manual department configuration
  var manualBtn = document.getElementById('manualDeptBtn');
  var manualModal = document.getElementById('manualDeptModal');
  var manualList = document.getElementById('manualDeptList');
  var addBtn = document.getElementById('addManualDeptBtn');
  var cancelBtn = document.getElementById('manualDeptCancel');
  var saveBtn = document.getElementById('manualDeptSave');
  var msgEl = document.getElementById('manualDeptMsg');

  if (!manualBtn) return;

  var fieldOptions = [
    { value: 'appealDescription', label: 'Appeal Description' },
    { value: 'appealCategory', label: 'Appeal Category' },
    { value: 'campaignDescription', label: 'Campaign Description' },
    { value: 'fundDescription', label: 'Fund Description' },
    { value: 'fundCategory', label: 'Fund Category' },
    { value: 'giftCode', label: 'Gift Code' },
    { value: 'giftAmount', label: 'Gift Amount (>=)' },
  ];

  var deptCount = 0;

  function addDeptRow(name, field, pattern, isDefault) {
    deptCount++;
    var id = 'dept_' + deptCount;
    var div = document.createElement('div');
    div.className = 'manual-dept-row';
    div.id = id;
    div.style.cssText = 'padding:14px; margin-bottom:10px; border:1px solid #EDEFF7; border-radius:10px; background:#FAFBFC;';

    var nameHtml = '<div style="margin-bottom:8px;"><input type="text" placeholder="Department name (e.g. Events)" value="' + (name || '') + '" class="mdept-name" style="width:100%; padding:8px 12px; border:1px solid #D3D6E0; border-radius:6px; font-family:Manrope,sans-serif; font-size:13px;"></div>';

    var defaultChecked = isDefault ? ' checked' : '';
    var ruleDisplay = isDefault ? 'display:none;' : '';

    var ruleHtml = '<div class="mdept-rule" style="' + ruleDisplay + 'display:flex; gap:8px; align-items:center; flex-wrap:wrap;">';
    ruleHtml += '<select class="mdept-field" style="padding:6px 10px; border:1px solid #D3D6E0; border-radius:6px; font-size:12px; font-family:Manrope,sans-serif;">';
    fieldOptions.forEach(function(o) {
      ruleHtml += '<option value="' + o.value + '"' + (field === o.value ? ' selected' : '') + '>' + o.label + '</option>';
    });
    ruleHtml += '</select>';
    ruleHtml += '<input type="text" placeholder="Pattern (e.g. gala|dinner|auction)" value="' + (pattern || '') + '" class="mdept-pattern" style="flex:1; min-width:150px; padding:6px 10px; border:1px solid #D3D6E0; border-radius:6px; font-size:12px; font-family:Manrope,sans-serif;">';
    ruleHtml += '</div>';

    var defaultHtml = '<div style="margin-top:8px; display:flex; align-items:center; justify-content:space-between;">';
    defaultHtml += '<label style="font-size:12px; color:#6E7180; display:flex; align-items:center; gap:6px; cursor:pointer;"><input type="checkbox" class="mdept-default"' + defaultChecked + '> Default (catch-all)</label>';
    defaultHtml += '<button type="button" class="mdept-remove" style="background:none; border:none; color:#dc2626; font-size:12px; cursor:pointer;"><i class="bi bi-trash"></i> Remove</button>';
    defaultHtml += '</div>';

    div.innerHTML = nameHtml + ruleHtml + defaultHtml;
    manualList.appendChild(div);

    // Toggle rule visibility when default is checked
    var chk = div.querySelector('.mdept-default');
    var ruleEl = div.querySelector('.mdept-rule');
    chk.addEventListener('change', function() {
      ruleEl.style.display = chk.checked ? 'none' : 'flex';
    });

    // Remove button
    div.querySelector('.mdept-remove').addEventListener('click', function() {
      div.remove();
    });
  }

  manualBtn.addEventListener('click', function() {
    manualModal.style.display = 'flex';
    if (manualList.children.length === 0) {
      addDeptRow('Annual Giving', '', '', true);
      addDeptRow('', 'appealDescription', '', false);
    }
  });

  addBtn.addEventListener('click', function() { addDeptRow('', 'appealDescription', '', false); });
  cancelBtn.addEventListener('click', function() { manualModal.style.display = 'none'; });

  saveBtn.addEventListener('click', function() {
    var rows = manualList.querySelectorAll('.manual-dept-row');
    var departments = [];
    rows.forEach(function(row) {
      var name = row.querySelector('.mdept-name').value.trim();
      if (!name) return;
      var isDefault = row.querySelector('.mdept-default').checked;
      var field = row.querySelector('.mdept-field').value;
      var pattern = row.querySelector('.mdept-pattern').value.trim();
      departments.push({ name: name, field: isDefault ? null : field, pattern: isDefault ? null : pattern, matchType: field === 'giftAmount' ? 'gte' : 'regex', isDefault: isDefault });
    });

    if (departments.length === 0) {
      msgEl.style.display = 'block'; msgEl.style.background = '#fef2f2'; msgEl.style.color = '#dc2626';
      msgEl.textContent = 'Add at least one department.'; return;
    }

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    msgEl.style.display = 'none';

    fetch('/api/onboarding/manual-departments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ departments: departments }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.error) throw new Error(data.error);
      msgEl.style.display = 'block'; msgEl.style.background = '#f0fdf4'; msgEl.style.color = '#16a34a';
      msgEl.textContent = 'Departments saved! ' + (data.giftsReclassified || 0) + ' gifts reclassified.';
      setTimeout(function() { location.reload(); }, 1500);
    })
    .catch(function(err) {
      msgEl.style.display = 'block'; msgEl.style.background = '#fef2f2'; msgEl.style.color = '#dc2626';
      msgEl.textContent = err.message || 'Failed to save.';
    })
    .finally(function() { saveBtn.disabled = false; saveBtn.textContent = 'Save & Apply'; });
  });
})();
</script>

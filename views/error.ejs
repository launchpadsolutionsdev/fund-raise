<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Fund-Raise</title>
    <link rel="icon" type="image/svg+xml" href="/images/fund-raise-icon-flat.svg">
    <link href="/css/style.css" rel="stylesheet">
    <script>
        (function(){var t=localStorage.getItem('fr-theme');if(!t){t=window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';}document.documentElement.setAttribute('data-theme',t);})();
    </script>
    <style>
        .error-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--color-background-secondary);
            padding: 24px;
        }
        .error-container {
            text-align: center;
            max-width: 480px;
        }
        .error-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            font-size: 36px;
        }
        .error-icon.not-found {
            background: var(--color-background-info);
            color: var(--color-text-info);
        }
        .error-icon.server-error {
            background: var(--color-background-danger);
            color: var(--color-text-danger);
        }
        .error-icon.forbidden {
            background: var(--color-background-warning);
            color: var(--color-text-warning);
        }
        .error-code {
            font-size: 64px;
            font-weight: 800;
            letter-spacing: -2px;
            margin-bottom: 4px;
            background: var(--fr-gradient-blue);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .error-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--color-text-primary);
            margin-bottom: 8px;
        }
        .error-message {
            font-size: 14px;
            color: var(--color-text-secondary);
            line-height: 1.6;
            margin-bottom: 28px;
        }
        .error-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .error-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 20px;
            border-radius: var(--border-radius-md);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.15s, transform 0.1s;
            cursor: pointer;
            border: none;
            font-family: inherit;
        }
        .error-btn:hover { transform: translateY(-1px); }
        .error-btn-primary {
            background: var(--fr-indigo);
            color: #fff;
        }
        .error-btn-primary:hover { background: var(--fr-navy); }
        .error-btn-secondary {
            background: var(--color-background-primary);
            color: var(--color-text-primary);
            border: 1px solid var(--color-border-primary);
        }
        .error-btn-secondary:hover { background: var(--color-background-secondary); }
        .error-brand {
            margin-top: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: var(--color-text-tertiary);
            font-size: 12px;
        }
        .error-brand img {
            width: 20px;
            height: 20px;
            opacity: 0.5;
        }
    </style>
</head>
<body>
    <div class="error-page">
        <div class="error-container">
            <%
                const statusCode = typeof status !== 'undefined' ? status : 404;
                let iconClass = 'not-found';
                let iconName = 'bi-compass';
                let errorTitle = 'Page Not Found';
                let errorMsg = message || "The page you're looking for doesn't exist or has been moved.";

                if (statusCode === 500) {
                    iconClass = 'server-error';
                    iconName = 'bi-exclamation-octagon';
                    errorTitle = 'Something Went Wrong';
                    errorMsg = message || "We hit an unexpected error. Our team has been notified. Please try again in a moment.";
                } else if (statusCode === 403) {
                    iconClass = 'forbidden';
                    iconName = 'bi-shield-lock';
                    errorTitle = 'Access Denied';
                    errorMsg = message || "You don't have permission to view this page. Contact your admin if you think this is a mistake.";
                } else if (statusCode === 503) {
                    iconClass = 'server-error';
                    iconName = 'bi-wrench-adjustable';
                    errorTitle = 'Under Maintenance';
                    errorMsg = message || "We're doing a bit of maintenance. We'll be back shortly.";
                }
            %>
            <div class="error-icon <%= iconClass %>">
                <i class="bi <%= iconName %>"></i>
            </div>
            <div class="error-code"><%= statusCode %></div>
            <div class="error-title"><%= errorTitle %></div>
            <p class="error-message"><%= errorMsg %></p>
            <div class="error-actions">
                <a href="/crm-dashboard" class="error-btn error-btn-primary">
                    <i class="bi bi-graph-up"></i> Go to Dashboard
                </a>
                <button onclick="history.back()" class="error-btn error-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Go Back
                </button>
            </div>
            <div class="error-brand">
                <img src="/images/fund-raise-icon-flat.svg" alt="Fund-Raise">
                Fund-Raise
            </div>
        </div>
    </div>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</body>
</html>

<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting" id="donor-name">Donor Detail</div>
        <div class="page-subtitle">Complete giving history for constituent <code><%= constituentId %></code></div>
    </div>
    <div style="display:flex;gap:8px;">
        <% if (currentUser && currentUser.canUpload()) { %>
        <button class="fr-btn fr-btn-primary" id="assignActionBtn" style="font-size:12px;"><i class="bi bi-lightning-charge"></i> Assign Action</button>
        <% } %>
        <a href="javascript:history.back()" class="fr-btn fr-btn-secondary" style="font-size:12px;"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div id="donor-loading" class="crm-loading-container">
    <div class="crm-loading-inner">
        <div class="crm-loading-bars">
            <div class="crm-bar" style="--i:0"></div><div class="crm-bar" style="--i:1"></div>
            <div class="crm-bar" style="--i:2"></div><div class="crm-bar" style="--i:3"></div><div class="crm-bar" style="--i:4"></div>
        </div>
        <div class="crm-loading-text">Loading donor profile...</div>
    </div>
</div>

<style>
.crm-loading-container{display:flex;justify-content:center;align-items:center;min-height:300px;transition:opacity .5s,transform .5s}
.crm-loading-container.fade-out{opacity:0;transform:translateY(-20px)}
.crm-loading-inner{text-align:center}
.crm-loading-bars{display:flex;justify-content:center;align-items:flex-end;gap:6px;height:80px;margin-bottom:24px}
.crm-bar{width:14px;border-radius:4px 4px 0 0;background:var(--color-brand-blue);animation:crm-bar-bounce 1.2s ease-in-out calc(var(--i)*.15s) infinite}
.crm-bar:nth-child(2){background:var(--color-brand-navy)}.crm-bar:nth-child(4){background:var(--color-brand-gold)}.crm-bar:nth-child(5){background:var(--color-brand-navy)}
@keyframes crm-bar-bounce{0%,100%{height:20px;opacity:.5}50%{height:70px;opacity:1}}
.crm-loading-text{font-size:18px;font-weight:600;color:var(--color-text-primary);margin-bottom:8px}
#donor-content{animation:crm-content-in .6s ease both}
@keyframes crm-content-in{0%{opacity:0;transform:translateY(20px)}100%{opacity:1;transform:translateY(0)}}
</style>

<div id="donor-content" style="display:none;"></div>

<script>
(function() {
    const constituentId = <%- JSON.stringify(constituentId) %>;
    var ctrl = new AbortController();
    setTimeout(function() { ctrl.abort(); }, 30000);
    fetch('/crm/donor/' + encodeURIComponent(constituentId) + '/data', { signal: ctrl.signal })
        .then(function(r) { if (!r.ok) throw new Error('Server returned ' + r.status); return r.json(); })
        .then(function(data) {
            if (data.error) throw new Error(data.error);
            render(data);
        })
        .catch(function(err) {
            var msg = err.name === 'AbortError' ? 'Request timed out. The query may be too heavy — try again.' : err.message;
            document.getElementById('donor-loading').innerHTML =
                '<div class="alert-card danger"><div class="alert-card-title">Error</div><div class="alert-card-text">' + msg + '</div></div>';
        });

    function fmt(n) { return Number(n).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}); }
    function esc(s) { if(!s) return ''; const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

    function render(d) {
        const s = d.summary;
        if (!s) {
            document.getElementById('donor-loading').innerHTML = '<div class="alert-card info"><div class="alert-card-title">Donor not found</div></div>';
            return;
        }
        var donorName = ((s.first_name || '') + ' ' + (s.last_name || '')).trim() || s.constituent_id || 'Unknown Donor';
        document.getElementById('donor-name').textContent = donorName;
        var html = '';

        // Constituent type badge (shown next to name)
        if (s.constituent_type) {
            var typeIcons = { 'individual': 'bi-person', 'business': 'bi-building', 'organization': 'bi-people', 'foundation': 'bi-bank', 'charity': 'bi-heart', 'non profit': 'bi-heart', 'nonprofit': 'bi-heart', 'service club': 'bi-flag', 'vendor': 'bi-shop' };
            var typeKey = s.constituent_type.toLowerCase().trim();
            var typeIcon = typeIcons[typeKey] || 'bi-tag';
            html += '<div style="margin-bottom:16px;"><span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;padding:4px 12px;border-radius:20px;background:var(--color-background-secondary);color:var(--color-text-secondary);">' +
                '<i class="bi ' + typeIcon + '"></i>' + esc(s.constituent_type) + '</span></div>';
        }

        // KPIs — split cash received from outstanding pledge commitments
        var cashReceived = Number(s.total_cash || 0) + Number(s.total_pledge_payments || 0);
        var pledgeOutstanding = Number(s.total_pledge_commitments || 0);
        html += '<div class="kpi-grid" style="grid-template-columns:repeat(5,minmax(0,1fr));margin-bottom:20px;">' +
            '<div class="kpi-card"><div class="kpi-label">Cash Received</div><div class="kpi-value">$' + fmt(cashReceived) + '</div>' +
                (pledgeOutstanding > 0 ? '<div style="font-size:11px;color:#d97706;margin-top:2px;font-weight:600;">+ $' + fmt(pledgeOutstanding) + ' pledged</div>' : '') + '</div>' +
            '<div class="kpi-card"><div class="kpi-label">Total Gifts</div><div class="kpi-value">' + fmt(s.total_gifts) + '</div>' +
                (Number(s.pledge_commitment_count || 0) > 0 ? '<div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">' + fmt(s.pledge_commitment_count) + ' pledge ' + (Number(s.pledge_commitment_count) === 1 ? 'commitment' : 'commitments') + '</div>' : '') + '</div>' +
            '<div class="kpi-card"><div class="kpi-label">Average Gift</div><div class="kpi-value">$' + fmt(s.avg_gift) + '</div></div>' +
            '<div class="kpi-card"><div class="kpi-label">Largest Gift</div><div class="kpi-value">$' + fmt(s.largest_gift) + '</div></div>' +
            '<div class="kpi-card"><div class="kpi-label">Giving Since</div><div class="kpi-value" style="font-size:16px;">' + (s.first_gift_date || 'N/A') + '</div></div></div>';

        // Pledge banner — explicit warning when outstanding commitments exist
        if (pledgeOutstanding > 0) {
            html += '<div style="margin-bottom:16px;padding:12px 16px;background:#FFF6E0;border:1px solid #fbbf24;border-radius:8px;display:flex;align-items:center;gap:10px;font-size:13px;color:#92400e;">' +
                '<i class="bi bi-exclamation-triangle-fill" style="font-size:16px;"></i>' +
                '<div><strong>$' + fmt(pledgeOutstanding) + '</strong> in outstanding pledge commitments &mdash; not counted as realised cash. ' +
                '<a href="/crm/pledge-pipeline" style="color:#92400e;text-decoration:underline;">View pledge pipeline</a>.</div></div>';
        }

        // Contact info card
        if (s.email || s.phone || s.address) {
            html += '<div class="fr-card" style="margin-bottom:16px;"><div class="fr-card-body" style="display:flex;flex-wrap:wrap;gap:20px;font-size:13px;">';
            if (s.email) {
                html += '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<i class="bi bi-envelope" style="color:var(--color-text-tertiary);"></i>' +
                    '<a href="mailto:' + esc(s.email) + '">' + esc(s.email) + '</a></div>';
            }
            if (s.phone) {
                html += '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<i class="bi bi-telephone" style="color:var(--color-text-tertiary);"></i>' +
                    '<a href="tel:' + esc(s.phone) + '">' + esc(s.phone) + '</a></div>';
            }
            if (s.address) {
                var addrParts = [s.address, s.city, s.state, s.zip].filter(Boolean);
                if (s.country && s.country !== 'United States' && s.country !== 'US' && s.country !== 'USA') addrParts.push(s.country);
                html += '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<i class="bi bi-geo-alt" style="color:var(--color-text-tertiary);"></i>' +
                    '<span>' + esc(addrParts.join(', ')) + '</span></div>';
            }
            html += '</div></div>';
        }

        // Assigned fundraisers
        if (d.fundraisers && d.fundraisers.length > 0) {
            html += '<div style="margin-bottom:16px;font-size:13px;">' +
                '<span style="font-weight:600;">Fundraiser(s):</span> ' +
                d.fundraisers.map(f => '<a href="/fundraiser-performance?fundraiser=' + encodeURIComponent(f) + '">' + esc(f) + '</a>').join(', ') + '</div>';
        }

        // By FY table
        if (d.byYear && d.byYear.length > 0) {
            html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">';
            html += '<div class="fr-card"><div class="fr-card-body"><div class="section-title" style="margin-bottom:12px;">Giving by Fiscal Year</div>' +
                '<table class="fr-table" style="width:100%;font-size:13px;"><thead><tr><th>FY</th><th style="text-align:right;">Gifts</th><th style="text-align:right;">Total</th></tr></thead><tbody>';
            d.byYear.forEach(y => {
                html += '<tr><td>FY' + y.fy + '</td><td style="text-align:right;">' + fmt(y.gift_count) + '</td>' +
                    '<td style="text-align:right;font-weight:600;">$' + fmt(y.total) + '</td></tr>';
            });
            html += '</tbody></table></div></div>';

            // Bar chart
            const maxY = Math.max(...d.byYear.map(y => Number(y.total)));
            let bars = '';
            [...d.byYear].reverse().forEach(y => {
                const pct = maxY > 0 ? (Number(y.total) / maxY * 100) : 0;
                bars += '<div style="flex:1;display:flex;flex-direction:column;align-items:center;min-width:50px;">' +
                    '<div style="font-size:10px;color:var(--color-text-secondary);margin-bottom:4px;">$' + (Number(y.total)/1000).toFixed(0) + 'K</div>' +
                    '<div style="width:100%;max-width:40px;height:' + Math.max(pct,2) + '%;background:var(--color-brand-blue);border-radius:3px 3px 0 0;"></div>' +
                    '<div style="font-size:10px;color:var(--color-text-secondary);margin-top:4px;">FY' + y.fy + '</div></div>';
            });
            html += '<div class="fr-card"><div class="fr-card-body"><div class="section-title" style="margin-bottom:12px;">Annual Trend</div>' +
                '<div style="display:flex;align-items:flex-end;gap:4px;height:150px;">' + bars + '</div></div></div></div>';
        }

        // Gift history table.
        // Pledge commitments render with their installment payments nested
        // underneath (expandable row) so a donor's $1M pledge + 10 $100k
        // payments shows as ONE pledge event, not 11 rows. Orphan payments
        // (no matching parent commitment) render as their own rows with a
        // "standalone" badge. Cash gifts render normally.
        var totalRows = d.gifts.length;
        d.gifts.forEach(function(g){ if (g.payments) totalRows += g.payments.length; });
        html += '<div class="fr-card" style="margin-bottom:20px;"><div class="fr-card-body">' +
            '<div class="section-title" style="margin-bottom:12px;">Gift History (' + d.gifts.length + ' gift event' + (d.gifts.length === 1 ? '' : 's') +
            (totalRows !== d.gifts.length ? ', including ' + (totalRows - d.gifts.length) + ' pledge installment' + (totalRows - d.gifts.length === 1 ? '' : 's') : '') + ')</div>' +
            '<table class="fr-table" style="width:100%;font-size:13px;"><thead><tr>' +
            '<th style="width:24px;"></th><th>Date</th><th style="text-align:right;">Amount</th><th>Type</th><th>Fund</th><th>Campaign</th><th>Appeal</th><th style="width:40px;"></th></tr></thead><tbody>';

        function rowHtml(g, isNested) {
            var typeLabel = g.gift_type || g.gift_code || '';
            var badge = '';
            if (g.pledge_category === 'pledge_commitment') {
                badge = '<span style="display:inline-block;padding:1px 6px;border-radius:10px;font-size:10px;font-weight:600;background:#FFF6E0;color:#d97706;margin-left:6px;">PLEDGE</span>';
            } else if (g.pledge_category === 'pledge_payment') {
                var paymentLabel = g.pledge_orphan ? 'PAYMENT (no pledge match)' : 'PAYMENT';
                var paymentBg = g.pledge_orphan ? '#FEE2E2' : '#EAF3DE';
                var paymentColor = g.pledge_orphan ? '#991b1b' : '#15803d';
                badge = '<span style="display:inline-block;padding:1px 6px;border-radius:10px;font-size:10px;font-weight:600;background:' + paymentBg + ';color:' + paymentColor + ';margin-left:6px;">' + paymentLabel + '</span>';
            }
            var indent = isNested ? '<span style="color:#94a3b8;margin-right:6px;">↳</span>' : '';
            var rowBg = isNested ? 'background:#F8FAFC;' : '';
            return '<tr style="' + rowBg + '"><td></td><td>' + indent + (g.gift_date || '') + '</td>' +
                '<td style="text-align:right;font-weight:600;">$' + fmt(g.gift_amount) + '</td>' +
                '<td>' + esc(typeLabel) + badge + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.fund_id ? '<a href="/crm/fund/' + encodeURIComponent(g.fund_id) + '">' + esc(g.fund_description) + '</a>' : esc(g.fund_description)) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.campaign_id ? '<a href="/crm/campaign/' + encodeURIComponent(g.campaign_id) + '">' + esc(g.campaign_description) + '</a>' : esc(g.campaign_description)) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.appeal_id ? '<a href="/crm/appeal/' + encodeURIComponent(g.appeal_id) + '">' + esc(g.appeal_description) + '</a>' : esc(g.appeal_description)) + '</td></tr>';
        }

        d.gifts.forEach(function(g, idx) {
            var hasPayments = g.pledge_category === 'pledge_commitment' && Array.isArray(g.payments) && g.payments.length > 0;
            var typeLabel = g.gift_type || g.gift_code || '';
            var badge = '';
            if (g.pledge_category === 'pledge_commitment') {
                badge = '<span style="display:inline-block;padding:1px 6px;border-radius:10px;font-size:10px;font-weight:600;background:#FFF6E0;color:#d97706;margin-left:6px;">PLEDGE</span>';
                if (g.fulfillment_pct != null) {
                    badge += '<span style="display:inline-block;padding:1px 6px;border-radius:10px;font-size:10px;font-weight:600;background:#E0E7FF;color:#3730a3;margin-left:4px;">' +
                        Math.round(g.fulfillment_pct) + '% fulfilled</span>';
                }
            } else if (g.pledge_category === 'pledge_payment') {
                var paymentLabel = g.pledge_orphan ? 'PAYMENT (no pledge match)' : 'PAYMENT';
                var paymentBg = g.pledge_orphan ? '#FEE2E2' : '#EAF3DE';
                var paymentColor = g.pledge_orphan ? '#991b1b' : '#15803d';
                badge = '<span style="display:inline-block;padding:1px 6px;border-radius:10px;font-size:10px;font-weight:600;background:' + paymentBg + ';color:' + paymentColor + ';margin-left:6px;">' + paymentLabel + '</span>';
            }

            // Parent row
            var toggleCell = hasPayments
                ? '<td style="cursor:pointer;user-select:none;" onclick="(function(btn){var r=btn.closest(\'tr\').nextElementSibling;while(r && r.classList.contains(\'pledge-pmt-' + idx + '\')){r.style.display=(r.style.display===\'none\'?\'\':\'none\');r=r.nextElementSibling;}btn.firstChild.textContent=(btn.firstChild.textContent===\'▸\'?\'▾\':\'▸\');})(this)"><span>▾</span></td>'
                : '<td></td>';
            var amountCell = hasPayments
                ? '<td style="text-align:right;font-weight:600;">$' + fmt(g.gift_amount) + '<div style="font-size:10px;font-weight:400;color:#64748b;">$' + fmt(g.paid_total || 0) + ' received</div></td>'
                : '<td style="text-align:right;font-weight:600;">$' + fmt(g.gift_amount) + '</td>';
            // "Generate thank-you" button on cash + pledge_payment rows
            // (commitments aren't "received" so we don't offer one there).
            var canAck = (g.pledge_category === 'cash' || g.pledge_category === 'pledge_payment') && g.gift_id;
            var ackCell = canAck
                ? '<td style="white-space:nowrap;"><button class="fr-btn fr-btn-secondary ty-gen-btn" data-gift="' + esc(g.gift_id) + '" style="padding:3px 8px;font-size:11px;" title="Generate thank-you letter from your templates"><i class="bi bi-envelope-heart"></i></button></td>'
                : '<td></td>';
            html += '<tr>' + toggleCell + '<td>' + (g.gift_date || '') + '</td>' + amountCell +
                '<td>' + esc(typeLabel) + badge + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.fund_id ? '<a href="/crm/fund/' + encodeURIComponent(g.fund_id) + '">' + esc(g.fund_description) + '</a>' : esc(g.fund_description)) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.campaign_id ? '<a href="/crm/campaign/' + encodeURIComponent(g.campaign_id) + '">' + esc(g.campaign_description) + '</a>' : esc(g.campaign_description)) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.appeal_id ? '<a href="/crm/appeal/' + encodeURIComponent(g.appeal_id) + '">' + esc(g.appeal_description) + '</a>' : esc(g.appeal_description)) + '</td>' +
                ackCell + '</tr>';

            // Nested payment rows for pledge commitments
            if (hasPayments) {
                g.payments.forEach(function(p) {
                    var pTypeLabel = p.gift_type || p.gift_code || 'Pledge Payment';
                    var pBadge = '<span style="display:inline-block;padding:1px 6px;border-radius:10px;font-size:10px;font-weight:600;background:#EAF3DE;color:#15803d;margin-left:6px;">PAYMENT</span>';
                    var pAckCell = p.gift_id
                        ? '<td style="white-space:nowrap;"><button class="fr-btn fr-btn-secondary ty-gen-btn" data-gift="' + esc(p.gift_id) + '" style="padding:3px 8px;font-size:11px;" title="Generate thank-you letter from your templates"><i class="bi bi-envelope-heart"></i></button></td>'
                        : '<td></td>';
                    html += '<tr class="pledge-pmt-' + idx + '" style="background:#F8FAFC;"><td></td>' +
                        '<td><span style="color:#94a3b8;margin-right:6px;">↳</span>' + (p.gift_date || '') + '</td>' +
                        '<td style="text-align:right;font-weight:600;">$' + fmt(p.gift_amount) + '</td>' +
                        '<td>' + esc(pTypeLabel) + pBadge + '</td>' +
                        '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                        (p.fund_id ? '<a href="/crm/fund/' + encodeURIComponent(p.fund_id) + '">' + esc(p.fund_description) + '</a>' : esc(p.fund_description)) + '</td>' +
                        '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                        (p.campaign_id ? '<a href="/crm/campaign/' + encodeURIComponent(p.campaign_id) + '">' + esc(p.campaign_description) + '</a>' : esc(p.campaign_description)) + '</td>' +
                        '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                        (p.appeal_id ? '<a href="/crm/appeal/' + encodeURIComponent(p.appeal_id) + '">' + esc(p.appeal_description) + '</a>' : esc(p.appeal_description)) + '</td>' +
                        pAckCell + '</tr>';
                });
            }
        });
        html += '</tbody></table></div></div>';

        const loader = document.getElementById('donor-loading');
        const content = document.getElementById('donor-content');
        loader.classList.add('fade-out');
        setTimeout(() => {
            loader.style.display = 'none';
            content.innerHTML = html;
            content.style.display = 'block';
            wireThankYouButtons();
        }, 400);
    }

    // ── Thank-you letter from template ──
    // Each received gift row has a small envelope button; clicking it picks
    // the best template for that gift (fund → campaign → appeal → default),
    // renders it with the donor's real data, and shows the result in a
    // modal the team can copy to the clipboard.
    function wireThankYouButtons(){
        document.querySelectorAll('.ty-gen-btn').forEach(function(btn){
            btn.addEventListener('click', function(){
                var giftId = btn.getAttribute('data-gift');
                if (!giftId) return;
                btn.disabled = true;
                fetch('/api/thank-you-templates/for-gift/' + encodeURIComponent(giftId))
                    .then(function(r){return r.json().then(function(d){ return { ok:r.ok, data:d }; });})
                    .then(function(res){
                        if (!res.ok){
                            var hint = res.data && res.data.hint ? '\n\n' + res.data.hint : '';
                            frAlert((res.data && res.data.error || 'Unable to generate letter') + hint, { variant:'warning', title:'No template' });
                            return;
                        }
                        showLetterModal(res.data);
                    })
                    .catch(function(){ frAlert('Failed to load template', { variant:'danger', title:'Error' }); })
                    .finally(function(){ btn.disabled = false; });
            });
        });
    }

    function showLetterModal(data){
        var overlay = document.getElementById('tyLetterOverlay');
        if (!overlay){
            overlay = document.createElement('div');
            overlay.id = 'tyLetterOverlay';
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:9998;display:flex;align-items:center;justify-content:center;padding:20px;';
            overlay.innerHTML = ''
              + '<div style="background:#fff;border-radius:12px;max-width:720px;width:100%;max-height:90vh;overflow:auto;box-shadow:0 10px 40px rgba(0,0,0,.2);">'
              + '  <div style="padding:18px 24px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center;">'
              + '    <div>'
              + '      <div style="font-weight:600;font-size:15px;" id="tyTplName">Thank-you letter</div>'
              + '      <div style="font-size:11px;color:#64748b;margin-top:2px;" id="tyTplScope"></div>'
              + '    </div>'
              + '    <button id="tyCloseBtn" style="border:none;background:transparent;cursor:pointer;font-size:22px;color:#64748b;">&times;</button>'
              + '  </div>'
              + '  <div style="padding:20px 24px;">'
              + '    <div id="tySubjectWrap" style="margin-bottom:12px;display:none;">'
              + '      <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.5px;font-weight:600;margin-bottom:4px;">Subject</div>'
              + '      <div id="tySubject" style="font-weight:600;font-size:14px;"></div>'
              + '    </div>'
              + '    <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.5px;font-weight:600;margin-bottom:4px;">Letter</div>'
              + '    <div id="tyBody" style="white-space:pre-wrap;font-family:Georgia,serif;font-size:14px;line-height:1.65;background:#f8fafc;border:1px solid #e5e7eb;border-radius:8px;padding:16px 18px;color:#0f172a;"></div>'
              + '    <div id="tyMissing" style="display:none;margin-top:10px;font-size:11px;color:#92400e;"></div>'
              + '  </div>'
              + '  <div style="padding:14px 24px 18px;border-top:1px solid #e5e7eb;display:flex;justify-content:flex-end;gap:8px;">'
              + '    <button id="tyCopyBtn" class="fr-btn fr-btn-secondary"><i class="bi bi-clipboard"></i> Copy</button>'
              + '    <a href="/settings/thank-you-templates" class="fr-btn fr-btn-secondary">Edit templates</a>'
              + '    <button id="tyDoneBtn" class="fr-btn fr-btn-primary">Done</button>'
              + '  </div>'
              + '</div>';
            document.body.appendChild(overlay);
            overlay.addEventListener('click', function(e){ if (e.target === overlay) overlay.style.display = 'none'; });
            document.getElementById('tyCloseBtn').addEventListener('click', function(){ overlay.style.display = 'none'; });
            document.getElementById('tyDoneBtn').addEventListener('click', function(){ overlay.style.display = 'none'; });
            document.getElementById('tyCopyBtn').addEventListener('click', function(){
                var text = (document.getElementById('tySubject').textContent ? 'Subject: ' + document.getElementById('tySubject').textContent + '\n\n' : '') + document.getElementById('tyBody').textContent;
                navigator.clipboard.writeText(text).then(function(){
                    var btn = document.getElementById('tyCopyBtn');
                    var orig = btn.innerHTML;
                    btn.innerHTML = '<i class="bi bi-check-lg"></i> Copied';
                    setTimeout(function(){ btn.innerHTML = orig; }, 1500);
                });
            });
        }
        document.getElementById('tyTplName').textContent = 'Thank-you letter — ' + (data.template.name || '');
        var scopeLabel = data.template.scopeType === 'default'
            ? 'Default template'
            : (data.template.scopeType + ' · ' + (data.template.scopeLabel || ''));
        document.getElementById('tyTplScope').textContent = scopeLabel;
        if (data.subject){
            document.getElementById('tySubjectWrap').style.display = '';
            document.getElementById('tySubject').textContent = data.subject;
        } else {
            document.getElementById('tySubjectWrap').style.display = 'none';
        }
        document.getElementById('tyBody').textContent = data.body || '';
        var missingEl = document.getElementById('tyMissing');
        if (data.missingTokens && data.missingTokens.length){
            missingEl.style.display = '';
            missingEl.textContent = 'Unknown merge tokens in this template: ' +
                data.missingTokens.map(function(t){return '{{' + t + '}}';}).join(', ');
        } else {
            missingEl.style.display = 'none';
        }
        overlay.style.display = 'flex';
    }
})();
</script>

<% if (currentUser && currentUser.canUpload()) { %>
<%- include('../partials/assign-action-modal') %>
<script>
(function() {
    var btn = document.getElementById('assignActionBtn');
    if (!btn) return;
    var constituentId = <%- JSON.stringify(constituentId) %>;

    btn.addEventListener('click', function() {
        // Fetch donor context from the data endpoint
        btn.disabled = true;
        fetch('/crm/donor/' + encodeURIComponent(constituentId) + '/data')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var s = data.summary || {};
                var donorName = ((s.first_name || '') + ' ' + (s.last_name || '')).trim() || constituentId;
                var donorContext = null;
                if (s.total_given != null) {
                    donorContext = {
                        lifetimeGiving: parseFloat(s.total_given) || 0,
                        giftCount: parseInt(s.total_gifts) || 0,
                        lastGiftDate: s.last_gift_date || null,
                        lastGiftAmount: parseFloat(s.last_gift_amount) || 0,
                        lastFund: s.last_fund || null,
                        firstGiftDate: s.first_gift_date || null,
                    };
                }
                AssignActionModal.open({
                    constituentName: donorName,
                    constituentId: String(constituentId),
                    systemRecordId: s.system_record_id || null,
                    donorContext: donorContext,
                });
            })
            .catch(function() {
                // Open modal even without donor context
                AssignActionModal.open({
                    constituentName: constituentId,
                    constituentId: String(constituentId),
                });
            })
            .finally(function() { btn.disabled = false; });
    });
})();
</script>
<% } %>

<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting" id="donor-name">Donor Detail</div>
        <div class="page-subtitle">Complete giving history for constituent <code><%= constituentId %></code></div>
    </div>
    <a href="javascript:history.back()" class="fr-btn fr-btn-secondary" style="font-size:12px;"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div id="donor-loading" class="crm-loading-container">
    <div class="crm-loading-inner">
        <div class="crm-loading-bars">
            <div class="crm-bar" style="--i:0"></div><div class="crm-bar" style="--i:1"></div>
            <div class="crm-bar" style="--i:2"></div><div class="crm-bar" style="--i:3"></div><div class="crm-bar" style="--i:4"></div>
        </div>
        <div class="crm-loading-text">Loading donor profile...</div>
    </div>
</div>

<style>
.crm-loading-container{display:flex;justify-content:center;align-items:center;min-height:300px;transition:opacity .5s,transform .5s}
.crm-loading-container.fade-out{opacity:0;transform:translateY(-20px)}
.crm-loading-inner{text-align:center}
.crm-loading-bars{display:flex;justify-content:center;align-items:flex-end;gap:6px;height:80px;margin-bottom:24px}
.crm-bar{width:14px;border-radius:4px 4px 0 0;background:var(--color-brand-blue);animation:crm-bar-bounce 1.2s ease-in-out calc(var(--i)*.15s) infinite}
.crm-bar:nth-child(2){background:var(--color-brand-navy)}.crm-bar:nth-child(4){background:var(--color-brand-gold)}.crm-bar:nth-child(5){background:var(--color-brand-navy)}
@keyframes crm-bar-bounce{0%,100%{height:20px;opacity:.5}50%{height:70px;opacity:1}}
.crm-loading-text{font-size:18px;font-weight:600;color:var(--color-text-primary);margin-bottom:8px}
#donor-content{animation:crm-content-in .6s ease both}
@keyframes crm-content-in{0%{opacity:0;transform:translateY(20px)}100%{opacity:1;transform:translateY(0)}}
</style>

<div id="donor-content" style="display:none;"></div>

<script>
(function() {
    const constituentId = <%- JSON.stringify(constituentId) %>;
    var ctrl = new AbortController();
    setTimeout(function() { ctrl.abort(); }, 30000);
    fetch('/crm/donor/' + encodeURIComponent(constituentId) + '/data', { signal: ctrl.signal })
        .then(function(r) { if (!r.ok) throw new Error('Server returned ' + r.status); return r.json(); })
        .then(function(data) {
            if (data.error) throw new Error(data.error);
            render(data);
        })
        .catch(function(err) {
            var msg = err.name === 'AbortError' ? 'Request timed out. The query may be too heavy — try again.' : err.message;
            document.getElementById('donor-loading').innerHTML =
                '<div class="alert-card danger"><div class="alert-card-title">Error</div><div class="alert-card-text">' + msg + '</div></div>';
        });

    function fmt(n) { return Number(n).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}); }
    function esc(s) { if(!s) return ''; const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

    function render(d) {
        const s = d.summary;
        if (!s) {
            document.getElementById('donor-loading').innerHTML = '<div class="alert-card info"><div class="alert-card-title">Donor not found</div></div>';
            return;
        }
        document.getElementById('donor-name').textContent = ((s.first_name || '') + ' ' + (s.last_name || '')).trim() || s.constituent_id || 'Unknown Donor';
        let html = '';

        // KPIs
        html += '<div class="kpi-grid" style="grid-template-columns:repeat(5,minmax(0,1fr));margin-bottom:20px;">' +
            '<div class="kpi-card"><div class="kpi-label">Total Given</div><div class="kpi-value">$' + fmt(s.total_given) + '</div></div>' +
            '<div class="kpi-card"><div class="kpi-label">Total Gifts</div><div class="kpi-value">' + fmt(s.total_gifts) + '</div></div>' +
            '<div class="kpi-card"><div class="kpi-label">Average Gift</div><div class="kpi-value">$' + fmt(s.avg_gift) + '</div></div>' +
            '<div class="kpi-card"><div class="kpi-label">Largest Gift</div><div class="kpi-value">$' + fmt(s.largest_gift) + '</div></div>' +
            '<div class="kpi-card"><div class="kpi-label">Giving Since</div><div class="kpi-value" style="font-size:16px;">' + (s.first_gift_date || 'N/A') + '</div></div></div>';

        // Contact info card
        if (s.email || s.phone || s.address) {
            html += '<div class="fr-card" style="margin-bottom:16px;"><div class="fr-card-body" style="display:flex;flex-wrap:wrap;gap:20px;font-size:13px;">';
            if (s.email) {
                html += '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<i class="bi bi-envelope" style="color:var(--color-text-tertiary);"></i>' +
                    '<a href="mailto:' + esc(s.email) + '">' + esc(s.email) + '</a></div>';
            }
            if (s.phone) {
                html += '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<i class="bi bi-telephone" style="color:var(--color-text-tertiary);"></i>' +
                    '<a href="tel:' + esc(s.phone) + '">' + esc(s.phone) + '</a></div>';
            }
            if (s.address) {
                var addrParts = [s.address, s.city, s.state, s.zip].filter(Boolean);
                if (s.country && s.country !== 'United States' && s.country !== 'US' && s.country !== 'USA') addrParts.push(s.country);
                html += '<div style="display:flex;align-items:center;gap:8px;">' +
                    '<i class="bi bi-geo-alt" style="color:var(--color-text-tertiary);"></i>' +
                    '<span>' + esc(addrParts.join(', ')) + '</span></div>';
            }
            html += '</div></div>';
        }

        // Assigned fundraisers
        if (d.fundraisers && d.fundraisers.length > 0) {
            html += '<div style="margin-bottom:16px;font-size:13px;">' +
                '<span style="font-weight:600;">Fundraiser(s):</span> ' +
                d.fundraisers.map(f => '<a href="/fundraiser-performance?fundraiser=' + encodeURIComponent(f) + '">' + esc(f) + '</a>').join(', ') + '</div>';
        }

        // By FY table
        if (d.byYear && d.byYear.length > 0) {
            html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">';
            html += '<div class="fr-card"><div class="fr-card-body"><div class="section-title" style="margin-bottom:12px;">Giving by Fiscal Year</div>' +
                '<table class="fr-table" style="width:100%;font-size:13px;"><thead><tr><th>FY</th><th style="text-align:right;">Gifts</th><th style="text-align:right;">Total</th></tr></thead><tbody>';
            d.byYear.forEach(y => {
                html += '<tr><td>FY' + y.fy + '</td><td style="text-align:right;">' + fmt(y.gift_count) + '</td>' +
                    '<td style="text-align:right;font-weight:600;">$' + fmt(y.total) + '</td></tr>';
            });
            html += '</tbody></table></div></div>';

            // Bar chart
            const maxY = Math.max(...d.byYear.map(y => Number(y.total)));
            let bars = '';
            [...d.byYear].reverse().forEach(y => {
                const pct = maxY > 0 ? (Number(y.total) / maxY * 100) : 0;
                bars += '<div style="flex:1;display:flex;flex-direction:column;align-items:center;min-width:50px;">' +
                    '<div style="font-size:10px;color:var(--color-text-secondary);margin-bottom:4px;">$' + (Number(y.total)/1000).toFixed(0) + 'K</div>' +
                    '<div style="width:100%;max-width:40px;height:' + Math.max(pct,2) + '%;background:var(--color-brand-blue);border-radius:3px 3px 0 0;"></div>' +
                    '<div style="font-size:10px;color:var(--color-text-secondary);margin-top:4px;">FY' + y.fy + '</div></div>';
            });
            html += '<div class="fr-card"><div class="fr-card-body"><div class="section-title" style="margin-bottom:12px;">Annual Trend</div>' +
                '<div style="display:flex;align-items:flex-end;gap:4px;height:150px;">' + bars + '</div></div></div></div>';
        }

        // Gift history table
        html += '<div class="fr-card" style="margin-bottom:20px;"><div class="fr-card-body">' +
            '<div class="section-title" style="margin-bottom:12px;">Gift History (' + d.gifts.length + ')</div>' +
            '<table class="fr-table" style="width:100%;font-size:13px;"><thead><tr>' +
            '<th>Date</th><th style="text-align:right;">Amount</th><th>Type</th><th>Fund</th><th>Campaign</th><th>Appeal</th></tr></thead><tbody>';
        d.gifts.forEach(g => {
            html += '<tr><td>' + (g.gift_date || '') + '</td>' +
                '<td style="text-align:right;font-weight:600;">$' + fmt(g.gift_amount) + '</td>' +
                '<td>' + esc(g.gift_code) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.fund_id ? '<a href="/crm/fund/' + encodeURIComponent(g.fund_id) + '">' + esc(g.fund_description) + '</a>' : esc(g.fund_description)) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.campaign_id ? '<a href="/crm/campaign/' + encodeURIComponent(g.campaign_id) + '">' + esc(g.campaign_description) + '</a>' : esc(g.campaign_description)) + '</td>' +
                '<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
                (g.appeal_id ? '<a href="/crm/appeal/' + encodeURIComponent(g.appeal_id) + '">' + esc(g.appeal_description) + '</a>' : esc(g.appeal_description)) + '</td></tr>';
        });
        html += '</tbody></table></div></div>';

        const loader = document.getElementById('donor-loading');
        const content = document.getElementById('donor-content');
        loader.classList.add('fade-out');
        setTimeout(() => {
            loader.style.display = 'none';
            content.innerHTML = html;
            content.style.display = 'block';
        }, 400);
    }
})();
</script>

<%- include('../partials/footer') %>

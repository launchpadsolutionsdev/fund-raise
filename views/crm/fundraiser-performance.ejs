<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">Fundraiser Performance</div>
        <div class="page-subtitle">Solicitor leaderboard and portfolio analytics</div>
    </div>
</div>

<% if (!leaderboard || leaderboard.length === 0) { %>
<div class="alert-card info">
    <div class="alert-card-title">No fundraiser data available</div>
    <div class="alert-card-text">
        Your CRM export needs to include fundraiser columns. <a href="/crm-upload">Import data</a> with fundraiser fields.
    </div>
</div>
<% } else { %>

<!-- Fundraiser Leaderboard -->
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Fundraiser Leaderboard</div>
        <table class="fr-table" style="width: 100%; font-size: 13px;">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Fundraiser</th>
                    <th style="text-align:right;">Gifts</th>
                    <th style="text-align:right;">Donors</th>
                    <th style="text-align:right;">Amount Credited</th>
                    <th style="text-align:right;">Gift Total</th>
                    <th>Date Range</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% leaderboard.forEach((f, i) => { %>
                <tr style="<%= selectedFundraiser === f.fundraiser_name ? 'background: var(--color-bg-secondary);' : '' %>">
                    <td><%= i + 1 %></td>
                    <td style="font-weight: 600;"><%= f.fundraiser_name %></td>
                    <td style="text-align:right;"><%= Number(f.gift_count).toLocaleString() %></td>
                    <td style="text-align:right;"><%= Number(f.donor_count).toLocaleString() %></td>
                    <td style="text-align:right; font-weight:600;">$<%= Number(f.total_credited).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                    <td style="text-align:right;">$<%= Number(f.total_gift_amount).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                    <td style="font-size: 11px; color: var(--color-text-secondary);"><%= f.earliest_gift %> — <%= f.latest_gift %></td>
                    <td>
                        <a href="/fundraiser-performance?fundraiser=<%= encodeURIComponent(f.fundraiser_name) %>" class="fr-btn fr-btn-secondary" style="padding: 2px 10px; font-size: 11px;">
                            Portfolio
                        </a>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<!-- Selected Fundraiser Portfolio -->
<% if (selectedFundraiser && portfolio) { %>
<div id="portfolio-section">
    <div class="page-header" style="margin-top: 20px;">
        <div>
            <div class="page-greeting" style="font-size: 22px;"><%= selectedFundraiser %></div>
            <div class="page-subtitle">Portfolio Deep Dive</div>
        </div>
    </div>

    <!-- Portfolio KPIs -->
    <div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr)); margin-bottom: 20px;">
        <div class="kpi-card">
            <div class="kpi-label">Amount Credited</div>
            <div class="kpi-value">$<%= Number(portfolio.summary.total_credited).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Total Gifts</div>
            <div class="kpi-value"><%= Number(portfolio.summary.total_gifts).toLocaleString() %></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Donors Managed</div>
            <div class="kpi-value"><%= Number(portfolio.summary.total_donors).toLocaleString() %></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Avg Gift</div>
            <div class="kpi-value">$<%= Number(portfolio.summary.avg_gift).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <!-- Donors -->
        <div class="fr-card">
            <div class="fr-card-body">
                <div class="section-title" style="margin-bottom: 12px;">Donor Portfolio (<%= portfolio.donors.length %>)</div>
                <table class="fr-table" style="width: 100%; font-size: 13px;">
                    <thead><tr><th>Donor</th><th style="text-align:right;">Gifts</th><th style="text-align:right;">Credited</th><th>Last Gift</th></tr></thead>
                    <tbody>
                        <% portfolio.donors.forEach(d => { %>
                        <tr>
                            <td><%= d.first_name %> <%= d.last_name %></td>
                            <td style="text-align:right;"><%= d.gift_count %></td>
                            <td style="text-align:right; font-weight:600;">$<%= Number(d.total_credited).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                            <td style="font-size: 11px; color: var(--color-text-secondary);"><%= d.last_gift %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- By Fund -->
        <div class="fr-card">
            <div class="fr-card-body">
                <div class="section-title" style="margin-bottom: 12px;">By Fund</div>
                <table class="fr-table" style="width: 100%; font-size: 13px;">
                    <thead><tr><th>Fund</th><th style="text-align:right;">Gifts</th><th style="text-align:right;">Total</th></tr></thead>
                    <tbody>
                        <% portfolio.byFund.forEach(f => { %>
                        <tr>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= f.fund_description %></td>
                            <td style="text-align:right;"><%= f.gift_count %></td>
                            <td style="text-align:right; font-weight:600;">$<%= Number(f.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Monthly Giving Trend -->
    <% if (portfolio.byMonth.length > 0) { %>
    <div class="fr-card" style="margin-bottom: 20px;">
        <div class="fr-card-body">
            <div class="section-title" style="margin-bottom: 12px;">Monthly Giving Trend</div>
            <div style="overflow-x: auto;">
                <div style="display: flex; align-items: flex-end; gap: 2px; height: 150px; min-width: <%= portfolio.byMonth.length * 40 %>px;">
                    <% const maxMonthFr = Math.max(...portfolio.byMonth.map(m => Number(m.total))); %>
                    <% portfolio.byMonth.reverse().forEach(m => { %>
                        <% const pct = maxMonthFr > 0 ? (Number(m.total) / maxMonthFr * 100) : 0; %>
                        <div style="flex: 1; display: flex; flex-direction: column; align-items: center; min-width: 35px;">
                            <div style="font-size: 10px; color: var(--color-text-secondary); margin-bottom: 4px; white-space: nowrap;">
                                $<%= (Number(m.total) / 1000).toFixed(0) %>K
                            </div>
                            <div style="width: 100%; max-width: 30px; height: <%= Math.max(pct, 2) %>%; background: var(--color-primary); border-radius: 3px 3px 0 0;"></div>
                            <div style="font-size: 9px; color: var(--color-text-secondary); margin-top: 4px; transform: rotate(-45deg); white-space: nowrap;">
                                <%= m.month %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
    <% } %>
</div>
<% } %>

<% } %>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">CRM Dashboard</div>
        <div class="page-subtitle">Complete gift analytics from your RE NXT data</div>
    </div>
</div>

<% if (!hasData) { %>
<div class="alert-card info">
    <div class="alert-card-title">No CRM data imported yet</div>
    <div class="alert-card-text">
        <a href="/crm-upload">Import your RE NXT gift export</a> to see analytics here.
    </div>
</div>
<% } else { %>

<!-- Loading Animation -->
<div id="crm-loading" class="crm-loading-container">
    <div class="crm-loading-inner">
        <div class="crm-loading-bars">
            <div class="crm-bar" style="--i:0"></div>
            <div class="crm-bar" style="--i:1"></div>
            <div class="crm-bar" style="--i:2"></div>
            <div class="crm-bar" style="--i:3"></div>
            <div class="crm-bar" style="--i:4"></div>
        </div>
        <div class="crm-loading-text" id="crm-loading-text">Crunching the numbers...</div>
        <div class="crm-loading-dots">
            <span class="crm-dot" style="--d:0"></span>
            <span class="crm-dot" style="--d:1"></span>
            <span class="crm-dot" style="--d:2"></span>
        </div>
    </div>
</div>

<style>
.crm-loading-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 400px;
    transition: opacity 0.5s, transform 0.5s;
}
.crm-loading-container.fade-out {
    opacity: 0;
    transform: translateY(-20px);
}
.crm-loading-inner {
    text-align: center;
}
.crm-loading-bars {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 6px;
    height: 80px;
    margin-bottom: 24px;
}
.crm-bar {
    width: 14px;
    border-radius: 4px 4px 0 0;
    background: var(--color-brand-blue);
    animation: crm-bar-bounce 1.2s ease-in-out calc(var(--i) * 0.15s) infinite;
}
.crm-bar:nth-child(2) { background: var(--color-brand-navy); }
.crm-bar:nth-child(4) { background: var(--color-brand-gold); }
.crm-bar:nth-child(5) { background: var(--color-brand-navy); }
@keyframes crm-bar-bounce {
    0%, 100% { height: 20px; opacity: 0.5; }
    50% { height: 70px; opacity: 1; }
}
.crm-loading-text {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 8px;
    animation: crm-text-fade 0.5s ease;
    min-height: 28px;
}
@keyframes crm-text-fade {
    0% { opacity: 0; transform: translateY(8px); }
    100% { opacity: 1; transform: translateY(0); }
}
.crm-loading-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
}
.crm-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-brand-blue);
    opacity: 0.3;
    animation: crm-dot-pulse 1.4s ease-in-out calc(var(--d) * 0.2s) infinite;
}
@keyframes crm-dot-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.4); }
}

/* Dashboard content entrance */
#crm-content { animation: crm-content-in 0.6s ease both; }
@keyframes crm-content-in {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
}
</style>

<!-- Dashboard Content (hidden until loaded) -->
<div id="crm-content" style="display:none;"></div>

<script>
(function() {
    const phrases = [
        'Crunching the numbers...',
        'Ruminating on your data...',
        'Vibing with the spreadsheets...',
        'Tallying the generosity...',
        'Herding the gift records...',
        'Consulting the data oracle...',
        'Counting every penny...',
        'Summoning the analytics...',
        'Brewing insights...',
        'Almost there...',
    ];

    let phraseIdx = 0;
    const textEl = document.getElementById('crm-loading-text');
    const phraseInterval = setInterval(() => {
        phraseIdx = (phraseIdx + 1) % phrases.length;
        textEl.style.animation = 'none';
        void textEl.offsetWidth; // force reflow
        textEl.textContent = phrases[phraseIdx];
        textEl.style.animation = 'crm-text-fade 0.5s ease';
    }, 2200);

    fetch('/crm-dashboard/data')
        .then(r => r.json())
        .then(data => {
            clearInterval(phraseInterval);
            if (data.error) throw new Error(data.error);
            renderDashboard(data);
        })
        .catch(err => {
            clearInterval(phraseInterval);
            document.getElementById('crm-loading').innerHTML =
                '<div class="alert-card danger"><div class="alert-card-title">Error loading dashboard</div>' +
                '<div class="alert-card-text">' + err.message + '</div></div>';
        });

    function fmt(n) {
        return Number(n).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0});
    }

    function renderDashboard(d) {
        const o = d.overview;
        let html = '';

        // KPI Row 1
        html += '<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">';
        html += kpi('Total Raised', '$' + fmt(o.total_raised), fmt(o.total_gifts) + ' gifts');
        html += kpi('Unique Donors', fmt(o.unique_donors));
        html += kpi('Average Gift', '$' + fmt(o.avg_gift));
        html += kpi('Largest Gift', '$' + fmt(o.largest_gift));
        html += '</div>';

        // KPI Row 2
        html += '<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">';
        html += kpi('Funds', fmt(o.unique_funds));
        html += kpi('Campaigns', fmt(o.unique_campaigns));
        html += kpi('Appeals', fmt(o.unique_appeals));
        html += kpi('Date Range', o.earliest_date, 'to ' + o.latest_date, '16px');
        html += '</div>';

        // Monthly bar chart
        if (d.givingByMonth.length > 0) {
            const maxM = Math.max(...d.givingByMonth.map(m => Number(m.total)));
            let bars = '';
            d.givingByMonth.forEach(m => {
                const pct = maxM > 0 ? (Number(m.total) / maxM * 100) : 0;
                bars += '<div style="flex:1;display:flex;flex-direction:column;align-items:center;min-width:35px;">' +
                    '<div style="font-size:10px;color:var(--color-text-secondary);margin-bottom:4px;white-space:nowrap;">$' + (Number(m.total)/1000).toFixed(0) + 'K</div>' +
                    '<div style="width:100%;max-width:30px;height:' + Math.max(pct,2) + '%;background:var(--color-primary);border-radius:3px 3px 0 0;transition:height 0.3s;"></div>' +
                    '<div style="font-size:9px;color:var(--color-text-secondary);margin-top:4px;transform:rotate(-45deg);white-space:nowrap;">' + m.month + '</div></div>';
            });
            html += '<div class="fr-card" style="margin-bottom:20px;"><div class="fr-card-body">' +
                '<div class="section-title" style="margin-bottom:12px;">Giving by Month</div>' +
                '<div style="overflow-x:auto;"><div style="display:flex;align-items:flex-end;gap:2px;height:200px;min-width:' + (d.givingByMonth.length * 40) + 'px;">' +
                bars + '</div></div></div></div>';
        }

        // Two-column grids
        html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">';
        html += tableCard('Top Donors', ['#','Donor','Gifts','Total'], d.topDonors.map((d2,i) =>
            [i+1, (d2.first_name||'') + ' ' + (d2.last_name||''), d2.gift_count, '$'+fmt(d2.total)]));
        html += tableCard('Top Funds', ['#','Fund','Gifts','Total'], d.topFunds.map((f,i) =>
            [i+1, f.fund_description, f.gift_count, '$'+fmt(f.total)]));
        html += '</div>';

        html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">';
        html += tableCard('Top Campaigns', ['#','Campaign','Gifts','Total'], d.topCampaigns.map((c,i) =>
            [i+1, c.campaign_description, c.gift_count, '$'+fmt(c.total)]));
        html += tableCard('Top Appeals', ['#','Appeal','Gifts','Total'], d.topAppeals.map((a,i) =>
            [i+1, a.appeal_description, a.gift_count, '$'+fmt(a.total)]));
        html += '</div>';

        // Gift types
        if (d.giftsByType.length > 0) {
            let chips = '';
            d.giftsByType.forEach(t => {
                chips += '<div style="padding:8px 16px;background:var(--color-bg-secondary);border-radius:8px;text-align:center;">' +
                    '<div style="font-weight:600;font-size:16px;">$' + fmt(t.total) + '</div>' +
                    '<div style="font-size:11px;color:var(--color-text-secondary);">' + t.gift_type + ' (' + t.gift_count + ')</div></div>';
            });
            html += '<div class="fr-card" style="margin-bottom:20px;"><div class="fr-card-body">' +
                '<div class="section-title" style="margin-bottom:12px;">Giving by Type</div>' +
                '<div style="display:flex;flex-wrap:wrap;gap:12px;">' + chips + '</div></div></div>';
        }

        // Swap in
        const loader = document.getElementById('crm-loading');
        const content = document.getElementById('crm-content');
        loader.classList.add('fade-out');
        setTimeout(() => {
            loader.style.display = 'none';
            content.innerHTML = html;
            content.style.display = 'block';
        }, 500);
    }

    function kpi(label, value, sub, fontSize) {
        return '<div class="kpi-card"><div class="kpi-label">' + label + '</div>' +
            '<div class="kpi-value"' + (fontSize ? ' style="font-size:' + fontSize + ';"' : '') + '>' + value + '</div>' +
            (sub ? '<div class="kpi-change info">' + sub + '</div>' : '') + '</div>';
    }

    function tableCard(title, headers, rows) {
        let h = '<div class="fr-card"><div class="fr-card-body">' +
            '<div class="section-title" style="margin-bottom:12px;">' + title + '</div>' +
            '<table class="fr-table" style="width:100%;font-size:13px;"><thead><tr>';
        headers.forEach((hdr, i) => {
            const align = i === headers.length - 1 ? ' style="text-align:right;"' : '';
            h += '<th' + align + '>' + hdr + '</th>';
        });
        h += '</tr></thead><tbody>';
        rows.forEach(row => {
            h += '<tr>';
            row.forEach((cell, i) => {
                const style = i === row.length - 1 ? ' style="text-align:right;font-weight:600;"' :
                              (i === 1 ? ' style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"' : '');
                h += '<td' + style + '>' + (cell != null ? cell : '') + '</td>';
            });
            h += '</tr>';
        });
        h += '</tbody></table></div></div>';
        return h;
    }
})();
</script>

<% } %>

<%- include('../partials/footer') %>

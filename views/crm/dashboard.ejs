<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting">CRM Dashboard</div>
        <div class="page-subtitle">Complete gift analytics from your RE NXT data</div>
    </div>
</div>

<% if (!hasData) { %>
<div class="alert-card info">
    <div class="alert-card-title">No CRM data imported yet</div>
    <div class="alert-card-text">
        <a href="/crm-upload">Import your RE NXT gift export</a> to see analytics here.
    </div>
</div>
<% } else { %>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Total Raised</div>
        <div class="kpi-value">$<%= Number(overview.total_raised).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
        <div class="kpi-change info"><%= Number(overview.total_gifts).toLocaleString() %> gifts</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Unique Donors</div>
        <div class="kpi-value"><%= Number(overview.unique_donors).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Average Gift</div>
        <div class="kpi-value">$<%= Number(overview.avg_gift).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Largest Gift</div>
        <div class="kpi-value">$<%= Number(overview.largest_gift).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
</div>

<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Funds</div>
        <div class="kpi-value"><%= Number(overview.unique_funds).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Campaigns</div>
        <div class="kpi-value"><%= Number(overview.unique_campaigns).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Appeals</div>
        <div class="kpi-value"><%= Number(overview.unique_appeals).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Date Range</div>
        <div class="kpi-value" style="font-size: 16px;"><%= overview.earliest_date %></div>
        <div class="kpi-change info">to <%= overview.latest_date %></div>
    </div>
</div>

<!-- Giving by Month Chart -->
<% if (givingByMonth.length > 0) { %>
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Giving by Month</div>
        <div style="overflow-x: auto;">
            <div style="display: flex; align-items: flex-end; gap: 2px; height: 200px; min-width: <%= givingByMonth.length * 40 %>px;">
                <% const maxMonth = Math.max(...givingByMonth.map(m => Number(m.total))); %>
                <% givingByMonth.forEach(m => { %>
                    <% const pct = maxMonth > 0 ? (Number(m.total) / maxMonth * 100) : 0; %>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; min-width: 35px;">
                        <div style="font-size: 10px; color: var(--color-text-secondary); margin-bottom: 4px; white-space: nowrap;">
                            $<%= (Number(m.total) / 1000).toFixed(0) %>K
                        </div>
                        <div style="width: 100%; max-width: 30px; height: <%= Math.max(pct, 2) %>%; background: var(--color-primary); border-radius: 3px 3px 0 0; transition: height 0.3s;"></div>
                        <div style="font-size: 9px; color: var(--color-text-secondary); margin-top: 4px; transform: rotate(-45deg); white-space: nowrap;">
                            <%= m.month %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</div>
<% } %>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
    <!-- Top Donors -->
    <div class="fr-card">
        <div class="fr-card-body">
            <div class="section-title" style="margin-bottom: 12px;">Top Donors</div>
            <table class="fr-table" style="width: 100%; font-size: 13px;">
                <thead><tr><th>#</th><th>Donor</th><th>Gifts</th><th style="text-align:right;">Total</th></tr></thead>
                <tbody>
                    <% topDonors.forEach((d, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td><%= d.first_name %> <%= d.last_name %></td>
                        <td><%= d.gift_count %></td>
                        <td style="text-align:right; font-weight:600;">$<%= Number(d.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top Funds -->
    <div class="fr-card">
        <div class="fr-card-body">
            <div class="section-title" style="margin-bottom: 12px;">Top Funds</div>
            <table class="fr-table" style="width: 100%; font-size: 13px;">
                <thead><tr><th>#</th><th>Fund</th><th>Gifts</th><th style="text-align:right;">Total</th></tr></thead>
                <tbody>
                    <% topFunds.forEach((f, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= f.fund_description %></td>
                        <td><%= f.gift_count %></td>
                        <td style="text-align:right; font-weight:600;">$<%= Number(f.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
    <!-- Top Campaigns -->
    <div class="fr-card">
        <div class="fr-card-body">
            <div class="section-title" style="margin-bottom: 12px;">Top Campaigns</div>
            <table class="fr-table" style="width: 100%; font-size: 13px;">
                <thead><tr><th>#</th><th>Campaign</th><th>Gifts</th><th style="text-align:right;">Total</th></tr></thead>
                <tbody>
                    <% topCampaigns.forEach((c, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= c.campaign_description %></td>
                        <td><%= c.gift_count %></td>
                        <td style="text-align:right; font-weight:600;">$<%= Number(c.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top Appeals -->
    <div class="fr-card">
        <div class="fr-card-body">
            <div class="section-title" style="margin-bottom: 12px;">Top Appeals</div>
            <table class="fr-table" style="width: 100%; font-size: 13px;">
                <thead><tr><th>#</th><th>Appeal</th><th>Gifts</th><th style="text-align:right;">Total</th></tr></thead>
                <tbody>
                    <% topAppeals.forEach((a, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= a.appeal_description %></td>
                        <td><%= a.gift_count %></td>
                        <td style="text-align:right; font-weight:600;">$<%= Number(a.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Gift Types -->
<div class="fr-card" style="margin-bottom: 20px;">
    <div class="fr-card-body">
        <div class="section-title" style="margin-bottom: 12px;">Giving by Type</div>
        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
            <% giftsByType.forEach(t => { %>
            <div style="padding: 8px 16px; background: var(--color-bg-secondary); border-radius: 8px; text-align: center;">
                <div style="font-weight: 600; font-size: 16px;">$<%= Number(t.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div style="font-size: 11px; color: var(--color-text-secondary);"><%= t.gift_type %> (<%= t.gift_count %>)</div>
            </div>
            <% }); %>
        </div>
    </div>
</div>

<% } %>

<%- include('../partials/footer') %>

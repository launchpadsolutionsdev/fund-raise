<%- include('../partials/header') %>

<div class="fr-hero">
    <div class="fr-hero-icon"><i class="bi bi-shield-check"></i></div>
    <div class="fr-hero-text">
        <h2>Data Quality</h2>
        <p>Audit your CRM data for completeness, duplicates, and anomalies.</p>
        <div class="fr-hero-chips">
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Completeness</span>
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Duplicates</span>
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Anomalies</span>
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Field Coverage</span>
        </div>
    </div>
</div>

<div id="dq-loading" class="crm-loading-container">
    <div class="crm-loading-inner">
        <div class="crm-loading-bars">
            <div class="crm-bar" style="--i:0"></div><div class="crm-bar" style="--i:1"></div>
            <div class="crm-bar" style="--i:2"></div><div class="crm-bar" style="--i:3"></div><div class="crm-bar" style="--i:4"></div>
        </div>
        <div class="crm-loading-text">Scanning data quality...</div>
    </div>
</div>

<style>
.crm-loading-container{display:flex;justify-content:center;align-items:center;min-height:400px;transition:opacity .5s,transform .5s}
.crm-loading-container.fade-out{opacity:0;transform:translateY(-20px)}
.crm-loading-inner{text-align:center}
.crm-loading-bars{display:flex;justify-content:center;align-items:flex-end;gap:6px;height:80px;margin-bottom:24px}
.crm-bar{width:14px;border-radius:4px 4px 0 0;background:var(--color-brand-blue);animation:crm-bar-bounce 1.2s ease-in-out calc(var(--i)*.15s) infinite}
.crm-bar:nth-child(2){background:var(--color-brand-navy)}.crm-bar:nth-child(4){background:var(--color-brand-gold)}.crm-bar:nth-child(5){background:var(--color-brand-navy)}
@keyframes crm-bar-bounce{0%,100%{height:20px;opacity:.5}50%{height:70px;opacity:1}}
.crm-loading-text{font-size:18px;font-weight:600;color:var(--color-text-primary)}
#dq-content{animation:crm-content-in .6s ease both}
@keyframes crm-content-in{0%{opacity:0;transform:translateY(20px)}100%{opacity:1;transform:translateY(0)}}
.dq-score{width:120px;height:120px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 12px;border:6px solid;transition:all .3s}
.dq-score-value{font-size:32px;font-weight:800;line-height:1}
.dq-score-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.dq-field-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--color-border-primary)}
.dq-field-row:last-child{border-bottom:none}
.dq-field-name{width:180px;font-size:13px;font-weight:600;color:var(--color-text-primary)}
.dq-field-bar{flex:1;height:10px;background:var(--color-background-secondary);border-radius:5px;overflow:hidden}
.dq-field-fill{height:100%;border-radius:5px;transition:width .6s ease}
.dq-field-pct{width:60px;text-align:right;font-size:12px;font-weight:700}
.dq-field-count{width:80px;text-align:right;font-size:12px;color:var(--color-text-secondary)}
.dq-issue-badge{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:600;padding:4px 10px;border-radius:6px}
.dq-issue-badge.danger{background:#fef2f2;color:#dc2626}
.dq-issue-badge.warning{background:#fffbeb;color:#d97706}
.dq-issue-badge.success{background:#f0fdf4;color:#16a34a}
</style>

<div id="dq-content" style="display:none;"></div>

<script>
(function() {
    function fmt(n) { return Number(n).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}); }
    function esc(s) { if(!s) return ''; var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
    function pct(n, total) { return total > 0 ? (n / total * 100).toFixed(1) : '0.0'; }
    function completePct(missing, total) { return total > 0 ? ((total - missing) / total * 100).toFixed(1) : '100.0'; }
    function fillColor(p) { return p >= 95 ? '#16a34a' : p >= 80 ? '#0072BB' : p >= 60 ? '#d97706' : '#dc2626'; }

    fetch('/crm/data-quality/data')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) throw new Error(data.error);
            render(data);
        })
        .catch(function(err) {
            document.getElementById('dq-loading').innerHTML =
                '<div class="alert-card danger"><div class="alert-card-title">Error</div><div class="alert-card-text">' + err.message + '</div></div>';
        });

    function render(data) {
        var total = Number(data.total_gifts) || 0;
        if (total === 0) {
            show('<div class="alert-card info"><div class="alert-card-title">No data</div>' +
                '<div class="alert-card-text">Import CRM data to see a quality report.</div></div>');
            return;
        }

        // Calculate overall health score
        var coreFields = [
            { name: 'Gift Date', missing: Number(data.missing_date), icon: 'calendar3', critical: true },
            { name: 'Gift Amount', missing: Number(data.missing_amount), icon: 'currency-dollar', critical: true },
            { name: 'Constituent ID', missing: Number(data.missing_constituent), icon: 'person', critical: true },
            { name: 'Donor Name', missing: Number(data.missing_name), icon: 'person-badge', critical: true },
            { name: 'Fund', missing: Number(data.missing_fund), icon: 'bank', critical: false },
            { name: 'Campaign', missing: Number(data.missing_campaign), icon: 'megaphone', critical: false },
            { name: 'Appeal', missing: Number(data.missing_appeal), icon: 'envelope', critical: false },
            { name: 'Gift Code', missing: Number(data.missing_gift_code), icon: 'tag', critical: false },
            { name: 'Appeal Category', missing: Number(data.missing_appeal_category), icon: 'bookmark', critical: false },
            { name: 'Fund Category', missing: Number(data.missing_fund_category), icon: 'folder', critical: false },
        ];

        // Weighted score: critical fields count double
        var totalWeight = 0, filledWeight = 0;
        coreFields.forEach(function(f) {
            var w = f.critical ? 2 : 1;
            totalWeight += w;
            filledWeight += w * ((total - f.missing) / total);
        });
        var score = Math.round(filledWeight / totalWeight * 100);
        var scoreColor = score >= 90 ? '#16a34a' : score >= 70 ? '#0072BB' : score >= 50 ? '#d97706' : '#dc2626';
        var scoreLabel = score >= 90 ? 'Excellent' : score >= 70 ? 'Good' : score >= 50 ? 'Needs Work' : 'Poor';

        var html = '';

        // Score + Summary row
        html += '<div style="display:grid;grid-template-columns:200px 1fr;gap:24px;margin-bottom:24px;">';

        // Score circle
        html += '<div class="fr-card"><div class="fr-card-body" style="text-align:center;padding:24px 16px;">' +
            '<div class="dq-score" style="border-color:' + scoreColor + ';">' +
            '<div class="dq-score-value" style="color:' + scoreColor + ';">' + score + '</div>' +
            '<div class="dq-score-label" style="color:' + scoreColor + ';">' + scoreLabel + '</div></div>' +
            '<div style="font-size:13px;font-weight:600;color:var(--color-text-primary);">Data Health Score</div>' +
            '<div style="font-size:12px;color:var(--color-text-secondary);margin-top:4px;">' + fmt(total) + ' total gifts</div>' +
            '<div style="font-size:12px;color:var(--color-text-secondary);">' + fmt(data.unique_constituents) + ' unique donors</div>' +
            '</div></div>';

        // Issue summary cards
        html += '<div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">';

        var issues = [
            { label: 'Negative Amounts', count: Number(data.negative_amounts), icon: 'exclamation-triangle', level: 'danger' },
            { label: 'Future Dates', count: Number(data.future_dates), icon: 'clock-history', level: 'danger' },
            { label: 'Very Old Dates (pre-1990)', count: Number(data.very_old_dates), icon: 'calendar-x', level: 'warning' },
            { label: 'Potential Duplicate Gifts', count: Number(data.duplicate_gifts), icon: 'files', level: 'warning' },
            { label: 'Possible Duplicate Donors', count: Number(data.duplicate_constituents), icon: 'people', level: 'warning' },
        ];

        issues.forEach(function(issue) {
            var level = issue.count > 0 ? issue.level : 'success';
            var bg = level === 'danger' ? '#fef2f2' : level === 'warning' ? '#fffbeb' : '#f0fdf4';
            var color = level === 'danger' ? '#dc2626' : level === 'warning' ? '#d97706' : '#16a34a';
            html += '<div class="fr-card" style="border-left:3px solid ' + color + ';"><div class="fr-card-body" style="padding:14px;">' +
                '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">' +
                '<i class="bi bi-' + issue.icon + '" style="color:' + color + ';"></i>' +
                '<span style="font-size:12px;font-weight:600;color:var(--color-text-secondary);">' + issue.label + '</span></div>' +
                '<div style="font-size:22px;font-weight:800;color:' + color + ';">' + fmt(issue.count) + '</div>' +
                (issue.count > 0 ? '<div style="font-size:11px;color:var(--color-text-secondary);">' + pct(issue.count, total) + '% of gifts</div>' : '<div style="font-size:11px;color:#16a34a;">None found</div>') +
                '</div></div>';
        });

        html += '</div></div></div>';

        // Field completeness
        html += '<div class="fr-card" style="margin-bottom:24px;"><div class="fr-card-body">' +
            '<div class="section-title" style="margin-bottom:16px;">Field Completeness</div>';

        coreFields.forEach(function(f) {
            var cp = Number(completePct(f.missing, total));
            var color = fillColor(cp);
            html += '<div class="dq-field-row">' +
                '<div class="dq-field-name"><i class="bi bi-' + f.icon + '" style="margin-right:6px;color:' + color + ';"></i>' + f.name +
                (f.critical ? ' <span style="font-size:9px;color:#dc2626;font-weight:700;">CORE</span>' : '') + '</div>' +
                '<div class="dq-field-bar"><div class="dq-field-fill" style="width:' + cp + '%;background:' + color + ';"></div></div>' +
                '<div class="dq-field-pct" style="color:' + color + ';">' + cp + '%</div>' +
                '<div class="dq-field-count">' + (f.missing > 0 ? fmt(f.missing) + ' missing' : '<span style="color:#16a34a;">Complete</span>') + '</div>' +
                '</div>';
        });

        html += '</div></div>';

        // Sample records with most issues
        var samples = data.sampleBadRecords || [];
        if (samples.length > 0 && Number(samples[0].issue_count) > 0) {
            html += '<div class="fr-card" style="margin-bottom:24px;"><div class="fr-card-body">' +
                '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">' +
                '<div class="section-title">Records Needing Attention</div>' +
                '<span style="font-size:12px;color:var(--color-text-secondary);">Sorted by number of missing fields</span></div>' +
                '<div style="overflow-x:auto;"><table class="fr-table" style="width:100%;font-size:12px;"><thead><tr>' +
                '<th>Gift ID</th><th>Donor</th><th style="text-align:right;">Amount</th><th>Date</th>' +
                '<th>Fund</th><th>Campaign</th><th>Appeal</th><th>Code</th><th style="text-align:center;">Issues</th>' +
                '</tr></thead><tbody>';

            samples.forEach(function(r) {
                if (Number(r.issue_count) === 0) return;
                var rawName = ((r.first_name || '') + ' ' + (r.last_name || '')).trim();
                var nameHtml = rawName ? esc(rawName) : '<em style="color:var(--color-text-tertiary);">Missing</em>';
                var link = r.constituent_id ? '<a href="/crm/donor/' + encodeURIComponent(r.constituent_id) + '">' + nameHtml + '</a>' : nameHtml;

                function cell(val) {
                    if (!val || val === '') return '<td style="color:#dc2626;"><i class="bi bi-x-circle-fill" style="font-size:10px;"></i></td>';
                    return '<td style="max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + esc(val) + '">' + esc(val) + '</td>';
                }

                html += '<tr>' +
                    '<td style="font-weight:600;">' + esc(r.gift_id) + '</td>' +
                    '<td>' + link + '</td>' +
                    '<td style="text-align:right;">' + (r.gift_amount != null ? '$' + fmt(r.gift_amount) : '<span style="color:#dc2626;">Missing</span>') + '</td>' +
                    '<td>' + (r.gift_date || '<span style="color:#dc2626;">Missing</span>') + '</td>' +
                    cell(r.fund_id) + cell(r.campaign_id) + cell(r.appeal_id) + cell(r.gift_code) +
                    '<td style="text-align:center;"><span class="dq-issue-badge danger">' + r.issue_count + '</span></td></tr>';
            });

            html += '</tbody></table></div></div></div>';
        }

        // Tips
        html += '<div class="fr-card"><div class="fr-card-body">' +
            '<div class="section-title" style="margin-bottom:12px;"><i class="bi bi-lightbulb" style="color:var(--color-brand-gold);margin-right:6px;"></i>Recommendations</div>' +
            '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:13px;">';

        var tips = [];
        if (Number(data.missing_constituent) > 0) tips.push({ icon: 'person-exclamation', text: '<strong>' + fmt(data.missing_constituent) + ' gifts</strong> have no Constituent ID — these cannot be linked to donors for retention or scoring analysis.' });
        if (Number(data.missing_fund) > total * 0.2) tips.push({ icon: 'bank', text: '<strong>' + pct(data.missing_fund, total) + '%</strong> of gifts are missing Fund data. This limits fund health and campaign comparison reports.' });
        if (Number(data.missing_appeal_category) > total * 0.3) tips.push({ icon: 'bookmark', text: '<strong>' + pct(data.missing_appeal_category, total) + '%</strong> are missing Appeal Category. Department classification relies heavily on this field.' });
        if (Number(data.duplicate_gifts) > 0) tips.push({ icon: 'files', text: '<strong>' + fmt(data.duplicate_gifts) + ' gift groups</strong> share the same donor + amount + date, which may be duplicates. Review in your CRM.' });
        if (Number(data.duplicate_constituents) > 0) tips.push({ icon: 'people', text: '<strong>' + fmt(data.duplicate_constituents) + ' name groups</strong> may be duplicate donor records (same last name + first initial, different IDs).' });
        if (Number(data.negative_amounts) > 0) tips.push({ icon: 'dash-circle', text: '<strong>' + fmt(data.negative_amounts) + ' negative amounts</strong> found. These may be refunds or reversals — verify they are intentional.' });
        if (tips.length === 0) tips.push({ icon: 'check-circle', text: 'Your data looks clean! Keep up the good work maintaining your CRM records.' });

        tips.forEach(function(tip) {
            html += '<div style="display:flex;gap:8px;padding:10px;background:var(--color-background-secondary);border-radius:8px;">' +
                '<i class="bi bi-' + tip.icon + '" style="color:var(--color-brand-blue);flex-shrink:0;margin-top:2px;"></i>' +
                '<span>' + tip.text + '</span></div>';
        });

        html += '</div></div></div>';

        show(html);
    }

    function show(html) {
        var loader = document.getElementById('dq-loading');
        var content = document.getElementById('dq-content');
        if (loader.style.display !== 'none') {
            loader.classList.add('fade-out');
            setTimeout(function() { loader.style.display = 'none'; content.innerHTML = html; content.style.display = 'block'; }, 400);
        } else { content.innerHTML = html; content.style.display = 'block'; }
    }
})();
</script>

<%- include('../partials/footer') %>

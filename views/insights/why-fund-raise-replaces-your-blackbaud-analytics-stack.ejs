                    <td>30+ built-in dashboards</td>
                </tr>
                <tr>
                    <td>MissionBI / Zuri Aqueduct</td>
                    <td class="cost-old">$3,000&ndash;$10,000/yr</td>
                    <td>Direct CSV import to PostgreSQL</td>
                </tr>
                <tr>
                    <td>Crystal Reports</td>
                    <td class="cost-old">$500&ndash;$1,500/yr</td>
                    <td>10 one-click PDF reports</td>
                </tr>
                <tr>

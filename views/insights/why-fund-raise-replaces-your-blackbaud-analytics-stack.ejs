                    <td class="cost-old">$1,000&ndash;$4,000/yr</td>
                    <td>Native in-app visualizations</td>
                </tr>
                <tr>
                    <td>Excel exports &amp; manual work</td>
                    <td class="cost-old">$4,800/yr (staff time)</td>
                    <td>AI queries + one-click reports</td>
                </tr>
                <tr>
                    <td>Standalone AI tools</td>

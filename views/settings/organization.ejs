<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting"><i class="bi bi-building"></i> Organization Profile</div>
        <div class="page-subtitle">Manage your organization's details and branding</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:300px 1fr;gap:24px;align-items:start;">

    <!-- Preview card -->
    <div class="fr-card" id="previewCard" style="position:sticky;top:24px;">
        <div class="fr-card-body" style="text-align:center;padding:28px 20px;">
            <div id="previewLogo" style="width:80px;height:80px;border-radius:12px;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;background:var(--color-bg-secondary);overflow:hidden;">
                <% if (tenant.logoPath) { %>
                <img src="/uploads/logos/<%= tenant.logoPath %>" alt="Logo" style="width:100%;height:100%;object-fit:cover;" id="previewLogoImg">
                <% } else { %>
                <i class="bi bi-building" style="font-size:36px;color:var(--color-text-tertiary);" id="previewLogoIcon"></i>
                <% } %>
            </div>
            <div id="previewName" style="font-weight:600;font-size:16px;color:var(--color-text-primary);margin-bottom:6px;"><%= tenant.name %></div>
            <div id="previewMission" style="font-size:12px;color:var(--color-text-secondary);line-height:1.5;"><%= tenant.missionStatement || '' %></div>
        </div>
    </div>

    <!-- Edit form -->
    <div>
        <!-- Logo section -->
        <div class="fr-card" style="margin-bottom:18px;">
            <div class="fr-card-body" style="padding:20px 24px;">
                <h4 style="margin:0 0 14px;font-size:14px;font-weight:600;color:var(--color-text-primary);">Logo</h4>
                <div style="display:flex;align-items:center;gap:16px;">
                    <div id="logoCurrent" style="width:64px;height:64px;border-radius:10px;background:var(--color-bg-secondary);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;">
                        <% if (tenant.logoPath) { %>
                        <img src="/uploads/logos/<%= tenant.logoPath %>" alt="Current logo" style="width:100%;height:100%;object-fit:cover;">
                        <% } else { %>
                        <i class="bi bi-building" style="font-size:28px;color:var(--color-text-tertiary);"></i>
                        <% } %>
                    </div>
                    <div>
                        <label class="fr-btn fr-btn-secondary" style="cursor:pointer;padding:8px 14px;font-size:12px;display:inline-block;">
                            <i class="bi bi-upload"></i> Upload Logo
                            <input type="file" id="logoInput" accept="image/*" style="display:none;">
                        </label>
                        <div style="font-size:11px;color:var(--color-text-tertiary);margin-top:4px;">JPG, PNG, or GIF. Max 5 MB.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Organization Details -->
        <div class="fr-card" style="margin-bottom:18px;">
            <div class="fr-card-body" style="padding:20px 24px;">
                <h4 style="margin:0 0 14px;font-size:14px;font-weight:600;color:var(--color-text-primary);">Organization Details</h4>

                <div style="margin-bottom:14px;">
                    <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Organization Name</label>
                    <input type="text" id="orgName" value="<%= tenant.name %>" disabled
                        style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;background:var(--color-bg-secondary);color:var(--color-text-tertiary);cursor:not-allowed;">
                    <div style="font-size:11px;color:var(--color-text-tertiary);margin-top:3px;">Contact support to change your organization name</div>
                </div>

                <div style="margin-bottom:14px;">
                    <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Mission Statement</label>
                    <textarea id="missionStatement" maxlength="500" rows="4" placeholder="Describe your organization's mission..."
                        style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;resize:vertical;"><%= tenant.missionStatement || '' %></textarea>
                    <div style="font-size:11px;color:var(--color-text-tertiary);margin-top:3px;"><span id="missionCount"><%= (tenant.missionStatement || '').length %></span>/500 characters</div>
                </div>

                <div style="margin-bottom:0;">
                    <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Fiscal Year Start Month</label>
                    <select id="fiscalYearStart"
                        style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                        <% const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>
                        <% months.forEach((m, i) => { %>
                        <option value="<%= i+1 %>" <%= (tenant.fiscalYearStart || 4) === (i+1) ? 'selected' : '' %>><%= m %></option>
                        <% }); %>
                    </select>
                </div>
            </div>
        </div>

        <!-- Contact Information -->
        <div class="fr-card" style="margin-bottom:18px;">
            <div class="fr-card-body" style="padding:20px 24px;">
                <h4 style="margin:0 0 14px;font-size:14px;font-weight:600;color:var(--color-text-primary);">Contact Information</h4>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
                    <div>
                        <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Phone</label>
                        <input type="tel" id="phone" value="<%= tenant.phone || '' %>" maxlength="30" placeholder="(555) 123-4567"
                            style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                    </div>
                    <div>
                        <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Website</label>
                        <input type="url" id="website" value="<%= tenant.website || '' %>" maxlength="255" placeholder="https://example.org"
                            style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                    </div>
                    <div>
                        <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">EIN (Tax ID)</label>
                        <input type="text" id="ein" value="<%= tenant.ein || '' %>" maxlength="20" placeholder="XX-XXXXXXX"
                            style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Address -->
        <div class="fr-card" style="margin-bottom:18px;">
            <div class="fr-card-body" style="padding:20px 24px;">
                <h4 style="margin:0 0 14px;font-size:14px;font-weight:600;color:var(--color-text-primary);">Address</h4>

                <div style="margin-bottom:14px;">
                    <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Address Line 1</label>
                    <input type="text" id="addressLine1" value="<%= tenant.addressLine1 || '' %>" maxlength="255" placeholder="123 Main Street"
                        style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                </div>

                <div style="margin-bottom:14px;">
                    <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">Address Line 2</label>
                    <input type="text" id="addressLine2" value="<%= tenant.addressLine2 || '' %>" maxlength="255" placeholder="Suite 100"
                        style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                </div>

                <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:14px;">
                    <div>
                        <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">City</label>
                        <input type="text" id="city" value="<%= tenant.city || '' %>" maxlength="100" placeholder="City"
                            style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                    </div>
                    <div>
                        <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">State</label>
                        <input type="text" id="state" value="<%= tenant.state || '' %>" maxlength="50" placeholder="State"
                            style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                    </div>
                    <div>
                        <label style="display:block;font-size:12px;font-weight:500;color:var(--color-text-secondary);margin-bottom:4px;">ZIP Code</label>
                        <input type="text" id="zip" value="<%= tenant.zip || '' %>" maxlength="20" placeholder="12345"
                            style="width:100%;padding:8px 12px;border:1px solid var(--color-border-primary);border-radius:6px;font-family:'Manrope',sans-serif;font-size:13px;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Save -->
        <button class="fr-btn fr-btn-primary" id="saveBtn" style="width:100%;padding:10px;font-size:14px;">
            <i class="bi bi-check-lg"></i> Save Organization Profile
        </button>
        <div id="saveSuccess" style="display:none;text-align:center;padding:10px;margin-top:10px;color:var(--color-success, #22c55e);font-size:13px;font-weight:500;">
            Organization profile saved!
        </div>
    </div>
</div>

<script>
(function() {
    const missionInput = document.getElementById('missionStatement');
    const missionCount = document.getElementById('missionCount');
    const saveBtn = document.getElementById('saveBtn');
    const saveSuccess = document.getElementById('saveSuccess');
    const logoInput = document.getElementById('logoInput');

    // Live preview
    missionInput.addEventListener('input', function() {
        document.getElementById('previewMission').textContent = this.value;
        missionCount.textContent = this.value.length;
    });

    // Fetch current data and populate form
    fetch('/api/organization')
        .then(r => r.json())
        .then(data => {
            if (data.error) return;
            // Fields are already populated via EJS, but sync any server-side values
            if (data.missionStatement) missionInput.value = data.missionStatement;
            if (data.phone) document.getElementById('phone').value = data.phone;
            if (data.website) document.getElementById('website').value = data.website;
            if (data.ein) document.getElementById('ein').value = data.ein;
            if (data.addressLine1) document.getElementById('addressLine1').value = data.addressLine1;
            if (data.addressLine2) document.getElementById('addressLine2').value = data.addressLine2;
            if (data.city) document.getElementById('city').value = data.city;
            if (data.state) document.getElementById('state').value = data.state;
            if (data.zip) document.getElementById('zip').value = data.zip;
            if (data.fiscalYearStart) document.getElementById('fiscalYearStart').value = data.fiscalYearStart;
        })
        .catch(() => {});

    // Save
    saveBtn.addEventListener('click', function() {
        saveBtn.disabled = true;
        fetch('/api/organization', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                missionStatement: missionInput.value,
                addressLine1: document.getElementById('addressLine1').value,
                addressLine2: document.getElementById('addressLine2').value,
                city: document.getElementById('city').value,
                state: document.getElementById('state').value,
                zip: document.getElementById('zip').value,
                phone: document.getElementById('phone').value,
                website: document.getElementById('website').value,
                ein: document.getElementById('ein').value,
                fiscalYearStart: document.getElementById('fiscalYearStart').value,
            }),
        })
        .then(r => r.json())
        .then(data => {
            if (data.error) throw new Error(data.error);
            saveSuccess.style.display = 'block';
            setTimeout(() => { saveSuccess.style.display = 'none'; }, 3000);
        })
        .catch(err => frAlert('Error: ' + err.message, { variant: 'danger', title: 'Error' }))
        .finally(() => { saveBtn.disabled = false; });
    });

    // Logo upload
    logoInput.addEventListener('change', function() {
        if (!this.files[0]) return;
        const formData = new FormData();
        formData.append('logo', this.files[0]);

        fetch('/api/organization/logo', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(data => {
                if (data.error) throw new Error(data.error);
                const ts = Date.now();
                const imgHtml = '<img src="' + data.logoSrc + '?' + ts + '" alt="Logo" style="width:100%;height:100%;object-fit:cover;">';
                document.getElementById('logoCurrent').innerHTML = imgHtml;
                document.getElementById('previewLogo').innerHTML =
                    '<img src="' + data.logoSrc + '?' + ts + '" alt="Logo" style="width:100%;height:100%;object-fit:cover;" id="previewLogoImg">';
            })
            .catch(err => frAlert('Upload error: ' + err.message, { variant: 'danger', title: 'Error' }));
    });
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

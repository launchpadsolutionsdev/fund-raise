<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Fund-Raise</title>
    <link rel="icon" type="image/svg+xml" href="/fund-raise-icon-accent (1).svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1a1a1a;
        }

        .login-card {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06), 0 0 1px rgba(0, 0, 0, 0.1);
            padding: 48px 44px;
            max-width: 420px;
            width: 100%;
            text-align: center;
        }

        .login-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        .login-logo img {
            width: 44px;
            height: 44px;
        }

        .login-logo-text {
            font-size: 26px;
            font-weight: 700;
            background: linear-gradient(135deg, #0072BB, #143D8D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.2;
        }

        .login-heading {
            font-size: 22px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 6px;
        }

        .login-subheading {
            font-size: 14px;
            font-weight: 400;
            color: #6b7280;
            margin-bottom: 32px;
        }

        .login-flash {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
            background: #FCEBEB;
            color: #dc2626;
            text-align: left;
            border: 1px solid rgba(220, 38, 38, 0.15);
        }

        .btn-auth {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 13px 20px;
            background: #FFFFFF;
            color: #1a1a1a;
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
        }

        .btn-auth:hover {
            background: #f9fafb;
            border-color: #d1d5db;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
            color: #1a1a1a;
        }

        .btn-auth + .btn-auth {
            margin-top: 12px;
        }

        .btn-auth svg {
            flex-shrink: 0;
        }

        .login-footer {
            font-size: 12px;
            font-weight: 400;
            color: #9ca3af;
            margin-top: 24px;
            line-height: 1.5;
        }

        @media (max-width: 480px) {
            .login-card {
                margin: 16px;
                padding: 36px 24px;
            }
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <img src="/images/fund-raise-icon-flat.svg" alt="Fund-Raise">
            <span class="login-logo-text">Fund-Raise</span>
        </div>

        <div class="login-heading">Welcome to Fund-Raise</div>
        <div class="login-subheading">Sign in to continue</div>

        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div class="login-flash"><%= msg.message %></div>
        <% } %>
        <% } %>

        <a href="/auth/login/google" class="btn-auth">
            <svg width="18" height="18" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Sign in with Google
        </a>

        <div class="login-footer">
            New users will be automatically registered<br>when signing in for the first time.
        </div>
    </div>
</body>
</html>

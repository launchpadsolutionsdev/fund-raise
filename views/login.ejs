<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - TBRHSF Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body { background-color: #1a1d23; color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { max-width: 420px; width: 100%; }
        .btn-google { background-color: #fff; color: #333; border: 1px solid #ddd; }
        .btn-google:hover { background-color: #f8f9fa; color: #333; }
    </style>
</head>
<body>
    <div class="login-card text-center">
        <div class="mb-4">
            <i class="bi bi-heart-pulse-fill text-danger" style="font-size: 3rem;"></i>
            <h2 class="mt-3">TBRHSF Dashboard</h2>
            <p class="text-secondary">Thunder Bay Regional Health Sciences Foundation</p>
        </div>

        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div class="alert alert-<%= msg.category %> alert-dismissible fade show" role="alert">
            <%= msg.message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <% } %>

        <div class="card bg-dark border-secondary p-4">
            <h5 class="mb-4">Sign in to continue</h5>
            <a href="/auth/login/google" class="btn btn-google btn-lg w-100 d-flex align-items-center justify-content-center">
                <svg class="me-2" width="20" height="20" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Sign in with Google
            </a>
            <p class="text-secondary mt-3 mb-0"><small>Only authorized users can access this dashboard.</small></p>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

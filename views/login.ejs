<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - Fund-Raise</title>
    <link href="/css/style.css" rel="stylesheet">
    <style>
        body {
            background: var(--color-brand-navy);
            color: #fff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-container { max-width: 380px; width: 100%; text-align: center; }
        .login-logo {
            width: 48px; height: 48px; border-radius: 12px;
            background: var(--color-brand-blue);
            display: inline-flex; align-items: center; justify-content: center;
            margin-bottom: 16px;
        }
        .login-title { font-size: 18px; font-weight: 500; margin-bottom: 4px; }
        .login-subtitle { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 24px; }
        .login-card {
            background: rgba(255,255,255,0.06);
            border: 0.5px solid rgba(255,255,255,0.12);
            border-radius: var(--border-radius-lg);
            padding: 28px 24px;
        }
        .login-card-title { font-size: 14px; font-weight: 500; margin-bottom: 20px; color: #fff; }
        .btn-google {
            display: inline-flex; align-items: center; justify-content: center; gap: 10px;
            width: 100%; padding: 10px 16px;
            background: #fff; color: var(--color-text-primary);
            border: none; border-radius: var(--border-radius-md);
            font-size: 14px; font-weight: 500; cursor: pointer;
            text-decoration: none;
            transition: background 0.15s;
        }
        .btn-google:hover { background: #f5f5f4; color: var(--color-text-primary); }
        .login-footer { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 16px; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-logo">
            <svg width="24" height="24" viewBox="0 0 16 16" fill="none"><path d="M8 2L10.5 7H13L9.5 10L11 14L8 11.5L5 14L6.5 10L3 7H5.5L8 2Z" fill="white"/></svg>
        </div>
        <div class="login-title">Fund-Raise</div>
        <div class="login-subtitle">Thunder Bay Regional Health Sciences Foundation</div>

        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div style="padding: 10px 14px; border-radius: 6px; font-size: 13px; margin-bottom: 12px; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); text-align: left;">
            <%= msg.message %>
        </div>
        <% } %>
        <% } %>

        <div class="login-card">
            <div class="login-card-title">Sign in to continue</div>
            <a href="/auth/login/google" class="btn-google">
                <svg width="18" height="18" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Sign in with Google
            </a>
            <div class="login-footer">Only authorized users can access this dashboard.</div>
        </div>
    </div>
</body>
</html>

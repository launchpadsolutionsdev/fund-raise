<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>TBRHSF Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<div class="d-flex">
    <!-- Sidebar -->
    <nav id="sidebar" class="sidebar d-flex flex-column flex-shrink-0 p-3 text-white bg-dark">
        <a href="/" class="d-flex align-items-center mb-3 text-white text-decoration-none">
            <i class="bi bi-heart-pulse-fill me-2 fs-4"></i>
            <span class="fs-5 fw-semibold">TBRHSF Dashboard</span>
        </a>
        <hr>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="/" class="nav-link text-white <%= currentPath === '/' ? 'active' : '' %>">
                    <i class="bi bi-bar-chart-fill me-2"></i> Master Dashboard
                </a>
            </li>
            <li class="mt-3 mb-1"><small class="text-uppercase text-secondary fw-bold">Departments</small></li>
            <% const deptNav = [
                { slug: 'annual_giving', label: 'Annual Giving', icon: 'gift' },
                { slug: 'direct_mail', label: 'Direct Mail', icon: 'envelope' },
                { slug: 'events', label: 'Events', icon: 'calendar-event' },
                { slug: 'major_gifts', label: 'Major Gifts', icon: 'trophy' },
                { slug: 'legacy_giving', label: 'Legacy Giving', icon: 'tree' },
            ]; %>
            <% for (const d of deptNav) { %>
            <li>
                <a href="/departments/<%= d.slug %>" class="nav-link text-white <%= currentPath.includes(d.slug) ? 'active' : '' %>">
                    <i class="bi bi-<%= d.icon %> me-2"></i> <%= d.label %>
                </a>
            </li>
            <% } %>
            <% if (currentUser && currentUser.canUpload()) { %>
            <li class="mt-3">
                <a href="/upload" class="nav-link text-white <%= currentPath === '/upload' ? 'active' : '' %>">
                    <i class="bi bi-cloud-upload me-2"></i> Upload Data
                </a>
            </li>
            <% } %>
        </ul>
        <hr>
        <!-- Date picker -->
        <div class="mb-3">
            <label class="form-label text-secondary small"><i class="bi bi-calendar3 me-1"></i> Snapshot Date</label>
            <input type="date" id="snapshot-date-picker" class="form-control form-control-sm bg-dark text-white border-secondary"
                   value="<%= typeof selectedDate !== 'undefined' && selectedDate ? selectedDate : '' %>">
        </div>
        <hr>
        <!-- User info -->
        <div class="d-flex align-items-center">
            <% if (currentUser && currentUser.avatarUrl) { %>
            <img src="<%= currentUser.avatarUrl %>" alt="avatar" class="rounded-circle me-2" width="32" height="32">
            <% } else { %>
            <i class="bi bi-person-circle me-2 fs-4"></i>
            <% } %>
            <div class="flex-grow-1">
                <small class="d-block text-white"><%= currentUser ? (currentUser.name || currentUser.email) : '' %></small>
                <small class="text-secondary"><%= currentUser ? currentUser.role : '' %></small>
            </div>
            <a href="/auth/logout" class="text-secondary" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
    </nav>

    <!-- Main content -->
    <main class="main-content flex-grow-1 p-4">
        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div class="alert alert-<%= msg.category %> alert-dismissible fade show" role="alert">
            <%= msg.message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <% } %>

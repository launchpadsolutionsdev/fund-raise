<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise</title>
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Fund-Raise helps foundations and nonprofits track donations, manage departments, and hit fundraising goals with real-time dashboards and AI-powered insights.' %>">
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#0072BB">
    <link rel="icon" type="image/svg+xml" href="/images/fund-raise-icon-flat.svg">
    <link rel="canonical" href="https://fund-raise.onrender.com<%= typeof currentPath !== 'undefined' ? currentPath : '' %>">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Fund-Raise">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise">
    <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Fundraising intelligence for nonprofits — real-time dashboards, AI-powered insights, and donor analytics.' %>">
    <meta property="og:image" content="https://fund-raise.onrender.com/images/SEO-Image-FR.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url" content="https://fund-raise.onrender.com<%= typeof currentPath !== 'undefined' ? currentPath : '' %>">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise">
    <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Fundraising intelligence for nonprofits — real-time dashboards, AI-powered insights, and donor analytics.' %>">
    <meta name="twitter:image" content="https://fund-raise.onrender.com/images/SEO-Image-FR.jpg">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<div class="app-layout">
    <!-- Sidebar -->
    <nav class="sidebar">
      <div class="sidebar-scroll">
        <a href="/dashboard" class="sidebar-brand">
            <img src="/images/fund-raise-icon-flat.svg" alt="Fund-Raise Icon" class="sidebar-brand-icon">
            <span class="sidebar-brand-text">Fund-Raise</span>
        </a>

        <hr class="sidebar-divider">

        <ul class="sidebar-nav">
            <li>
                <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>">
                    <i class="bi bi-bar-chart-fill"></i> Master Dashboard
                </a>
            </li>

            <li>
                <a href="/analytics" class="<%= currentPath === '/analytics' ? 'active' : '' %>">
                    <i class="bi bi-diagram-3"></i> Analytics
                </a>
            </li>
            <li>
                <a href="/trends" class="<%= currentPath === '/trends' ? 'active' : '' %>">
                    <i class="bi bi-graph-up-arrow"></i> Trends
                </a>
            </li>

            <li><div class="sidebar-label" style="margin-top:14px;">AI Assistant</div></li>
            <li>
                <a href="/ask" class="<%= currentPath === '/ask' ? 'active' : '' %>">
                    <i class="bi bi-chat-dots"></i> Ask Fund-Raise
                </a>
            </li>

            <li><div class="sidebar-label" style="margin-top:14px;">Departments</div></li>

            <% const deptNav = [
                { slug: 'annual_giving', label: 'Annual Giving', icon: 'gift' },
                { slug: 'direct_mail', label: 'Direct Mail', icon: 'envelope' },
                { slug: 'events', label: 'Events', icon: 'calendar-event' },
                { slug: 'major_gifts', label: 'Major Gifts', icon: 'trophy' },
                { slug: 'legacy_giving', label: 'Legacy Giving', icon: 'tree' },
            ]; %>
            <% for (const d of deptNav) { %>
            <li>
                <a href="/departments/<%= d.slug %>" class="<%= currentPath.includes(d.slug) ? 'active' : '' %>">
                    <i class="bi bi-<%= d.icon %>"></i> <%= d.label %>
                </a>
            </li>
            <% } %>

            <% if (typeof bbConnected !== 'undefined' && bbConnected) { %>
            <li><div class="sidebar-label" style="margin-top:14px;">Live <span class="status-badge-dot online"></span></div></li>
            <li>
                <a href="/live/dashboard" class="<%= currentPath.startsWith('/live') ? 'active' : '' %>">
                    <i class="bi bi-lightning-charge"></i> Live Dashboard
                </a>
            </li>
            <% } %>

            <li><div class="sidebar-label" style="margin-top:14px;">Team</div></li>
            <li>
                <a href="/directory" class="<%= currentPath === '/directory' ? 'active' : '' %>">
                    <i class="bi bi-people"></i> Staff Directory
                </a>
            </li>
            <li>
                <a href="/board" class="<%= currentPath.startsWith('/board') ? 'active' : '' %>">
                    <i class="bi bi-pin-angle"></i> Message Board
                </a>
            </li>
            <li>
                <a href="/milestones" class="<%= currentPath === '/milestones' ? 'active' : '' %>">
                    <i class="bi bi-trophy"></i> Milestones
                </a>
            </li>
            <li>
                <a href="/kudos" class="<%= currentPath === '/kudos' ? 'active' : '' %>">
                    <i class="bi bi-star-fill"></i> Kudos Wall
                </a>
            </li>
            <li>
                <a href="/bingo" class="<%= currentPath === '/bingo' ? 'active' : '' %>">
                    <i class="bi bi-grid-3x3"></i> Bingo
                </a>
            </li>

            <li><div class="sidebar-label" style="margin-top:14px;">Tools</div></li>
            <li>
                <a href="/writing-assistant" class="<%= currentPath === '/writing-assistant' ? 'active' : '' %>">
                    <i class="bi bi-pencil-square"></i> Writing Assistant
                </a>
            </li>
            <li>
                <a href="/thank-you-letters" class="<%= currentPath === '/thank-you-letters' ? 'active' : '' %>">
                    <i class="bi bi-envelope-heart"></i> Thank-You Letters
                </a>
            </li>
            <li>
                <a href="/impact-stories" class="<%= currentPath === '/impact-stories' ? 'active' : '' %>">
                    <i class="bi bi-book"></i> Impact Stories
                </a>
            </li>
            <li>
                <a href="/meeting-prep" class="<%= currentPath === '/meeting-prep' ? 'active' : '' %>">
                    <i class="bi bi-briefcase"></i> Meeting Prep
                </a>
            </li>
            <li>
                <a href="/weekly-digest" class="<%= currentPath === '/weekly-digest' ? 'active' : '' %>">
                    <i class="bi bi-newspaper"></i> Weekly Digest
                </a>
            </li>
            <li>
                <a href="/notes" class="<%= currentPath === '/notes' ? 'active' : '' %>">
                    <i class="bi bi-sticky"></i> Quick Notes
                </a>
            </li>

            <li><div class="sidebar-label" style="margin-top:14px;">Planning</div></li>
            <li>
                <a href="/thermometer" class="<%= currentPath === '/thermometer' ? 'active' : '' %>">
                    <i class="bi bi-thermometer-half"></i> Thermometer
                </a>
            </li>
            <li>
                <a href="/scenario-planner" class="<%= currentPath === '/scenario-planner' ? 'active' : '' %>">
                    <i class="bi bi-sliders"></i> Scenario Planner
                </a>
            </li>

            <% if (currentUser && currentUser.canUpload()) { %>
            <li><div class="sidebar-label" style="margin-top:14px;">Admin</div></li>
            <li>
                <a href="/upload" class="<%= currentPath === '/upload' ? 'active' : '' %>">
                    <i class="bi bi-cloud-upload"></i> Upload Data
                </a>
            </li>
            <li>
                <a href="/crm-upload" class="<%= currentPath === '/crm-upload' ? 'active' : '' %>">
                    <i class="bi bi-database-up"></i> CRM Import
                </a>
            </li>
            <% } %>

            <% if (currentUser && currentUser.isAdmin()) { %>
            <li>
                <a href="/settings/blackbaud" class="<%= currentPath === '/settings/blackbaud' ? 'active' : '' %>">
                    <i class="bi bi-plug"></i> Blackbaud
                </a>
            </li>
            <% } %>
        </ul>

        <hr class="sidebar-divider">

        <!-- Date picker -->
        <div style="margin-bottom: 12px;">
            <div class="sidebar-date-label"><i class="bi bi-calendar3"></i> Report Week</div>
            <input type="date" id="snapshot-date-picker" class="sidebar-date-input"
                   value="<%= typeof selectedDate !== 'undefined' && selectedDate ? selectedDate : '' %>">
        </div>

      </div><!-- /.sidebar-scroll -->

        <div class="sidebar-footer">
        <hr class="sidebar-divider">

        <!-- User info -->
        <div class="sidebar-user">
            <% if (currentUser && (currentUser.localAvatarPath || currentUser.avatarUrl)) { %>
            <img src="<%= currentUser.localAvatarPath ? '/uploads/avatars/' + currentUser.localAvatarPath : currentUser.avatarUrl %>" alt="avatar" class="sidebar-avatar">
            <% } else { %>
            <%
                const userName = currentUser ? (currentUser.nickname || currentUser.name || currentUser.email || '') : '';
                const initials = userName.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() || '?';
            %>
            <div class="sidebar-avatar-initials"><%= initials %></div>
            <% } %>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name"><%= currentUser ? (currentUser.nickname || currentUser.name || currentUser.email) : '' %></div>
                <div class="sidebar-user-role"><%= currentUser ? currentUser.role : '' %></div>
            </div>
            <a href="/profile" class="sidebar-profile-link" title="My Profile">
                <i class="bi bi-pencil"></i>
            </a>
            <a href="/auth/logout" class="sidebar-logout" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
        </div><!-- /.sidebar-footer -->
    </nav>

    <!-- Main content -->
    <main class="main-content">
        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div class="flash-message flash-<%= msg.category %>">
            <%= msg.message %>
            <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
        <% } %>
        <% } %>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<div class="app-layout">
    <!-- Sidebar -->
    <nav class="sidebar">
        <a href="/dashboard" class="sidebar-brand">
            <img src="/images/Fund-Raise-Logo.png" alt="Fund-Raise" class="sidebar-logo">
        </a>

        <hr class="sidebar-divider">

        <ul class="sidebar-nav">
            <li>
                <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>">
                    <i class="bi bi-bar-chart-fill"></i> Master Dashboard
                </a>
            </li>

            <li>
                <a href="/analytics" class="<%= currentPath === '/analytics' ? 'active' : '' %>">
                    <i class="bi bi-diagram-3"></i> Analytics
                </a>
            </li>
            <li>
                <a href="/trends" class="<%= currentPath === '/trends' ? 'active' : '' %>">
                    <i class="bi bi-graph-up-arrow"></i> Trends
                </a>
            </li>

            <li><div class="sidebar-label" style="margin-top:14px;">Departments</div></li>

            <% const deptNav = [
                { slug: 'annual_giving', label: 'Annual Giving', icon: 'gift' },
                { slug: 'direct_mail', label: 'Direct Mail', icon: 'envelope' },
                { slug: 'events', label: 'Events', icon: 'calendar-event' },
                { slug: 'major_gifts', label: 'Major Gifts', icon: 'trophy' },
                { slug: 'legacy_giving', label: 'Legacy Giving', icon: 'tree' },
            ]; %>
            <% for (const d of deptNav) { %>
            <li>
                <a href="/departments/<%= d.slug %>" class="<%= currentPath.includes(d.slug) ? 'active' : '' %>">
                    <i class="bi bi-<%= d.icon %>"></i> <%= d.label %>
                </a>
            </li>
            <% } %>

            <% if (currentUser && currentUser.canUpload()) { %>
            <li style="margin-top: 14px;">
                <a href="/upload" class="<%= currentPath === '/upload' ? 'active' : '' %>">
                    <i class="bi bi-cloud-upload"></i> Upload Data
                </a>
            </li>
            <% } %>
        </ul>

        <hr class="sidebar-divider">

        <!-- Date picker -->
        <div style="margin-bottom: 12px;">
            <div class="sidebar-date-label"><i class="bi bi-calendar3"></i> Snapshot Date</div>
            <input type="date" id="snapshot-date-picker" class="sidebar-date-input"
                   value="<%= typeof selectedDate !== 'undefined' && selectedDate ? selectedDate : '' %>">
        </div>

        <hr class="sidebar-divider">

        <!-- User info -->
        <div class="sidebar-user">
            <% if (currentUser && currentUser.avatarUrl) { %>
            <img src="<%= currentUser.avatarUrl %>" alt="avatar" class="sidebar-avatar">
            <% } else { %>
            <%
                const userName = currentUser ? (currentUser.name || currentUser.email || '') : '';
                const initials = userName.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() || '?';
            %>
            <div class="sidebar-avatar-initials"><%= initials %></div>
            <% } %>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name"><%= currentUser ? (currentUser.name || currentUser.email) : '' %></div>
                <div class="sidebar-user-role"><%= currentUser ? currentUser.role : '' %></div>
            </div>
            <a href="/auth/logout" class="sidebar-logout" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
    </nav>

    <!-- Main content -->
    <main class="main-content">
        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div class="flash-message flash-<%= msg.category %>">
            <%= msg.message %>
            <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
        <% } %>
        <% } %>

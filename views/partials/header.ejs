<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise</title>
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Fund-Raise helps foundations and nonprofits track donations, manage departments, and hit fundraising goals with real-time dashboards and AI-powered insights.' %>">
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#0072BB">
    <link rel="icon" type="image/svg+xml" href="/images/fund-raise-icon-flat.svg">
    <link rel="canonical" href="https://fund-raise.onrender.com<%= typeof currentPath !== 'undefined' ? currentPath : '' %>">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Fund-Raise">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise">
    <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Fundraising intelligence for nonprofits — real-time dashboards, AI-powered insights, and donor analytics.' %>">
    <meta property="og:image" content="https://fund-raise.onrender.com/images/SEO-Image-FR.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url" content="https://fund-raise.onrender.com<%= typeof currentPath !== 'undefined' ? currentPath : '' %>">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title + ' - ' : '' %>Fund-Raise">
    <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Fundraising intelligence for nonprofits — real-time dashboards, AI-powered insights, and donor analytics.' %>">
    <meta name="twitter:image" content="https://fund-raise.onrender.com/images/SEO-Image-FR.jpg">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<div class="app-layout">
    <!-- Sidebar -->
    <nav class="sidebar" role="navigation" aria-label="Main navigation">
      <div class="sidebar-scroll">
        <a href="/dashboard" class="sidebar-brand">
            <img src="/images/fund-raise-icon-flat.svg" alt="Fund-Raise Icon" class="sidebar-brand-icon">
            <span class="sidebar-brand-text">Fund-Raise</span>
        </a>

        <hr class="sidebar-divider">

        <%
        /* ── Sidebar section definitions ── */
        const _p = currentPath;
        const _sections = [
            {
                key: 'ask', label: 'Ask Fund-Raise', icon: 'stars', standalone: true,
                items: [
                    { href: '/ask', icon: 'stars', label: 'Ask Fund-Raise', active: _p === '/ask' },
                ],
            },
            {
                key: 'team', label: 'Team', icon: 'people-fill',
                items: [
                    { href: '/directory', icon: 'people', label: 'Staff Directory', active: _p === '/directory' },
                    { href: '/board', icon: 'pin-angle', label: 'Message Board', active: _p.startsWith('/board') },
                    { href: '/milestones', icon: 'trophy', label: 'Milestones', active: _p === '/milestones' },
                    { href: '/kudos', icon: 'star-fill', label: 'Kudos Wall', active: _p === '/kudos' },
                    { href: '/bingo', icon: 'grid-3x3', label: 'Bingo', active: _p === '/bingo' },
                ],
            },
            {
                key: 'tools', label: 'Tools', icon: 'tools',
                items: [
                    { href: '/writing-assistant', icon: 'pencil-square', label: 'Writing Assistant', active: _p === '/writing-assistant' },
                    { href: '/thank-you-letters', icon: 'envelope-heart', label: 'Thank-You Letters', active: _p === '/thank-you-letters' },
                    { href: '/impact-stories', icon: 'book', label: 'Impact Stories', active: _p === '/impact-stories' },
                    { href: '/meeting-prep', icon: 'briefcase', label: 'Meeting Prep', active: _p === '/meeting-prep' },
                    { href: '/weekly-digest', icon: 'newspaper', label: 'Weekly Digest', active: _p === '/weekly-digest' },
                    { href: '/notes', icon: 'sticky', label: 'Quick Notes', active: _p === '/notes' },
                ],
            },
            {
                key: 'planning', label: 'Planning', icon: 'bullseye',
                items: [
                    { href: '/thermometer', icon: 'thermometer-half', label: 'Thermometer', active: _p === '/thermometer' },
                    { href: '/scenario-planner', icon: 'sliders', label: 'Scenario Planner', active: _p === '/scenario-planner' },
                ],
            },
            {
                key: 'crm-overview', label: 'CRM Overview', icon: 'database',
                items: [
                    { href: '/crm-dashboard', icon: 'graph-up', label: 'CRM Dashboard', active: _p === '/crm-dashboard' },
                    { href: '/crm/department-analytics', icon: 'building', label: 'Dept. Analytics', active: _p === '/crm/department-analytics' },
                    { href: '/crm/department-goals', icon: 'flag', label: 'Dept. Goals', active: _p === '/crm/department-goals' },
                    { href: '/crm/data-quality', icon: 'shield-check', label: 'Data Quality', active: _p === '/crm/data-quality' },
                    { href: '/crm/anomalies', icon: 'exclamation-triangle', label: 'Anomaly Detection', active: _p === '/crm/anomalies' },
                    { href: '/crm/recommendations', icon: 'stars', label: 'AI Recommendations', active: _p === '/crm/recommendations' },
                    { href: '/crm/reports', icon: 'file-earmark-pdf', label: 'Reports', active: _p === '/crm/reports' },
                    { href: '/crm/gifts', icon: 'search', label: 'Gift Search', active: _p === '/crm/gifts' },
                ],
            },
            {
                key: 'crm-donors', label: 'Donor Analytics', icon: 'person-lines-fill',
                items: [
                    { href: '/crm/donor-scoring', icon: 'bullseye', label: 'Donor Scoring', active: _p === '/crm/donor-scoring' },
                    { href: '/crm/retention', icon: 'person-lines-fill', label: 'Retention Analytics', active: _p === '/crm/retention' },
                    { href: '/crm/recurring-donors', icon: 'arrow-repeat', label: 'Recurring Donors', active: _p === '/crm/recurring-donors' },
                    { href: '/crm/donor-lifecycle', icon: 'recycle', label: 'Donor Lifecycle', active: _p === '/crm/donor-lifecycle' },
                    { href: '/crm/donor-insights', icon: 'lightbulb', label: 'Donor Insights', active: _p === '/crm/donor-insights' },
                    { href: '/crm/lybunt-sybunt', icon: 'person-dash', label: 'LYBUNT / SYBUNT', active: _p === '/crm/lybunt-sybunt' },
                    { href: '/crm/donor-upgrade-downgrade', icon: 'arrow-up-down', label: 'Upgrade / Downgrade', active: _p === '/crm/donor-upgrade-downgrade' },
                    { href: '/crm/first-time-donors', icon: 'person-plus', label: 'First-Time Conversion', active: _p === '/crm/first-time-donors' },
                ],
            },
            {
                key: 'crm-fundraisers', label: 'Fundraiser & Goals', icon: 'person-badge',
                items: [
                    { href: '/fundraiser-performance', icon: 'people', label: 'Fundraiser Performance', active: _p === '/fundraiser-performance' },
                    { href: '/fundraiser-goals', icon: 'flag', label: 'Fundraiser Goals', active: _p === '/fundraiser-goals' },
                ],
            },
            {
                key: 'crm-gifts', label: 'Gift & Fund Analytics', icon: 'cash-stack',
                items: [
                    { href: '/crm/acknowledgments', icon: 'check2-circle', label: 'Acknowledgments', active: _p === '/crm/acknowledgments' },
                    { href: '/crm/matching-gifts', icon: 'copy', label: 'Matching Gifts', active: _p === '/crm/matching-gifts' },
                    { href: '/crm/soft-credits', icon: 'person-check', label: 'Soft Credits', active: _p === '/crm/soft-credits' },
                    { href: '/crm/household-giving', icon: 'house', label: 'Household Giving', active: _p === '/crm/household-giving' },
                    { href: '/crm/payment-methods', icon: 'credit-card', label: 'Payment Methods', active: _p === '/crm/payment-methods' },
                    { href: '/crm/gift-trends', icon: 'graph-up-arrow', label: 'Gift Trends', active: _p === '/crm/gift-trends' },
                ],
            },
            {
                key: 'crm-compare', label: 'Comparisons', icon: 'arrow-left-right',
                items: [
                    { href: '/crm/campaign-compare', icon: 'bar-chart-line', label: 'Campaign Compare', active: _p === '/crm/campaign-compare' },
                    { href: '/crm/appeal-compare', icon: 'megaphone', label: 'Appeal Compare', active: _p === '/crm/appeal-compare' },
                    { href: '/crm/fund-health', icon: 'heart-pulse', label: 'Fund Health', active: _p === '/crm/fund-health' },
                    { href: '/crm/yoy-compare', icon: 'calendar2-range', label: 'Year-over-Year', active: _p === '/crm/yoy-compare' },
                ],
            },
        ];
        %>

        <ul class="sidebar-nav">
            <% for (const sec of _sections) { %>
            <%
                const _hasActive = sec.items.some(i => i.active);
                const _isCrm = sec.key.startsWith('crm');
            %>
            <li>
                <% if (sec.standalone) { %>
                <a href="<%= sec.items[0].href %>" class="sidebar-section-toggle sidebar-standalone<%= _hasActive ? ' has-active' : '' %>">
                    <span class="sidebar-section-icon"><i class="bi bi-<%= sec.icon %>"></i></span>
                    <span class="sidebar-section-label"><%= sec.label %></span>
                </a>
                <% } else { %>
                <div class="sidebar-section-toggle<%= _hasActive ? ' has-active' : '' %>" data-section="<%= sec.key %>">
                    <span class="sidebar-section-icon"><i class="bi bi-<%= sec.icon %>"></i></span>
                    <span class="sidebar-section-label"><%= sec.label %></span>
                    <% if (_isCrm && _sections.filter(s => s.key.startsWith('crm')).indexOf(sec) === 0) { %>
                    <span class="sidebar-section-badge">CRM</span>
                    <% } %>
                    <i class="bi bi-chevron-right sidebar-section-chevron"></i>
                </div>
                <ul class="sidebar-section-items" data-section="<%= sec.key %>">
                    <% for (const item of sec.items) { %>
                    <li>
                        <a href="<%= item.href %>" class="<%= item.active ? 'active' : '' %>">
                            <i class="bi bi-<%= item.icon %>"></i> <%= item.label %>
                        </a>
                    </li>
                    <% } %>
                </ul>
                <% } %>
            </li>
            <% } %>

            <% if (typeof bbConnected !== 'undefined' && bbConnected) { %>
            <li>
                <div class="sidebar-section-toggle<%= _p.startsWith('/live') ? ' has-active' : '' %>" data-section="live">
                    <span class="sidebar-section-icon"><i class="bi bi-lightning-charge"></i></span>
                    <span class="sidebar-section-label">Live <span class="status-badge-dot online"></span></span>
                    <i class="bi bi-chevron-right sidebar-section-chevron"></i>
                </div>
                <ul class="sidebar-section-items" data-section="live">
                    <li><a href="/live/dashboard" class="<%= _p.startsWith('/live') ? 'active' : '' %>"><i class="bi bi-lightning-charge"></i> Live Dashboard</a></li>
                </ul>
            </li>
            <% } %>

            <% if (currentUser && currentUser.canUpload()) { %>
            <li>
                <div class="sidebar-section-toggle<%= _p === '/upload' || _p === '/crm-upload' || _p === '/organization' ? ' has-active' : '' %>" data-section="admin">
                    <span class="sidebar-section-icon"><i class="bi bi-gear"></i></span>
                    <span class="sidebar-section-label">Admin</span>
                    <i class="bi bi-chevron-right sidebar-section-chevron"></i>
                </div>
                <ul class="sidebar-section-items" data-section="admin">
                    <li><a href="/upload" class="<%= _p === '/upload' ? 'active' : '' %>"><i class="bi bi-cloud-upload"></i> Upload Data</a></li>
                    <li><a href="/crm-upload" class="<%= _p === '/crm-upload' ? 'active' : '' %>"><i class="bi bi-database-up"></i> CRM Import</a></li>
                    <% if (currentUser.isAdmin()) { %>
                    <li><a href="/settings/blackbaud" class="<%= _p === '/settings/blackbaud' ? 'active' : '' %>"><i class="bi bi-plug"></i> Blackbaud</a></li>
                    <li><a href="/organization" class="<%= _p === '/organization' ? 'active' : '' %>"><i class="bi bi-building"></i> Organization</a></li>
                    <% } %>
                </ul>
            </li>
            <% } %>

            <!-- Legacy Dashboards (snapshot-based, pre-CRM) -->
            <li>
                <div class="sidebar-section-toggle sidebar-section-legacy<%= _p === '/dashboard' || _p === '/analytics' || _p === '/trends' || _p.includes('/departments/') ? ' has-active' : '' %>" data-section="legacy">
                    <span class="sidebar-section-icon"><i class="bi bi-clock-history"></i></span>
                    <span class="sidebar-section-label">Legacy Dashboards</span>
                    <span class="sidebar-legacy-badge">Snapshot</span>
                    <i class="bi bi-chevron-right sidebar-section-chevron"></i>
                </div>
                <ul class="sidebar-section-items" data-section="legacy">
                    <li><a href="/dashboard" class="<%= _p === '/dashboard' ? 'active' : '' %>"><i class="bi bi-bar-chart-fill"></i> Master Dashboard</a></li>
                    <li><a href="/analytics" class="<%= _p === '/analytics' ? 'active' : '' %>"><i class="bi bi-diagram-3"></i> Analytics</a></li>
                    <li><a href="/trends" class="<%= _p === '/trends' ? 'active' : '' %>"><i class="bi bi-graph-up-arrow"></i> Trends</a></li>
                    <li><a href="/departments/annual_giving" class="<%= _p.includes('annual_giving') ? 'active' : '' %>"><i class="bi bi-gift"></i> Annual Giving</a></li>
                    <li><a href="/departments/direct_mail" class="<%= _p.includes('direct_mail') ? 'active' : '' %>"><i class="bi bi-envelope"></i> Direct Mail</a></li>
                    <li><a href="/departments/events" class="<%= _p.includes('events') ? 'active' : '' %>"><i class="bi bi-calendar-event"></i> Events</a></li>
                    <li><a href="/departments/major_gifts" class="<%= _p.includes('major_gifts') ? 'active' : '' %>"><i class="bi bi-trophy"></i> Major Gifts</a></li>
                    <li><a href="/departments/legacy_giving" class="<%= _p.includes('legacy_giving') ? 'active' : '' %>"><i class="bi bi-tree"></i> Legacy Giving</a></li>
                </ul>
            </li>
        </ul>

        <hr class="sidebar-divider">

        <!-- Date picker -->
        <div style="margin-bottom: 12px;">
            <div class="sidebar-date-label"><i class="bi bi-calendar3"></i> Report Week</div>
            <input type="date" id="snapshot-date-picker" class="sidebar-date-input"
                   value="<%= typeof selectedDate !== 'undefined' && selectedDate ? selectedDate : '' %>">
        </div>

      </div><!-- /.sidebar-scroll -->

        <div class="sidebar-footer">
        <hr class="sidebar-divider">

        <!-- User info -->
        <div class="sidebar-user">
            <% if (currentUser && (currentUser.localAvatarPath || currentUser.avatarUrl)) { %>
            <img src="<%= currentUser.localAvatarPath ? '/uploads/avatars/' + currentUser.localAvatarPath : currentUser.avatarUrl %>" alt="avatar" class="sidebar-avatar">
            <% } else { %>
            <%
                const userName = currentUser ? (currentUser.nickname || currentUser.name || currentUser.email || '') : '';
                const initials = userName.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() || '?';
            %>
            <div class="sidebar-avatar-initials"><%= initials %></div>
            <% } %>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name"><%= currentUser ? (currentUser.nickname || currentUser.name || currentUser.email) : '' %></div>
                <div class="sidebar-user-role"><%= currentUser ? currentUser.role : '' %></div>
            </div>
            <a href="/profile" class="sidebar-profile-link" title="My Profile">
                <i class="bi bi-pencil"></i>
            </a>
            <a href="/auth/logout" class="sidebar-logout" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
        <div style="padding:8px 16px;font-size:10px;color:var(--color-text-tertiary);border-top:1px solid var(--color-border-primary);">
            <div style="display:flex;justify-content:space-between;"><span>Ask AI</span><kbd style="background:var(--color-background-secondary);padding:1px 5px;border-radius:3px;font-size:9px;border:1px solid var(--color-border-primary);">Ctrl+K</kbd></div>
        </div>
        </div><!-- /.sidebar-footer -->
    </nav>

    <!-- Main content -->
    <main class="main-content" role="main">
        <% if (typeof flash !== 'undefined' && flash.length > 0) { %>
        <% for (const msg of flash) { %>
        <div class="flash-message flash-<%= msg.category %>">
            <%= msg.message %>
            <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
        <% } %>
        <% } %>

<script>
// Shared markdown renderer for writing assistants — mirrors Ask Fund-Raise chat.ejs
function renderMarkdown(text) {
    var html = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

    // Code blocks
    html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, function(match, lang, code) {
        return '<pre><code class="lang-' + lang + '">' + code.trim() + '</code></pre>';
    });

    // Markdown tables
    html = html.replace(/((?:^\|.+\|$\n?)+)/gm, function(tableBlock) {
        var rows = tableBlock.trim().split('\n');
        if (rows.length < 2) return tableBlock;
        var tableHtml = '<div class="writing-table-wrap"><table class="writing-table">';
        var isHeader = true;
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i].trim();
            var sepCells = row.split('|').filter(function(c) { return c.trim() !== ''; });
            if (sepCells.every(function(c) { return /^[\s\-:]+$/.test(c); })) {
                isHeader = false;
                continue;
            }
            var cells = sepCells;
            if (isHeader) {
                tableHtml += '<thead><tr>' + cells.map(function(c) {
                    return '<th>' + c.trim() + '</th>';
                }).join('') + '</tr></thead><tbody>';
                isHeader = false;
            } else {
                tableHtml += '<tr>' + cells.map(function(c) {
                    return '<td>' + c.trim() + '</td>';
                }).join('') + '</tr>';
            }
        }
        tableHtml += '</tbody></table></div>';
        return tableHtml;
    });

    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

    // Horizontal rules
    html = html.replace(/^---+$/gm, '<hr class="writing-hr">');

    // Blockquotes
    html = html.replace(/^&gt;\s?(.+)$/gm, '<blockquote>$1</blockquote>');
    // Merge consecutive blockquotes
    html = html.replace(/<\/blockquote>\n?<blockquote>/g, '\n');

    html = html
        .replace(/^#### (.+)$/gm, '<h5>$1</h5>')
        .replace(/^### (.+)$/gm, '<h4>$1</h4>')
        .replace(/^## (.+)$/gm, '<h3>$1</h3>')
        .replace(/^# (.+)$/gm, '<h2>$1</h2>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
        .replace(/^- (.+)$/gm, '<li>$1</li>')
        .replace(/^\d+\.\s+(.+)$/gm, '<li class="writing-ol-item">$1</li>')
        .replace(/\n\n/g, '</p><p>')
        .replace(/\n/g, '<br>');

    // Wrap consecutive ordered list items
    html = html.replace(/((?:<li class="writing-ol-item">.*?<\/li>\s*(?:<br>)?)+)/g, function(match) {
        return '<ol>' + match.replace(/<br>/g, '').replace(/ class="writing-ol-item"/g, '') + '</ol>';
    });
    // Wrap consecutive unordered list items
    html = html.replace(/((?:<li>.*?<\/li>\s*(?:<br>)?)+)/g, function(match) {
        return '<ul>' + match.replace(/<br>/g, '') + '</ul>';
    });

    return '<p>' + html + '</p>';
}
</script>

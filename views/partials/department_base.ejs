<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting"><%= departmentName %></div>
        <div class="page-subtitle">
            <% if (typeof selectedDate !== 'undefined' && selectedDate) { %>
            Week of <%= selectedDate %> &middot; Cumulative FY 2025–2026
            <% } %>
        </div>
    </div>
</div>

<% if (!data || !data.summary) { %>
<div class="alert-card info">
    <div class="alert-card-title">No data available for <%= departmentName %></div>
    <div class="alert-card-text">
        <% if (currentUser && currentUser.canUpload()) { %><a href="/upload">Upload spreadsheets</a> to get started.<% } %>
    </div>
</div>
<% } else { %>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Total Gifts</div>
        <div class="kpi-value"><%= (data.summary.totalGifts || 0).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Total Amount</div>
        <div class="kpi-value">$<%= (parseFloat(data.summary.totalAmount) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Goal</div>
        <div class="kpi-value">$<%= (parseFloat(data.summary.goal) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">% to Goal</div>
        <div class="kpi-value"><%= ((parseFloat(data.summary.pctToGoal) || 0) * 100).toFixed(1) %>%</div>
        <% var pctVal = (parseFloat(data.summary.pctToGoal) || 0) * 100; %>
        <div class="kpi-change <%= pctVal >= 100 ? 'success' : pctVal >= 50 ? 'warning' : 'danger' %>">
            <%= pctVal >= 100 ? 'Goal reached' : (100 - pctVal).toFixed(1) + '% remaining' %>
        </div>
    </div>
</div>

<% } %>

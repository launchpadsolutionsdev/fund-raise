<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <div class="page-greeting"><%= departmentName %></div>
        <div class="page-subtitle">
            <% if (typeof selectedDate !== 'undefined' && selectedDate) { %>
            Snapshot: <%= selectedDate %>
            <% } %>
        </div>
    </div>
</div>

<% if (!data || !data.summary) { %>
<div class="alert-card info">
    <div class="alert-card-title">No data available for <%= departmentName %></div>
    <div class="alert-card-text">
        <% if (currentUser && currentUser.canUpload()) { %><a href="/upload">Upload spreadsheets</a> to get started.<% } %>
    </div>
</div>
<% } else { %>
<% const s = data.summary; %>

<!-- KPI Cards -->
<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Total Gifts</div>
        <div class="kpi-value"><%= (s.totalGifts || 0).toLocaleString() %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Total Amount</div>
        <div class="kpi-value">$<%= (parseFloat(s.totalAmount) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Goal</div>
        <div class="kpi-value">$<%= (parseFloat(s.goal) || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
    </div>
    <div class="kpi-card">
        <% const pct = (parseFloat(s.pctToGoal) || 0) * 100; %>
        <div class="kpi-label">% to Goal</div>
        <div class="kpi-value"><%= pct.toFixed(1) %>%</div>
        <div class="kpi-change <%= pct >= 100 ? 'success' : pct >= 50 ? 'warning' : 'danger' %>">
            <%= pct >= 100 ? 'Goal reached' : (100 - pct).toFixed(1) + '% remaining' %>
        </div>
    </div>
</div>

<%
// Only render on CRM-related pages
const _crmPaths = ['/crm-dashboard', '/fundraiser-performance', '/crm/', '/fundraiser-goals'];
const _showPanel = typeof currentPath !== 'undefined' && _crmPaths.some(function(p) { return currentPath === p || currentPath.startsWith(p); });
%>
<% if (_showPanel) { %>

<!-- Ask Fund-Raise Floating Button -->
<button class="ask-fab" id="askFab" title="Ask Fund-Raise">
    <i class="bi bi-stars"></i>
</button>

<!-- Ask Fund-Raise Slide-in Panel -->
<div class="ask-panel-overlay" id="askOverlay"></div>
<div class="ask-panel-wrapper" id="askPanel">
    <div class="ask-panel-header">
        <div class="ask-panel-title">
            <img src="/images/fund-raise-icon-flat.svg" alt="" class="ask-panel-logo">
            <span>Ask Fund-Raise</span>
        </div>
        <button class="ask-panel-close" id="askClose" title="Close panel">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="ask-panel-messages" id="askMessages">
        <div class="ask-panel-welcome" id="askWelcome">
            <p class="ask-panel-welcome-text">Ask me anything about your CRM data.</p>
            <div class="ask-panel-chips" id="askChips">
                <button class="ask-chip" data-prompt="What are my top performing fundraisers this quarter?">Top performing fundraisers this quarter?</button>
                <button class="ask-chip" data-prompt="Which donors are at risk of lapsing?">Which donors are at risk of lapsing?</button>
                <button class="ask-chip" data-prompt="Summarize my giving trends">Summarize my giving trends</button>
                <button class="ask-chip" data-prompt="How does this fiscal year compare to last year?">This FY vs. last year?</button>
            </div>
        </div>
    </div>

    <div class="ask-panel-input-area">
        <form id="askForm" class="ask-panel-form" autocomplete="off">
            <input type="text" id="askInput" class="ask-panel-input" placeholder="Ask about your CRM data..." maxlength="2000">
            <button type="submit" class="ask-panel-send" id="askSend" title="Send">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>
</div>

<style>
/* ── Ask Panel FAB ── */
.ask-fab {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--brand, #0072BB);
    color: #fff;
    border: none;
    font-size: 24px;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,.25);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .2s, box-shadow .2s;
    animation: askFabPulse 2s ease-in-out 3;
}
.ask-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(0,0,0,.3);
}
@keyframes askFabPulse {
    0%, 100% { box-shadow: 0 4px 16px rgba(0,0,0,.25); }
    50% { box-shadow: 0 4px 24px rgba(0,114,187,.6); }
}

/* ── Overlay ── */
.ask-panel-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.3);
    z-index: 1001;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease;
}
.ask-panel-overlay.open {
    opacity: 1;
    pointer-events: auto;
}

/* ── Panel ── */
.ask-panel-wrapper {
    position: fixed;
    top: 0;
    right: 0;
    width: 560px;
    max-width: 100vw;
    height: 100vh;
    background: var(--card-bg, #fff);
    z-index: 1002;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform .3s cubic-bezier(.4,0,.2,1);
    box-shadow: -4px 0 24px rgba(0,0,0,.15);
}
.ask-panel-wrapper.open {
    transform: translateX(0);
}

/* ── Header ── */
.ask-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border, #e2e8f0);
    flex-shrink: 0;
}
.ask-panel-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 15px;
    color: var(--text, #1a202c);
}
.ask-panel-logo {
    width: 22px;
    height: 22px;
}
.ask-panel-close {
    background: none;
    border: none;
    font-size: 18px;
    color: var(--text-muted, #718096);
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 6px;
    transition: background .15s;
}
.ask-panel-close:hover {
    background: var(--hover-bg, #f1f5f9);
}

/* ── Messages ── */
.ask-panel-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    scroll-behavior: smooth;
}

/* ── Welcome / Chips ── */
.ask-panel-welcome {
    text-align: center;
    padding: 24px 8px 8px;
}
.ask-panel-welcome-text {
    color: var(--text-muted, #718096);
    font-size: 14px;
    margin-bottom: 16px;
}
.ask-panel-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
}
.ask-chip {
    background: var(--hover-bg, #f1f5f9);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 20px;
    padding: 7px 14px;
    font-size: 12.5px;
    color: var(--text, #1a202c);
    cursor: pointer;
    transition: background .15s, border-color .15s;
    text-align: left;
    line-height: 1.35;
}
.ask-chip:hover {
    background: var(--brand-light, #e6f2fa);
    border-color: var(--brand, #0072BB);
}

/* ── Message bubbles ── */
.ask-msg {
    display: flex;
    margin-bottom: 12px;
    gap: 8px;
    align-items: flex-start;
}
.ask-msg-user {
    flex-direction: row-reverse;
}
.ask-msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}
.ask-msg-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.ask-msg-avatar-initials {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--brand, #0072BB);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
}
.ask-bubble {
    max-width: 92%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 13.5px;
    line-height: 1.5;
    word-wrap: break-word;
    overflow-wrap: break-word;
}
.ask-bubble-user {
    background: var(--brand, #0072BB);
    color: #fff;
    border-bottom-right-radius: 4px;
}
.ask-bubble-ai {
    background: var(--hover-bg, #f1f5f9);
    color: var(--text, #1a202c);
    border-bottom-left-radius: 4px;
}

/* Markdown inside AI bubbles */
.ask-bubble-ai h3, .ask-bubble-ai h4, .ask-bubble-ai h5 {
    margin: 8px 0 4px;
    font-size: 13.5px;
    font-weight: 600;
}
.ask-bubble-ai p { margin: 0 0 6px; }
.ask-bubble-ai ul, .ask-bubble-ai ol { margin: 4px 0 8px 16px; padding: 0; }
.ask-bubble-ai li { margin-bottom: 2px; }
.ask-bubble-ai pre {
    background: var(--code-bg, #1e293b);
    color: #e2e8f0;
    padding: 10px;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 12px;
    margin: 6px 0;
}
.ask-bubble-ai code {
    background: rgba(0,0,0,.06);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 12px;
}
.ask-bubble-ai pre code {
    background: none;
    padding: 0;
}
.ask-bubble-ai .ask-table-wrap {
    overflow-x: auto;
    margin: 6px 0;
}
.ask-bubble-ai table.ask-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    white-space: nowrap;
}
.ask-bubble-ai .ask-table th,
.ask-bubble-ai .ask-table td {
    border: 1px solid var(--border, #e2e8f0);
    padding: 4px 8px;
    text-align: left;
}
.ask-bubble-ai .ask-table th {
    background: rgba(0,0,0,.04);
    font-weight: 600;
}
.ask-bubble-ai hr { border: none; border-top: 1px solid var(--border, #e2e8f0); margin: 8px 0; }
.ask-bubble-ai a { color: var(--brand, #0072BB); }
.ask-bubble-ai strong { font-weight: 600; }

/* ── Typing indicator ── */
.ask-typing { display: flex; gap: 4px; padding: 4px 0; align-items: center; }
.ask-typing span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-muted, #a0aec0);
    animation: askTypingBounce .6s infinite alternate;
}
.ask-typing span:nth-child(2) { animation-delay: .15s; }
.ask-typing span:nth-child(3) { animation-delay: .3s; }
@keyframes askTypingBounce {
    0% { opacity: .3; transform: translateY(0); }
    100% { opacity: 1; transform: translateY(-3px); }
}

/* ── Error state ── */
.ask-bubble-error {
    color: #e53e3e;
    font-size: 13px;
}

/* ── Input area ── */
.ask-panel-input-area {
    flex-shrink: 0;
    padding: 12px 16px;
    border-top: 1px solid var(--border, #e2e8f0);
}
.ask-panel-form {
    display: flex;
    gap: 8px;
    align-items: center;
}
.ask-panel-input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 24px;
    font-size: 13.5px;
    outline: none;
    background: var(--input-bg, #f8fafc);
    color: var(--text, #1a202c);
    transition: border-color .15s;
}
.ask-panel-input:focus {
    border-color: var(--brand, #0072BB);
}
.ask-panel-input::placeholder {
    color: var(--text-muted, #a0aec0);
}
.ask-panel-send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--brand, #0072BB);
    color: #fff;
    border: none;
    font-size: 15px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background .15s, opacity .15s;
}
.ask-panel-send:hover {
    background: var(--brand-dark, #005a94);
}
.ask-panel-send:disabled {
    opacity: .5;
    cursor: not-allowed;
}

/* ── Responsive ── */
@media (max-width: 640px) {
    .ask-panel-wrapper { width: 100vw; }
    .ask-fab { bottom: 16px; right: 16px; width: 48px; height: 48px; font-size: 20px; }
}
</style>

<script>
(function() {
    'use strict';

    // ── DOM refs ──
    var fab = document.getElementById('askFab');
    var overlay = document.getElementById('askOverlay');
    var panel = document.getElementById('askPanel');
    var closeBtn = document.getElementById('askClose');
    var form = document.getElementById('askForm');
    var input = document.getElementById('askInput');
    var sendBtn = document.getElementById('askSend');
    var messagesEl = document.getElementById('askMessages');
    var welcome = document.getElementById('askWelcome');
    var chips = document.querySelectorAll('.ask-chip');

    // ── State ──
    var conversationId = null;
    var conversationHistory = [];
    var isLoading = false;
    var isOpen = false;

    // ── Open / Close ──
    function openPanel() {
        isOpen = true;
        panel.classList.add('open');
        overlay.classList.add('open');
        fab.style.display = 'none';
        setTimeout(function() { input.focus(); }, 350);
    }

    function closePanel() {
        isOpen = false;
        panel.classList.remove('open');
        overlay.classList.remove('open');
        fab.style.display = 'flex';
    }

    fab.addEventListener('click', openPanel);
    closeBtn.addEventListener('click', closePanel);
    overlay.addEventListener('click', closePanel);
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && isOpen) closePanel();
    });

    // ── Chips ──
    chips.forEach(function(chip) {
        chip.addEventListener('click', function() {
            var prompt = chip.getAttribute('data-prompt');
            if (prompt && !isLoading) {
                input.value = prompt;
                sendMessage(prompt);
            }
        });
    });

    // ── Form submit ──
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var text = input.value.trim();
        if (!text || isLoading) return;
        sendMessage(text);
    });

    // ── Send ──
    function sendMessage(text) {
        // Hide welcome
        if (welcome) {
            welcome.style.display = 'none';
        }

        // Append user bubble
        appendMessage('user', text);
        conversationHistory.push({ role: 'user', content: text });

        input.value = '';
        isLoading = true;
        sendBtn.disabled = true;

        // Create AI bubble with typing indicator
        var aiMsg = createAIBubble();
        var bubble = aiMsg.bubble;
        var streamedText = '';

        // Build fetch request
        var abortController = new AbortController();
        var lastDataTime = Date.now();
        var TIMEOUT = 120000;
        var timeoutChecker = setInterval(function() {
            if (Date.now() - lastDataTime > TIMEOUT) {
                clearInterval(timeoutChecker);
                abortController.abort();
            }
        }, 5000);

        fetch('/api/ai/chat/stream', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                messages: conversationHistory,
                conversationId: conversationId,
                crmMode: true,
            }),
            signal: abortController.signal,
        })
        .then(function(response) {
            if (!response.ok) throw new Error('Stream request failed');

            var reader = response.body.getReader();
            var decoder = new TextDecoder();
            var buffer = '';

            function read() {
                return reader.read().then(function(result) {
                    if (result.done) {
                        finishStream(streamedText, bubble);
                        return;
                    }

                    lastDataTime = Date.now();
                    buffer += decoder.decode(result.value, { stream: true });
                    var lines = buffer.split('\n');
                    buffer = lines.pop();

                    var currentEvent = '';
                    for (var i = 0; i < lines.length; i++) {
                        var line = lines[i];
                        if (line.startsWith('event: ')) {
                            currentEvent = line.substring(7);
                        } else if (line.startsWith('data: ')) {
                            try {
                                var data = JSON.parse(line.substring(6));
                                if (currentEvent === 'delta') {
                                    // Remove typing indicator on first delta
                                    var typing = bubble.querySelector('.ask-typing');
                                    if (typing) bubble.innerHTML = '';
                                    streamedText += data.text;
                                    bubble.innerHTML = renderMarkdown(streamedText);
                                } else if (currentEvent === 'tool_use') {
                                    bubble.innerHTML = '<div class="ask-typing"><span></span><span></span><span></span></div><div style="font-size:12px;color:var(--text-muted,#718096);margin-top:4px;">Searching data...</div>';
                                } else if (currentEvent === 'done') {
                                    streamedText = data.text || streamedText;
                                    bubble.innerHTML = renderMarkdown(streamedText);
                                } else if (currentEvent === 'saved' && data.conversationId) {
                                    conversationId = data.conversationId;
                                } else if (currentEvent === 'error') {
                                    bubble.innerHTML = '<span class="ask-bubble-error">' + escapeHtml(data.error || 'An error occurred') + '</span>';
                                }
                            } catch (e) {
                                // ignore parse errors
                            }
                            currentEvent = '';
                        }
                    }

                    scrollToBottom();
                    return read();
                });
            }

            return read();
        })
        .catch(function(err) {
            var errMsg = 'Failed to connect. Please try again.';
            if (err.name === 'AbortError') {
                errMsg = 'Request timed out. Please try again.';
            }
            if (!streamedText) {
                bubble.innerHTML = '<span class="ask-bubble-error">' + errMsg + '</span>';
            }
        })
        .finally(function() {
            clearInterval(timeoutChecker);
            isLoading = false;
            sendBtn.disabled = false;
            input.focus();
        });
    }

    function finishStream(text, bubble) {
        if (text) {
            bubble.innerHTML = renderMarkdown(text);
            conversationHistory.push({ role: 'assistant', content: text });
        }
    }

    // ── DOM helpers ──
    function appendMessage(role, text) {
        var div = document.createElement('div');
        div.className = 'ask-msg ask-msg-' + role;

        var avatar = document.createElement('div');
        avatar.className = 'ask-msg-avatar';
        if (role === 'user') {
            avatar.innerHTML = '<div class="ask-msg-avatar-initials">You</div>';
        } else {
            avatar.innerHTML = '<img src="/images/fund-raise-icon-flat.svg" alt="AI">';
        }

        var bubble = document.createElement('div');
        bubble.className = 'ask-bubble ask-bubble-' + role;
        bubble.textContent = text;

        div.appendChild(avatar);
        div.appendChild(bubble);
        messagesEl.appendChild(div);
        scrollToBottom();
    }

    function createAIBubble() {
        var div = document.createElement('div');
        div.className = 'ask-msg ask-msg-ai';

        var avatar = document.createElement('div');
        avatar.className = 'ask-msg-avatar';
        avatar.innerHTML = '<img src="/images/fund-raise-icon-flat.svg" alt="AI">';

        var bubble = document.createElement('div');
        bubble.className = 'ask-bubble ask-bubble-ai';
        bubble.innerHTML = '<div class="ask-typing"><span></span><span></span><span></span></div>';

        div.appendChild(avatar);
        div.appendChild(bubble);
        messagesEl.appendChild(div);
        scrollToBottom();
        return { msgDiv: div, bubble: bubble };
    }

    function scrollToBottom() {
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    // ── Markdown renderer (lightweight) ──
    function escapeHtml(text) {
        return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function renderMarkdown(text) {
        var html = escapeHtml(text);

        // Code blocks
        html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, function(m, lang, code) {
            return '<pre><code>' + code.trim() + '</code></pre>';
        });

        // Tables
        html = html.replace(/((?:^\|.+\|$\n?)+)/gm, function(block) {
            var rows = block.trim().split('\n');
            if (rows.length < 2) return block;
            var t = '<table class="ask-table">';
            var isHeader = true;
            for (var i = 0; i < rows.length; i++) {
                var cells = rows[i].split('|').filter(function(c) { return c.trim() !== ''; });
                if (cells.every(function(c) { return /^[\s\-:]+$/.test(c); })) {
                    isHeader = false;
                    continue;
                }
                if (isHeader) {
                    t += '<thead><tr>' + cells.map(function(c) { return '<th>' + c.trim() + '</th>'; }).join('') + '</tr></thead><tbody>';
                    isHeader = false;
                } else {
                    t += '<tr>' + cells.map(function(c) { return '<td>' + c.trim() + '</td>'; }).join('') + '</tr>';
                }
            }
            t += '</tbody></table>';
            return '<div class="ask-table-wrap">' + t + '</div>';
        });

        // Inline code
        html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

        // Headings, bold, italic, links, lists
        html = html
            .replace(/^#### (.+)$/gm, '<h5>$1</h5>')
            .replace(/^### (.+)$/gm, '<h4>$1</h4>')
            .replace(/^## (.+)$/gm, '<h3>$1</h3>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
            .replace(/^- (.+)$/gm, '<li>$1</li>')
            .replace(/^\d+\.\s+(.+)$/gm, '<li>$1</li>');

        // Wrap consecutive <li> in <ul>
        html = html.replace(/((?:<li>[\s\S]*?<\/li>\s*)+)/g, '<ul>$1</ul>');

        // Paragraphs
        html = html
            .replace(/\n\n/g, '</p><p>')
            .replace(/\n/g, '<br>');

        // Horizontal rules
        html = html.replace(/^---+$/gm, '<hr>');

        return html;
    }
})();
</script>

<% } %>

    </main>
</div>
<%- include('./ask-panel') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script src="/js/csv-export.js"></script>
<script>
    document.getElementById('snapshot-date-picker')?.addEventListener('change', function() {
        const url = new URL(window.location.href);
        url.searchParams.set('date', this.value);
        window.location.href = url.toString();
    });

    // ── Collapsible sidebar sections ──
    (function() {
        var KEY = 'sidebarSections';
        var saved = {};
        try { saved = JSON.parse(sessionStorage.getItem(KEY)) || {}; } catch(e) {}

        document.querySelectorAll('.sidebar-section-toggle').forEach(function(toggle) {
            var section = toggle.getAttribute('data-section');
            var items = document.querySelector('.sidebar-section-items[data-section="' + section + '"]');
            if (!items) return;

            // Auto-expand if section has active link, or if previously saved as open
            var hasActive = toggle.classList.contains('has-active');
            var shouldOpen = hasActive || saved[section] === true;
            // If explicitly closed by user (false), respect that unless it has active
            if (saved[section] === false && !hasActive) shouldOpen = false;

            if (shouldOpen) {
                toggle.classList.add('open');
                items.classList.add('open');
            }

            toggle.addEventListener('click', function() {
                var isOpen = items.classList.contains('open');
                if (isOpen) {
                    toggle.classList.remove('open');
                    items.classList.remove('open');
                    saved[section] = false;
                } else {
                    toggle.classList.add('open');
                    items.classList.add('open');
                    saved[section] = true;
                }
                try { sessionStorage.setItem(KEY, JSON.stringify(saved)); } catch(e) {}
            });
        });
    })();

    // ── Sidebar scroll persistence ──
    (function() {
        var scrollEl = document.querySelector('.sidebar-scroll');
        if (!scrollEl) return;

        // Restore saved scroll position
        var saved = sessionStorage.getItem('sidebarScroll');
        if (saved !== null) scrollEl.scrollTop = parseInt(saved, 10);

        // Save scroll position before navigating away
        window.addEventListener('beforeunload', function() {
            sessionStorage.setItem('sidebarScroll', scrollEl.scrollTop);
        });
    })();

    // ── Page transitions ──
    (function() {
        // Clear fade-out class when page is restored from bfcache (back/forward)
        window.addEventListener('pageshow', function(e) {
            if (e.persisted) {
                document.body.classList.remove('page-exiting');
            }
        });
        // Also clear on regular load in case browser didn't use bfcache
        document.body.classList.remove('page-exiting');

        document.addEventListener('click', function(e) {
            var link = e.target.closest('a[href]');
            if (!link) return;
            var href = link.getAttribute('href');
            // Only intercept internal navigational links
            if (!href || href.startsWith('#') || href.startsWith('javascript:')
                || link.target === '_blank' || e.ctrlKey || e.metaKey || e.shiftKey) return;
            // Skip external links
            if (href.startsWith('http') && !href.startsWith(window.location.origin)) return;

            e.preventDefault();
            document.body.classList.add('page-exiting');
            setTimeout(function() { window.location.href = href; }, 150);
        });
    })();

    // ── Global keyboard shortcuts ──
    document.addEventListener('keydown', function(e) {
        // Escape: close any open modal/overlay
        if (e.key === 'Escape') {
            // Close any visible modals (look for common modal patterns)
            var modals = document.querySelectorAll('.modal-overlay, .fr-modal, [data-modal]');
            modals.forEach(function(m) {
                if (m.style.display !== 'none' && getComputedStyle(m).display !== 'none') {
                    m.style.display = 'none';
                }
            });
            // Close the Ask Fund-Raise AI panel if it's open
            var askPanel = document.getElementById('askPanel');
            if (askPanel && askPanel.classList.contains('open')) {
                var askClose = document.getElementById('askClose');
                if (askClose) askClose.click();
            }
        }

        // Ctrl/Cmd + K: Focus search / Ask Fund-Raise if available
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            var askFab = document.getElementById('askFab');
            if (askFab) askFab.click();
        }

        // Ctrl/Cmd + Shift + E: Export CSV if export button exists on page
        if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'E') {
            e.preventDefault();
            var exportBtn = document.querySelector('[onclick*="export"], [onclick*="Export"], button[class*="export"]');
            if (exportBtn) exportBtn.click();
        }
    });
</script>

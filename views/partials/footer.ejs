    </main>
</div>
<%- include('./ask-panel') %>

<!-- Branded Modal (replaces native confirm/alert) -->
<div class="fr-modal-overlay" id="frModal">
    <div class="fr-modal-dialog">
        <div class="fr-modal-icon confirm" id="frModalIcon"><i class="bi bi-question-circle"></i></div>
        <div class="fr-modal-title" id="frModalTitle">Are you sure?</div>
        <div class="fr-modal-message" id="frModalMsg"></div>
        <div class="fr-modal-actions">
            <button class="fr-modal-btn fr-modal-btn-cancel" id="frModalCancel">Cancel</button>
            <button class="fr-modal-btn fr-modal-btn-confirm" id="frModalOk">Confirm</button>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script src="/js/csv-export.js"></script>
<script>
    document.getElementById('snapshot-date-picker')?.addEventListener('change', function() {
        const url = new URL(window.location.href);
        url.searchParams.set('date', this.value);
        window.location.href = url.toString();
    });

    // ── Collapsible sidebar sections ──
    (function() {
        var KEY = 'sidebarSections';
        var saved = {};
        try { saved = JSON.parse(sessionStorage.getItem(KEY)) || {}; } catch(e) {}

        document.querySelectorAll('.sidebar-section-toggle').forEach(function(toggle) {
            var section = toggle.getAttribute('data-section');
            var items = document.querySelector('.sidebar-section-items[data-section="' + section + '"]');
            if (!items) return;

            // Auto-expand if section has active link, or if previously saved as open
            var hasActive = toggle.classList.contains('has-active');
            var shouldOpen = hasActive || saved[section] === true;
            // If explicitly closed by user (false), respect that unless it has active
            if (saved[section] === false && !hasActive) shouldOpen = false;

            if (shouldOpen) {
                toggle.classList.add('open');
                items.classList.add('open');
            }

            toggle.addEventListener('click', function() {
                var isOpen = items.classList.contains('open');
                if (isOpen) {
                    toggle.classList.remove('open');
                    items.classList.remove('open');
                    saved[section] = false;
                } else {
                    toggle.classList.add('open');
                    items.classList.add('open');
                    saved[section] = true;
                }
                try { sessionStorage.setItem(KEY, JSON.stringify(saved)); } catch(e) {}
            });
        });
    })();

    // ── Sidebar scroll persistence ──
    (function() {
        var scrollEl = document.querySelector('.sidebar-scroll');
        if (!scrollEl) return;

        // Restore saved scroll position
        var saved = sessionStorage.getItem('sidebarScroll');
        if (saved !== null) scrollEl.scrollTop = parseInt(saved, 10);

        // Save scroll position before navigating away
        window.addEventListener('beforeunload', function() {
            sessionStorage.setItem('sidebarScroll', scrollEl.scrollTop);
        });
    })();

    // ── Page transitions ──
    (function() {
        // Clear fade-out class when page is restored from bfcache (back/forward)
        window.addEventListener('pageshow', function(e) {
            if (e.persisted) {
                document.body.classList.remove('page-exiting');
            }
        });
        // Also clear on regular load in case browser didn't use bfcache
        document.body.classList.remove('page-exiting');

        document.addEventListener('click', function(e) {
            var link = e.target.closest('a[href]');
            if (!link) return;
            var href = link.getAttribute('href');
            // Only intercept internal navigational links
            if (!href || href.startsWith('#') || href.startsWith('javascript:')
                || link.target === '_blank' || e.ctrlKey || e.metaKey || e.shiftKey) return;
            // Skip external links
            if (href.startsWith('http') && !href.startsWith(window.location.origin)) return;

            e.preventDefault();
            document.body.classList.add('page-exiting');
            setTimeout(function() { window.location.href = href; }, 150);
        });
    })();

    // ── FY loading spinner ──
    (function() {
        var overlay = null;
        function getContentEl() {
            return document.getElementById('fr-content')
                || document.getElementById('crm-content')
                || document.getElementById('ret-content');
        }
        function ensureOverlay(contentEl) {
            if (overlay) return overlay;
            contentEl.style.position = 'relative';
            overlay = document.createElement('div');
            overlay.className = 'fy-loading-overlay';
            overlay.innerHTML = '<div class="fy-loading-spinner"></div>';
            contentEl.appendChild(overlay);
            return overlay;
        }
        // Listen for FY select changes (dynamically created by each page)
        document.addEventListener('change', function(e) {
            if (e.target.id !== 'fy-select') return;
            var contentEl = getContentEl();
            if (!contentEl || contentEl.style.display === 'none') return;
            ensureOverlay(contentEl).classList.add('active');
        });
        // Hide overlay when content is updated (detect via MutationObserver)
        var contentEl = getContentEl();
        if (contentEl) {
            new MutationObserver(function() {
                if (overlay) overlay.classList.remove('active');
            }).observe(contentEl, { childList: true });
        }
        // Also hook into dynamically created content containers
        new MutationObserver(function() {
            var el = getContentEl();
            if (el && el !== contentEl) {
                contentEl = el;
                new MutationObserver(function() {
                    if (overlay) overlay.classList.remove('active');
                }).observe(el, { childList: true });
            }
        }).observe(document.body, { childList: true, subtree: true });
    })();

    // ── Global keyboard shortcuts ──
    document.addEventListener('keydown', function(e) {
        // Escape: close any open modal/overlay
        if (e.key === 'Escape') {
            // Close any visible modals (look for common modal patterns)
            var modals = document.querySelectorAll('.modal-overlay, .fr-modal, [data-modal]');
            modals.forEach(function(m) {
                if (m.style.display !== 'none' && getComputedStyle(m).display !== 'none') {
                    m.style.display = 'none';
                }
            });
            // Close the Ask Fund-Raise AI panel if it's open
            var askPanel = document.getElementById('askPanel');
            if (askPanel && askPanel.classList.contains('open')) {
                var askClose = document.getElementById('askClose');
                if (askClose) askClose.click();
            }
        }

        // Ctrl/Cmd + K: Focus search / Ask Fund-Raise if available
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            var askFab = document.getElementById('askFab');
            if (askFab) askFab.click();
        }

        // Ctrl/Cmd + Shift + E: Export CSV if export button exists on page
        if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'E') {
            e.preventDefault();
            var exportBtn = document.querySelector('[onclick*="export"], [onclick*="Export"], button[class*="export"]');
            if (exportBtn) exportBtn.click();
        }
    });

    // ── Branded modal utilities (replace native confirm / alert) ──
    window.frConfirm = function(message, opts) {
        opts = opts || {};
        return new Promise(function(resolve) {
            var overlay = document.getElementById('frModal');
            var icon = document.getElementById('frModalIcon');
            var title = document.getElementById('frModalTitle');
            var msg = document.getElementById('frModalMsg');
            var okBtn = document.getElementById('frModalOk');
            var cancelBtn = document.getElementById('frModalCancel');

            var variant = opts.variant || 'confirm';
            var icons = { confirm: 'bi-question-circle', danger: 'bi-exclamation-triangle', warning: 'bi-exclamation-circle', info: 'bi-info-circle' };

            title.textContent = opts.title || (variant === 'danger' ? 'Are you sure?' : 'Confirm');
            msg.textContent = message;
            icon.className = 'fr-modal-icon ' + variant;
            icon.innerHTML = '<i class="bi ' + (icons[variant] || icons.confirm) + '"></i>';
            okBtn.textContent = opts.confirmText || (variant === 'danger' ? 'Delete' : 'Confirm');
            okBtn.className = 'fr-modal-btn ' + (variant === 'danger' ? 'fr-modal-btn-danger' : 'fr-modal-btn-confirm');
            cancelBtn.textContent = opts.cancelText || 'Cancel';
            cancelBtn.style.display = '';

            overlay.classList.add('visible');

            function cleanup() {
                overlay.classList.remove('visible');
                okBtn.removeEventListener('click', onOk);
                cancelBtn.removeEventListener('click', onCancel);
                overlay.removeEventListener('click', onBackdrop);
                document.removeEventListener('keydown', onKey);
            }
            function onOk() { cleanup(); resolve(true); }
            function onCancel() { cleanup(); resolve(false); }
            function onBackdrop(e) { if (e.target === overlay) { cleanup(); resolve(false); } }
            function onKey(e) { if (e.key === 'Escape') { cleanup(); resolve(false); } }

            okBtn.addEventListener('click', onOk);
            cancelBtn.addEventListener('click', onCancel);
            overlay.addEventListener('click', onBackdrop);
            document.addEventListener('keydown', onKey);
            okBtn.focus();
        });
    };

    window.frAlert = function(message, opts) {
        opts = opts || {};
        return new Promise(function(resolve) {
            var overlay = document.getElementById('frModal');
            var icon = document.getElementById('frModalIcon');
            var title = document.getElementById('frModalTitle');
            var msg = document.getElementById('frModalMsg');
            var okBtn = document.getElementById('frModalOk');
            var cancelBtn = document.getElementById('frModalCancel');

            var variant = opts.variant || 'info';
            var icons = { info: 'bi-info-circle', warning: 'bi-exclamation-circle', danger: 'bi-exclamation-triangle', confirm: 'bi-check-circle' };

            title.textContent = opts.title || (variant === 'danger' ? 'Error' : variant === 'warning' ? 'Warning' : 'Notice');
            msg.textContent = message;
            icon.className = 'fr-modal-icon ' + variant;
            icon.innerHTML = '<i class="bi ' + (icons[variant] || icons.info) + '"></i>';
            okBtn.textContent = opts.confirmText || 'OK';
            okBtn.className = 'fr-modal-btn fr-modal-btn-confirm';
            cancelBtn.style.display = 'none';

            overlay.classList.add('visible');

            function cleanup() {
                overlay.classList.remove('visible');
                okBtn.removeEventListener('click', onOk);
                overlay.removeEventListener('click', onBackdrop);
                document.removeEventListener('keydown', onKey);
            }
            function onOk() { cleanup(); resolve(); }
            function onBackdrop(e) { if (e.target === overlay) { cleanup(); resolve(); } }
            function onKey(e) { if (e.key === 'Escape') { cleanup(); resolve(); } }

            okBtn.addEventListener('click', onOk);
            overlay.addEventListener('click', onBackdrop);
            document.addEventListener('keydown', onKey);
            okBtn.focus();
        });
    };
</script>

<!-- Charts Row -->
<div class="chart-grid" style="grid-template-columns: <%= data.sources && data.sources.length ? 'repeat(3, minmax(0, 1fr))' : 'repeat(2, minmax(0, 1fr))' %>;">
    <% if (data.giftTypes && data.giftTypes.length) { %>
    <div>
        <div class="section-title">Gift Type Breakdown</div>
        <div class="chart-wrapper"><canvas id="giftTypeDoughnut"></canvas></div>
    </div>
    <% } %>

    <% if (data.sources && data.sources.length) { %>
    <div>
        <div class="section-title">Source Breakdown</div>
        <div class="chart-wrapper"><canvas id="sourcePieChart"></canvas></div>
    </div>
    <% } %>

    <div>
        <div class="section-title">Trend Over Time</div>
        <div class="chart-wrapper"><canvas id="deptTrendChart"></canvas></div>
    </div>
</div>

<!-- Fund Breakdown -->
<% if (data.funds && data.funds.length) { %>
<div class="fr-card">
    <div class="fr-card-header">Fund Breakdown</div>
    <div class="fr-card-body">
        <canvas id="fundBarChart" style="min-height: <%= Math.max(data.funds.length * 30, 200) %>px;"></canvas>
    </div>
</div>
<% } %>

<!-- Raw Data Table -->
<div class="fr-card">
    <div class="fr-card-header">
        <span>Individual Gifts (<%= data.rawCount %> records)</span>
        <input type="text" id="raw-search" class="fr-search" placeholder="Search gifts...">
    </div>
    <div class="fr-table-wrapper">
        <table class="fr-table">
            <thead>
                <tr>
                    <th>Addressee</th>
                    <th>Appeal ID</th>
                    <th class="text-end">Amount</th>
                    <th>Fund</th>
                    <th>Gift Type</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody id="raw-tbody"></tbody>
        </table>
    </div>
    <div class="fr-pagination" id="raw-pagination"></div>
</div>

<% } /* end if data.summary */ %>

<%- include('../partials/footer') %>

<% if (data && data.summary) { %>
<script src="/js/charts.js"></script>
<script>
    const selectedDate = '<%= selectedDate || "" %>';
    const deptSlug = '<%= deptSlug %>';
    const chartColors = ['#2187C5', '#D59D2C', '#1C7BB6', '#52A9DE', '#023D65', '#3a9ad4', '#e8b84d', '#034e82'];

    <% if (data.giftTypes && data.giftTypes.length) { %>
    createDoughnutChart('giftTypeDoughnut',
        <%- JSON.stringify(data.giftTypes.map(g => g.giftType)) %>,
        <%- JSON.stringify(data.giftTypes.map(g => g.amount)) %>,
        chartColors);
    <% } %>

    <% if (data.sources && data.sources.length) { %>
    createPieChart('sourcePieChart',
        <%- JSON.stringify(data.sources.map(s => s.source)) %>,
        <%- JSON.stringify(data.sources.map(s => s.amount)) %>,
        ['#2187C5', '#D59D2C', '#1C7BB6', '#52A9DE']);
    <% } %>

    <% if (data.funds && data.funds.length) { %>
    createHorizontalBarChart('fundBarChart',
        <%- JSON.stringify(data.funds.map(f => f.fundName)) %>,
        <%- JSON.stringify(data.funds.map(f => parseFloat(f.amount) || 0)) %>,
        '#2187C5');
    <% } %>

    // Trend chart
    fetch('/api/trends')
        .then(r => r.json())
        .then(trends => {
            if (trends.length > 0) {
                const dates = trends.map(t => t.date);
                const amounts = trends.map(t => t.departments[deptSlug] ? t.departments[deptSlug].totalAmount : 0);
                const ctx = document.getElementById('deptTrendChart');
                if (ctx) {
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: dates,
                            datasets: [{
                                label: 'Total Amount',
                                data: amounts,
                                borderColor: '#2187C5',
                                backgroundColor: 'rgba(33, 135, 197, 0.08)',
                                tension: 0.3,
                                fill: true,
                                pointRadius: 3,
                                pointBackgroundColor: '#2187C5',
                                borderWidth: 2,
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#1a1a1a',
                                    titleFont: { size: 12 },
                                    bodyFont: { size: 12 },
                                    padding: 8,
                                    cornerRadius: 4,
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: { color: 'rgba(0,0,0,0.04)' },
                                    ticks: {
                                        font: { size: 11 },
                                        color: '#a3a3a3',
                                        callback: v => '$' + (v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v)
                                    }
                                },
                                x: {
                                    grid: { display: false },
                                    ticks: { font: { size: 11 }, color: '#a3a3a3' }
                                }
                            }
                        }
                    });
                }
            } else {
                document.getElementById('deptTrendChart').parentElement.innerHTML =
                    '<p style="text-align:center; color: var(--color-text-tertiary); padding: 40px 0; font-size: 13px;">Upload more snapshots to see trends.</p>';
            }
        });

    // Raw data table
    function loadRawData(page, search) {
        const params = new URLSearchParams({ page, per_page: 50 });
        if (search) params.set('search', search);
        fetch(`/api/snapshot/${selectedDate}/raw/${deptSlug}?${params}`)
            .then(r => r.json())
            .then(data => {
                const tbody = document.getElementById('raw-tbody');
                tbody.innerHTML = data.gifts.map(g => `
                    <tr>
                        <td>${g.primaryAddressee || ''}</td>
                        <td>${g.appealId || ''}</td>
                        <td class="text-end">$${(g.splitAmount || 0).toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                        <td>${g.fundDescription || ''}</td>
                        <td>${g.giftType || ''}</td>
                        <td>${g.giftDate || ''}</td>
                    </tr>
                `).join('');
                const pagDiv = document.getElementById('raw-pagination');
                if (data.pages > 1) {
                    let html = '';
                    for (let i = 1; i <= Math.min(data.pages, 10); i++) {
                        html += `<a href="#" class="${i === data.page ? 'active' : ''}" onclick="loadRawData(${i}, document.getElementById('raw-search').value); return false;">${i}</a>`;
                    }
                    if (data.pages > 10) html += '<span>...</span>';
                    html += `<span class="page-info">Page ${data.page} of ${data.pages} (${data.total} records)</span>`;
                    pagDiv.innerHTML = html;
                } else {
                    pagDiv.innerHTML = `<span class="page-info">${data.total} records</span>`;
                }
            });
    }
    if (selectedDate) loadRawData(1, '');

    let searchTimeout;
    document.getElementById('raw-search')?.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => loadRawData(1, this.value), 300);
    });
</script>
<% } %>
</body>
</html>

<% if (data && data.summary) { %>
<!-- Charts Row -->
<div class="chart-grid" style="grid-template-columns: <%= data.sources && data.sources.length ? 'repeat(3, minmax(0, 1fr))' : 'repeat(2, minmax(0, 1fr))' %>;">
    <% if (data.giftTypes && data.giftTypes.length) { %>
    <div>
        <div class="section-title">Gift Type Breakdown</div>
        <div class="chart-wrapper"><canvas id="giftTypeDoughnut"></canvas></div>
    </div>
    <% } %>

    <% if (data.sources && data.sources.length) { %>
    <div>
        <div class="section-title">Source Breakdown</div>
        <div class="chart-wrapper"><canvas id="sourcePieChart"></canvas></div>
    </div>
    <% } %>

    <div>
        <div class="section-title">Trend Over Time</div>
        <div class="chart-wrapper"><canvas id="deptTrendChart"></canvas></div>
    </div>
</div>

<!-- Gift Distribution + Channel Mix (loaded via API) -->
<div class="chart-grid chart-grid-2">
    <div>
        <div class="section-title">Gift Size Distribution</div>
        <div class="chart-wrapper"><canvas id="deptGiftDistChart"></canvas></div>
    </div>
    <div>
        <div class="section-title" id="channelMixTitle">Channel Mix</div>
        <div class="chart-wrapper"><canvas id="deptChannelChart"></canvas></div>
    </div>
</div>

<!-- Fund Breakdown -->
<% if (data.funds && data.funds.length) { %>
<div class="fr-card">
    <div class="fr-card-header">Fund Breakdown</div>
    <div class="fr-card-body">
        <canvas id="fundBarChart" style="min-height: <%= Math.max(data.funds.length * 30, 200) %>px;"></canvas>
    </div>
</div>
<% } %>

<!-- Top Donors & Appeal Performance side by side (loaded via API) -->
<div class="chart-grid chart-grid-2">
    <div class="fr-card">
        <div class="fr-card-header">Top 10 Donors</div>
        <div class="fr-table-wrapper" style="max-height:400px;">
            <table class="fr-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Donor</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Gifts</th>
                        <th>Last Gift</th>
                    </tr>
                </thead>
                <tbody id="dept-top-donors-tbody">
                    <tr><td colspan="5" class="empty-state">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="fr-card">
        <div class="fr-card-header">Appeal Performance</div>
        <div class="fr-table-wrapper" style="max-height:400px;">
            <table class="fr-table">
                <thead>
                    <tr>
                        <th>Appeal ID</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Gifts</th>
                        <th class="text-end">Donors</th>
                        <th class="text-end">Avg Gift</th>
                    </tr>
                </thead>
                <tbody id="dept-appeals-tbody">
                    <tr><td colspan="5" class="empty-state">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Raw Data Table -->
<div class="fr-card">
    <div class="fr-card-header">
        <span>Individual Gifts (<%= data.rawCount %> records)</span>
        <input type="text" id="raw-search" class="fr-search" placeholder="Search gifts...">
    </div>
    <div class="fr-table-wrapper">
        <table class="fr-table">
            <thead>
                <tr>
                    <th class="sortable" data-sort="primaryAddressee">Addressee <span class="sort-icon"></span></th>
                    <th class="sortable" data-sort="appealId">Appeal ID <span class="sort-icon"></span></th>
                    <th class="sortable text-end active-sort" data-sort="splitAmount">Amount <span class="sort-icon">&#9660;</span></th>
                    <th class="sortable" data-sort="fundDescription">Fund <span class="sort-icon"></span></th>
                    <th class="sortable" data-sort="giftType">Gift Type <span class="sort-icon"></span></th>
                    <th class="sortable" data-sort="giftDate">Date <span class="sort-icon"></span></th>
                </tr>
            </thead>
            <tbody id="raw-tbody"></tbody>
        </table>
    </div>
    <div class="fr-pagination" id="raw-pagination"></div>
</div>
<% } %>

<%- include('../partials/footer') %>

<% if (data && data.summary) { %>
<script src="/js/charts.js"></script>
<script>
    const selectedDate = '<%= selectedDate || "" %>';
    const deptSlug = '<%= deptSlug %>';
    const chartColors = ['#0072BB', '#FFAA00', '#143D8D', '#3a9ad4', '#1a5276', '#0091EA', '#FFc233', '#0d2d6b'];

    <% if (data.giftTypes && data.giftTypes.length) { %>
    createDoughnutChart('giftTypeDoughnut',
        <%- JSON.stringify(data.giftTypes.map(g => g.giftType)) %>,
        <%- JSON.stringify(data.giftTypes.map(g => g.amount)) %>,
        chartColors);
    <% } %>

    <% if (data.sources && data.sources.length) { %>
    createPieChart('sourcePieChart',
        <%- JSON.stringify(data.sources.map(s => s.source)) %>,
        <%- JSON.stringify(data.sources.map(s => s.amount)) %>,
        ['#0072BB', '#FFAA00', '#143D8D', '#3a9ad4']);
    <% } %>

    <% if (data.funds && data.funds.length) { %>
    createHorizontalBarChart('fundBarChart',
        <%- JSON.stringify(data.funds.map(f => f.fundName)) %>,
        <%- JSON.stringify(data.funds.map(f => parseFloat(f.amount) || 0)) %>,
        '#0072BB');
    <% } %>

    // Trend chart
    fetch('/api/trends')
        .then(r => r.json())
        .then(trends => {
            if (trends.length > 0) {
                const dates = trends.map(t => t.date);
                const amounts = trends.map(t => t.departments[deptSlug] ? t.departments[deptSlug].totalAmount : 0);
                const ctx = document.getElementById('deptTrendChart');
                if (ctx) {
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: dates,
                            datasets: [{
                                label: 'Total Amount',
                                data: amounts,
                                borderColor: '#0072BB',
                                backgroundColor: 'rgba(0, 114, 187, 0.08)',
                                tension: 0.3,
                                fill: true,
                                pointRadius: 3,
                                pointBackgroundColor: '#0072BB',
                                borderWidth: 2,
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#143D8D',
                                    titleFont: { size: 12 },
                                    bodyFont: { size: 12 },
                                    padding: 8,
                                    cornerRadius: 4,
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: { color: 'rgba(0,0,0,0.04)' },
                                    ticks: {
                                        font: { size: 11 },
                                        color: '#9ca3af',
                                        callback: v => '$' + (v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v)
                                    }
                                },
                                x: {
                                    grid: { display: false },
                                    ticks: { font: { size: 11 }, color: '#9ca3af' }
                                }
                            }
                        }
                    });
                }
            } else {
                document.getElementById('deptTrendChart').parentElement.innerHTML =
                    '<p style="text-align:center; color: var(--color-text-tertiary); padding: 40px 0; font-size: 13px;">Upload more snapshots to see trends.</p>';
            }
        });

    // Load enhanced department data
    if (selectedDate) {
        fetch('/api/snapshot/' + selectedDate + '/department-enhanced/' + deptSlug)
            .then(r => r.json())
            .then(enhanced => {
                // Gift Distribution
                if (enhanced.giftDistribution && enhanced.giftDistribution.length) {
                    createGiftDistributionChart('deptGiftDistChart',
                        enhanced.giftDistribution.map(d => d.bucket),
                        enhanced.giftDistribution.map(d => d.count),
                        enhanced.giftDistribution.map(d => d.total));
                } else {
                    document.getElementById('deptGiftDistChart').parentElement.innerHTML =
                        '<p style="text-align:center; color: var(--color-text-tertiary); padding: 40px 0; font-size: 13px;">No gift data available.</p>';
                }

                // Channel Mix (annual_giving and direct_mail only)
                if (enhanced.channelTotals) {
                    createChannelMixChart('deptChannelChart', enhanced.channelTotals);
                    // Add rate badges
                    var title = document.getElementById('channelMixTitle');
                    title.innerHTML = 'Channel Mix <span class="status-badge info" style="font-size:10px;margin-left:6px;">' +
                        enhanced.channelTotals.recurringRate.toFixed(1) + '% recurring</span>' +
                        '<span class="status-badge info" style="font-size:10px;margin-left:4px;">' +
                        enhanced.channelTotals.onlineRate.toFixed(1) + '% online</span>';
                } else {
                    document.getElementById('deptChannelChart').parentElement.innerHTML =
                        '<p style="text-align:center; color: var(--color-text-tertiary); padding: 40px 0; font-size: 13px;">Channel data not available for this department.</p>';
                }

                // Top Donors Table
                var donorTbody = document.getElementById('dept-top-donors-tbody');
                if (enhanced.topDonors && enhanced.topDonors.length) {
                    donorTbody.innerHTML = enhanced.topDonors.map(function(d, i) {
                        return '<tr>' +
                            '<td>' + (i + 1) + '</td>' +
                            '<td>' + (d.primaryAddressee || '\u2014') + '</td>' +
                            '<td class="text-end">$' + (d.total || 0).toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td>' +
                            '<td class="text-end">' + d.gifts + '</td>' +
                            '<td>' + (d.last_gift || '\u2014') + '</td>' +
                            '</tr>';
                    }).join('');
                } else {
                    donorTbody.innerHTML = '<tr><td colspan="5" class="empty-state">No donor data</td></tr>';
                }

                // Appeal Performance Table
                var appealTbody = document.getElementById('dept-appeals-tbody');
                if (enhanced.appealPerformance && enhanced.appealPerformance.length) {
                    appealTbody.innerHTML = enhanced.appealPerformance.map(function(a) {
                        return '<tr>' +
                            '<td>' + a.appealId + '</td>' +
                            '<td class="text-end">$' + (a.total || 0).toLocaleString('en-US', {minimumFractionDigits: 2}) + '</td>' +
                            '<td class="text-end">' + a.gifts + '</td>' +
                            '<td class="text-end">' + a.donors + '</td>' +
                            '<td class="text-end">$' + (a.avg_gift || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) + '</td>' +
                            '</tr>';
                    }).join('');
                } else {
                    appealTbody.innerHTML = '<tr><td colspan="5" class="empty-state">No appeal data</td></tr>';
                }
            });
    }

    // Raw data table with sorting
    let currentSort = 'splitAmount';
    let currentOrder = 'DESC';

    function loadRawData(page, search) {
        const params = new URLSearchParams({ page, per_page: 50, sort: currentSort, order: currentOrder });
        if (search) params.set('search', search);
        fetch(`/api/snapshot/${selectedDate}/raw/${deptSlug}?${params}`)
            .then(r => r.json())
            .then(data => {
                const tbody = document.getElementById('raw-tbody');
                tbody.innerHTML = data.gifts.map(g => `
                    <tr>
                        <td>${g.primaryAddressee || ''}</td>
                        <td>${g.appealId || ''}</td>
                        <td class="text-end">$${(g.splitAmount || 0).toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                        <td>${g.fundDescription || ''}</td>
                        <td>${g.giftType || ''}</td>
                        <td>${g.giftDate || ''}</td>
                    </tr>
                `).join('');
                const pagDiv = document.getElementById('raw-pagination');
                if (data.pages > 1) {
                    let html = '';
                    for (let i = 1; i <= Math.min(data.pages, 10); i++) {
                        html += `<a href="#" class="${i === data.page ? 'active' : ''}" onclick="loadRawData(${i}, document.getElementById('raw-search').value); return false;">${i}</a>`;
                    }
                    if (data.pages > 10) html += '<span>...</span>';
                    html += `<span class="page-info">Page ${data.page} of ${data.pages} (${data.total} records)</span>`;
                    pagDiv.innerHTML = html;
                } else {
                    pagDiv.innerHTML = `<span class="page-info">${data.total} records</span>`;
                }
            });
    }

    // Sortable column headers
    document.querySelectorAll('.fr-table th.sortable').forEach(th => {
        th.addEventListener('click', function() {
            const col = this.dataset.sort;
            if (currentSort === col) {
                currentOrder = currentOrder === 'DESC' ? 'ASC' : 'DESC';
            } else {
                currentSort = col;
                currentOrder = col === 'splitAmount' ? 'DESC' : 'ASC';
            }
            // Update header icons
            document.querySelectorAll('.fr-table th.sortable').forEach(h => {
                h.classList.remove('active-sort');
                h.querySelector('.sort-icon').innerHTML = '';
            });
            this.classList.add('active-sort');
            this.querySelector('.sort-icon').innerHTML = currentOrder === 'DESC' ? '\u25BC' : '\u25B2';
            loadRawData(1, document.getElementById('raw-search').value);
        });
    });

    if (selectedDate) loadRawData(1, '');

    let searchTimeout;
    document.getElementById('raw-search')?.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => loadRawData(1, this.value), 300);
    });
</script>
<% } %>
</body>
</html>

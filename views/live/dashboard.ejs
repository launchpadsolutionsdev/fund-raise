<%- include('../partials/header') %>

<% if (typeof comingSoon !== 'undefined' && comingSoon) { %>
<div class="page-header">
    <div>
        <div class="page-greeting">Live Dashboard</div>
        <div class="page-subtitle">Real-time data from Blackbaud RE NXT</div>
    </div>
</div>
<div style="text-align:center;padding:80px 20px;">
    <div style="width:64px;height:64px;border-radius:16px;background:var(--color-background-info);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
        <i class="bi bi-lightning-charge" style="font-size:28px;color:var(--color-brand-blue);"></i>
    </div>
    <h3 style="font-size:20px;font-weight:600;color:var(--color-text-primary);margin:0 0 8px;">Coming Soon</h3>
    <p style="font-size:14px;color:var(--color-text-secondary);max-width:420px;margin:0 auto 24px;line-height:1.6;">
        The Live Dashboard is being upgraded and will be back shortly. In the meantime, you can use
        <a href="/ask" style="color:var(--color-brand-blue);font-weight:500;">Ask Fund-Raise</a>
        with Deep Dive mode to query Blackbaud data in real time.
    </p>
</div>
<%- include('../partials/footer') %>
</body></html>
<% return; } %>

<div class="page-header">
    <div>
        <div class="page-greeting">Live Dashboard <span class="status-badge-dot online"></span></div>
        <div class="page-subtitle">Data from Blackbaud RE NXT &middot; Refreshes every hour</div>
    </div>
    <div style="text-align:right;">
        <button class="btn-brand" id="btn-refresh" onclick="forceRefresh()" style="display:inline-flex;align-items:center;gap:6px;">
            <i class="bi bi-arrow-clockwise"></i> Force Refresh
        </button>
        <div class="text-muted" id="last-updated" style="font-size:12px;margin-top:4px;"></div>
    </div>
</div>

<!-- Loading state -->
<div id="loading-state" style="text-align:center;padding:60px 0;">
    <div class="spinner"></div>
    <p style="color:var(--color-text-secondary);margin-top:16px;">Fetching live data from Blackbaud...</p>
</div>

<!-- Error state -->
<div id="error-state" style="display:none;">
    <div class="alert-card danger">
        <div class="alert-card-title">Connection Error</div>
        <div class="alert-card-text" id="error-message"></div>
    </div>
</div>

<!-- Dashboard content (hidden until data loads) -->
<div id="dashboard-content" style="display:none;">

<!-- Primary KPIs -->
<div class="kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Raised (Last 30 Days)</div>
        <div class="kpi-value" id="kpi-total-raised">—</div>
        <div class="kpi-change info" id="kpi-gift-count-label"></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Average Gift</div>
        <div class="kpi-value" id="kpi-avg-gift">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Largest Gift</div>
        <div class="kpi-value" id="kpi-largest-gift">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Total Constituents</div>
        <div class="kpi-value" id="kpi-constituents">—</div>
    </div>
</div>

<!-- Secondary KPIs -->
<div class="kpi-grid" style="grid-template-columns: repeat(2, minmax(0, 1fr));">
    <div class="kpi-card">
        <div class="kpi-label">Active Campaigns</div>
        <div class="kpi-value" id="kpi-campaigns">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Gifts (Last 30 Days)</div>
        <div class="kpi-value" id="kpi-gift-count">—</div>
    </div>
</div>

<!-- Charts row -->
<div class="fr-card" style="margin-top:20px;">
    <div class="fr-card-header">Revenue by Day (Last 30 Days)</div>
    <div class="fr-card-body" style="padding:16px;">
        <canvas id="chart-daily-revenue" height="260"></canvas>
    </div>
</div>

<!-- Fund Breakdown -->
<div class="fr-card" style="margin-top:20px;">
    <div class="fr-card-header">Revenue by Fund</div>
    <div class="fr-card-body" style="padding:0;">
        <table class="fr-table">
            <thead>
                <tr>
                    <th>Fund</th>
                    <th style="text-align:right;">Total</th>
                    <th style="text-align:right;">Gifts</th>
                </tr>
            </thead>
            <tbody id="fund-breakdown-body">
                <tr><td colspan="3" style="text-align:center;color:var(--color-text-tertiary);">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Active Campaigns -->
<div class="fr-card" style="margin-top:20px;">
    <div class="fr-card-header">Active Campaigns</div>
    <div class="fr-card-body" style="padding:0;">
        <table class="fr-table" id="campaigns-table">
            <thead>
                <tr>
                    <th>Campaign</th>
                    <th>Goal</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                </tr>
            </thead>
            <tbody id="campaigns-body">
                <tr><td colspan="4" style="text-align:center;color:var(--color-text-tertiary);">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Recent Gifts -->
<div class="fr-card" style="margin-top:20px;">
    <div class="fr-card-header">Recent Gifts</div>
    <div class="fr-card-body" style="padding:0;">
        <table class="fr-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Type</th>
                    <th>Fund</th>
                </tr>
            </thead>
            <tbody id="recent-gifts-body">
                <tr><td colspan="4" style="text-align:center;color:var(--color-text-tertiary);">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

</div><!-- end dashboard-content -->

<%- include('../partials/footer') %>

<script>
const fmt = (n) => '$' + (n || 0).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
const fmtDate = (d) => d ? new Date(d).toLocaleDateString() : '—';
let dailyChart = null;

function forceRefresh() { loadDashboard(true); }

async function loadDashboard(force = false) {
    const btn = document.getElementById('btn-refresh');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-arrow-clockwise spin"></i> Loading...';

    try {
        const url = force ? '/api/live/dashboard?force=1' : '/api/live/dashboard';
        const res = await fetch(url);
        if (!res.ok) throw new Error('Failed to load live data');
        const data = await res.json();

        document.getElementById('loading-state').style.display = 'none';
        document.getElementById('error-state').style.display = 'none';
        document.getElementById('dashboard-content').style.display = 'block';

        // KPIs
        const gs = data.giftSummary;
        document.getElementById('kpi-total-raised').textContent = fmt(gs.totalAmount);
        document.getElementById('kpi-avg-gift').textContent = fmt(gs.averageGift);
        document.getElementById('kpi-largest-gift').textContent = fmt(gs.largestGift);
        document.getElementById('kpi-constituents').textContent = (data.constituentSummary.totalConstituents || 0).toLocaleString();
        document.getElementById('kpi-campaigns').textContent = data.campaigns.activeCampaigns || 0;
        document.getElementById('kpi-gift-count').textContent = (gs.giftCount || 0).toLocaleString();
        document.getElementById('kpi-gift-count-label').textContent = (gs.giftCount || 0).toLocaleString() + ' gifts';

        // Daily Revenue Chart
        renderDailyChart(gs.giftsByDay || {});

        // Fund Breakdown Table
        renderFundBreakdown(gs.giftsByFund || {});

        // Campaigns Table
        renderCampaigns(data.campaigns.campaigns || []);

        // Recent Gifts Table
        renderRecentGifts(data.recentGifts.gifts || []);

        // Timestamp
        const fetchedAt = data.fetchedAt ? new Date(data.fetchedAt).toLocaleTimeString() : new Date().toLocaleTimeString();
        const nextRefresh = data.nextRefresh ? new Date(data.nextRefresh).toLocaleTimeString() : '';
        document.getElementById('last-updated').textContent = 'Data from ' + fetchedAt + (nextRefresh ? ' · Next refresh ' + nextRefresh : '');

        // Show errors from individual endpoints
        const errors = [];
        if (gs.error) errors.push('Gifts: ' + gs.error);
        if (data.constituentSummary.error) errors.push('Constituents: ' + data.constituentSummary.error);
        if (data.campaigns.error) errors.push('Campaigns: ' + data.campaigns.error);
        if (errors.length > 0) {
            console.warn('[LIVE] Partial errors:', errors);
        }

    } catch (err) {
        document.getElementById('loading-state').style.display = 'none';
        document.getElementById('error-state').style.display = 'block';
        document.getElementById('error-message').textContent = err.message;
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Refresh';
    }
}

function renderDailyChart(giftsByDay) {
    // Fill in all 30 days (including zeros)
    const days = [];
    for (let i = 29; i >= 0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        days.push(d.toISOString().split('T')[0]);
    }
    const amounts = days.map(d => giftsByDay[d] || 0);
    const labels = days.map(d => {
        const dt = new Date(d + 'T12:00:00');
        return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    });

    const ctx = document.getElementById('chart-daily-revenue').getContext('2d');
    if (dailyChart) dailyChart.destroy();
    dailyChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [{
                label: 'Revenue',
                data: amounts,
                backgroundColor: '#0072BB',
                borderRadius: 3,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { ticks: { maxRotation: 45, font: { size: 11 } } },
                y: {
                    beginAtZero: true,
                    ticks: { callback: v => '$' + (v >= 1000 ? (v/1000).toFixed(0) + 'k' : v) }
                }
            }
        }
    });
}

function renderFundBreakdown(giftsByFund) {
    const tbody = document.getElementById('fund-breakdown-body');
    const funds = Object.entries(giftsByFund)
        .map(([name, data]) => ({ name, ...data }))
        .sort((a, b) => b.total - a.total);

    if (funds.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;color:var(--color-text-tertiary);">No fund data</td></tr>';
        return;
    }
    tbody.innerHTML = funds.slice(0, 20).map(f => `
        <tr>
            <td>${escHtml(f.name)}</td>
            <td style="text-align:right;"><strong>${fmt(f.total)}</strong></td>
            <td style="text-align:right;">${f.count.toLocaleString()}</td>
        </tr>
    `).join('');
}

function renderCampaigns(campaigns) {
    const tbody = document.getElementById('campaigns-body');
    if (campaigns.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--color-text-tertiary);">No active campaigns found</td></tr>';
        return;
    }
    tbody.innerHTML = campaigns.map(c => `
        <tr>
            <td><strong>${escHtml(c.description || c.lookupId || '—')}</strong></td>
            <td>${c.goal ? fmt(c.goal) : '—'}</td>
            <td>${fmtDate(c.startDate)}</td>
            <td>${fmtDate(c.endDate)}</td>
        </tr>
    `).join('');
}

function renderRecentGifts(gifts) {
    const tbody = document.getElementById('recent-gifts-body');
    if (gifts.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--color-text-tertiary);">No recent gifts found</td></tr>';
        return;
    }
    tbody.innerHTML = gifts.slice(0, 25).map(g => `
        <tr>
            <td>${fmtDate(g.date)}</td>
            <td><strong>${fmt(g.amount)}</strong></td>
            <td>${escHtml(g.type || '—')}</td>
            <td>${escHtml(g.fundName || '—')}</td>
        </tr>
    `).join('');
}

function escHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

// Load on page ready
loadDashboard();
</script>

<style>
.spinner {
    width: 36px; height: 36px;
    border: 3px solid var(--color-border-primary);
    border-top-color: var(--color-brand-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto;
}
@keyframes spin { to { transform: rotate(360deg); } }
.spin { animation: spin 0.8s linear infinite; }
.text-muted { color: var(--color-text-tertiary); }
</style>
</body>
</html>

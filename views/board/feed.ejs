<%- include('../partials/header') %>

<div class="fr-hero">
    <div class="fr-hero-icon"><i class="bi bi-pin-angle"></i></div>
    <div class="fr-hero-text">
        <h2>Team Board</h2>
        <p>Share updates, ask questions, and celebrate wins with your Foundation team.</p>
        <div class="fr-hero-chips">
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Announcements</span>
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Questions</span>
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Ideas</span>
            <span class="fr-hero-chip"><i class="bi bi-check-circle-fill"></i> Shout-Outs</span>
        </div>
    </div>
    <div class="fr-hero-actions">
        <button class="fr-hero-btn" id="newPostBtn"><i class="bi bi-plus-lg"></i> New Post</button>
    </div>
</div>

<!-- Category filters -->
<div class="board-filters" id="filters">
    <button class="board-filter active" data-cat="">All</button>
    <button class="board-filter" data-cat="Announcement">Announcement</button>
    <button class="board-filter" data-cat="Question">Question</button>
    <button class="board-filter" data-cat="Idea">Idea</button>
    <button class="board-filter" data-cat="General">General</button>
    <button class="board-filter" data-cat="Shout-Out">Shout-Out</button>
</div>

<div class="board-feed" id="boardFeed">
    <div style="text-align:center;padding:40px;color:var(--color-text-tertiary);font-size:13px;">Loading...</div>
</div>

<div id="loadMore" style="text-align:center;padding:16px;display:none;">
    <button class="btn-secondary" id="loadMoreBtn">Load More</button>
</div>

<!-- New Post Modal -->
<div class="modal-overlay" id="newPostModal" style="display:none;">
    <div class="modal-dialog">
        <div class="modal-header">
            <span>New Post</span>
            <button class="modal-close" id="closeModal"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Title</label>
                <input type="text" class="form-input" id="postTitle" maxlength="255" placeholder="What's on your mind?">
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <div class="writing-options">
                    <button class="writing-option active" data-cat="General">General</button>
                    <button class="writing-option" data-cat="Announcement">Announcement</button>
                    <button class="writing-option" data-cat="Question">Question</button>
                    <button class="writing-option" data-cat="Idea">Idea</button>
                    <button class="writing-option" data-cat="Shout-Out">Shout-Out</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Body</label>
                <textarea class="form-input form-textarea" id="postBody" rows="6" placeholder="Share your thoughts..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" id="cancelPost">Cancel</button>
            <button class="btn-brand" id="submitPost"><i class="bi bi-send"></i> Post</button>
        </div>
    </div>
</div>

<script>
(function() {
    const feed = document.getElementById('boardFeed');
    const modal = document.getElementById('newPostModal');
    const loadMoreDiv = document.getElementById('loadMore');
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    const isAdmin = <%= currentUser && currentUser.isAdmin() ? 'true' : 'false' %>;
    const currentUserId = <%= currentUser ? currentUser.id : 0 %>;

    let currentCategory = '';
    let offset = 0;
    const limit = 20;
    let total = 0;

    // Category filter
    document.getElementById('filters').addEventListener('click', function(e) {
        const btn = e.target.closest('.board-filter');
        if (!btn) return;
        document.querySelectorAll('.board-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCategory = btn.dataset.cat;
        offset = 0;
        loadPosts(true);
    });

    // New post modal
    let selectedCategory = 'General';
    document.getElementById('newPostBtn').addEventListener('click', () => { modal.style.display = 'flex'; });
    document.getElementById('closeModal').addEventListener('click', () => { modal.style.display = 'none'; });
    document.getElementById('cancelPost').addEventListener('click', () => { modal.style.display = 'none'; });
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

    modal.querySelectorAll('.writing-option').forEach(btn => {
        btn.addEventListener('click', function() {
            modal.querySelectorAll('.writing-option').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            selectedCategory = this.dataset.cat;
        });
    });

    document.getElementById('submitPost').addEventListener('click', function() {
        const title = document.getElementById('postTitle').value.trim();
        const body = document.getElementById('postBody').value.trim();
        if (!title || !body) return alert('Title and body are required.');
        this.disabled = true;

        fetch('/api/posts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, body, category: selectedCategory }),
        })
        .then(r => r.json())
        .then(data => {
            if (data.error) throw new Error(data.error);
            modal.style.display = 'none';
            document.getElementById('postTitle').value = '';
            document.getElementById('postBody').value = '';
            offset = 0;
            loadPosts(true);
        })
        .catch(err => alert('Error: ' + err.message))
        .finally(() => { document.getElementById('submitPost').disabled = false; });
    });

    // Load more
    loadMoreBtn.addEventListener('click', () => loadPosts(false));

    function loadPosts(replace) {
        if (replace) offset = 0;
        let url = '/api/posts?limit=' + limit + '&offset=' + offset;
        if (currentCategory) url += '&category=' + encodeURIComponent(currentCategory);

        fetch(url)
            .then(r => r.json())
            .then(data => {
                if (replace) feed.innerHTML = '';
                total = data.total;

                if (data.posts.length === 0 && offset === 0) {
                    feed.innerHTML = '<div style="text-align:center;padding:40px;color:var(--color-text-tertiary);font-size:13px;">No posts yet. Be the first to share!</div>';
                    loadMoreDiv.style.display = 'none';
                    return;
                }

                data.posts.forEach(p => feed.appendChild(createPostCard(p)));
                offset += data.posts.length;
                loadMoreDiv.style.display = offset < total ? 'block' : 'none';
            })
            .catch(() => {
                if (replace) feed.innerHTML = '<div style="text-align:center;padding:40px;color:var(--color-text-danger);">Failed to load posts.</div>';
            });
    }

    function createPostCard(p) {
        const card = document.createElement('div');
        card.className = 'board-post-card' + (p.pinned ? ' pinned' : '');
        card.addEventListener('click', () => { window.location.href = '/board/post/' + p.id; });

        let avatarHtml;
        if (p.author.avatarSrc) {
            avatarHtml = '<img src="' + esc(p.author.avatarSrc) + '" alt="">';
        } else {
            const initials = p.author.displayName.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() || '?';
            avatarHtml = '<span class="board-post-avatar-initials">' + initials + '</span>';
        }

        const catClass = 'board-cat-' + p.category.toLowerCase().replace(/\s+/g, '-');

        card.innerHTML =
            '<div class="board-post-header">' +
                '<div class="board-post-avatar">' + avatarHtml + '</div>' +
                '<div class="board-post-meta">' +
                    '<div class="board-post-author">' + esc(p.author.displayName) + '</div>' +
                    '<div class="board-post-time">' + formatDate(p.createdAt) + '</div>' +
                '</div>' +
            '</div>' +
            '<div class="board-post-title">' + esc(p.title) + '</div>' +
            '<div class="board-post-body-preview">' + esc(p.body) + '</div>' +
            '<div class="board-post-footer">' +
                '<span class="board-category-badge ' + catClass + '">' + esc(p.category) + '</span>' +
                '<span class="board-comment-count"><i class="bi bi-chat-dots"></i> ' + p.commentCount + '</span>' +
                (p.pinned ? '<span class="board-pin-badge"><i class="bi bi-pin-fill"></i> Pinned</span>' : '') +
            '</div>';

        return card;
    }

    function esc(str) {
        return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function formatDate(dateStr) {
        const d = new Date(dateStr);
        const now = new Date();
        const diff = now - d;
        if (diff < 60000) return 'Just now';
        if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';
        if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';
        if (diff < 604800000) return Math.floor(diff / 86400000) + 'd ago';
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    loadPosts(true);
})();
</script>

<%- include('../partials/footer') %>
</body>
</html>

# ─── Fund-Raise Environment Variables ───
# Copy this file to .env and fill in the values.

NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/foundation_dashboard

# Session
SESSION_SECRET=change-me-to-a-random-string

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Token encryption for Blackbaud OAuth tokens (64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Anthropic Claude API (for Ask Fund-Raise AI features)
ANTHROPIC_API_KEY=

# AI Configuration (all optional — sensible defaults built in)
# AI_MODEL=claude-sonnet-4-6
# AI_MAX_TOKENS=4096
# AI_MAX_TOOL_ROUNDS=10
# AI_API_TIMEOUT=90000
# AI_TOOL_TIMEOUT=60000
# AI_MAX_RETRIES=3
# AI_RATE_LIMIT_WINDOW=60000
# AI_RATE_LIMIT_MAX=20
# AI_MAX_CONV_MESSAGES=100
# AI_MAX_MESSAGE_LENGTH=50000

# Email (SMTP) — optional, required for invitation/notification emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Blackbaud RE NXT OAuth — optional, required for live data sync
# BLACKBAUD_CLIENT_ID=
# BLACKBAUD_CLIENT_SECRET=
# BLACKBAUD_REDIRECT_URI=

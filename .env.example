# ─── Fund-Raise Environment Variables ───
# Copy this file to .env and fill in the values.

NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/foundation_dashboard

# Session
SESSION_SECRET=change-me-to-a-random-string

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Token encryption for Blackbaud OAuth tokens (64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Anthropic Claude API (for Ask Fund-Raise AI features)
ANTHROPIC_API_KEY=

# Email (SMTP) — optional, required for invitation/notification emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Blackbaud RE NXT OAuth — optional, required for live data sync
# BLACKBAUD_CLIENT_ID=
# BLACKBAUD_CLIENT_SECRET=
# BLACKBAUD_REDIRECT_URI=
